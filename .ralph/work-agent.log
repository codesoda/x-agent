{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QerPSHoLLWdEXCHMiVXtsS","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# docker-agent: lean Dockerfile linter for coding agents\n     5→# deps: hadolint (required), docker (optional, for build-check)\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→LIB_DIR=\"${SCRIPT_DIR}/../../../lib\"\n     9→# shellcheck source=../../../lib/x-agent-common.sh\n    10→source \"${LIB_DIR}/x-agent-common.sh\"\n    11→\n    12→# ---- Agent-specific knobs ------------------------------------------------\n    13→\n    14→RUN_LINT=\"${RUN_LINT:-1}\"\n    15→RUN_BUILD_CHECK=\"${RUN_BUILD_CHECK:-0}\"  # opt-in, expensive\n    16→\n    17→# ---- Usage ----------------------------------------------------------------\n    18→\n    19→usage() {\n    20→  cat <<'EOF'\n    21→docker-agent — lean Dockerfile linter for coding agents.\n    22→\n    23→Usage: docker-agent.sh [options] [command]\n    24→\n    25→Commands:\n    26→  lint          Run hadolint on discovered Dockerfiles\n    27→  build-check   Run docker build --check (BuildKit lint mode, opt-in)\n    28→  all           Run enabled steps (default: lint only)\n    29→  help          Show this help\n    30→\n    31→Options:\n    32→  --fail-fast   Stop after first failing step\n    33→\n    34→Environment:\n    35→  RUN_LINT=0|1               Toggle lint step (default: 1)\n    36→  RUN_BUILD_CHECK=0|1        Toggle build-check step (default: 0)\n    37→  CHANGED_FILES=\"a b\"        Scope to specific files\n    38→  MAX_LINES=N                Max diagnostic lines per step (default: 40)\n    39→  KEEP_DIR=0|1               Keep temp log dir on success (default: 0)\n    40→  FAIL_FAST=0|1              Stop after first failure (default: 0)\n    41→EOF\n    42→}\n    43→\n    44→# ---- Dockerfile discovery -------------------------------------------------\n    45→\n    46→# Populates DOCKERFILES (newline-separated list of Dockerfile paths).\n    47→discover_dockerfiles() {\n    48→  DOCKERFILES=\"\"\n    49→\n    50→  if [[ -n \"${CHANGED_FILES:-}\" ]]; then\n    51→    local f\n    52→    for f in $CHANGED_FILES; do\n    53→      local base\n    54→      base=\"$(basename \"$f\")\"\n    55→      case \"$base\" in\n    56→        Dockerfile|Dockerfile.*|*.dockerfile)\n    57→          if [[ -f \"$f\" ]]; then\n    58→            if [[ -z \"$DOCKERFILES\" ]]; then\n    59→              DOCKERFILES=\"$f\"\n    60→            else\n    61→              DOCKERFILES=\"${DOCKERFILES}\n    62→$f\"\n    63→            fi\n    64→          fi\n    65→          ;;\n    66→      esac\n    67→    done\n    68→  else\n    69→    # Recursive find, excluding common non-project directories\n    70→    DOCKERFILES=\"$(find . \\\n    71→      -name '.git' -prune -o \\\n    72→      -name 'node_modules' -prune -o \\\n    73→      -name 'vendor' -prune -o \\\n    74→      -type f \\( -name 'Dockerfile' -o -name 'Dockerfile.*' -o -name '*.dockerfile' \\) \\\n    75→      -print | sort)\"\n    76→  fi\n    77→\n    78→  local count=0\n    79→  if [[ -n \"$DOCKERFILES\" ]]; then\n    80→    count=\"$(printf '%s\\n' \"$DOCKERFILES\" | wc -l | tr -d ' ')\"\n    81→  fi\n    82→  echo \"Discovered ${count} Dockerfile(s)\"\n    83→}\n    84→\n    85→# ---- Steps ----------------------------------------------------------------\n    86→\n    87→run_lint() {\n    88→  step \"lint\"\n    89→\n    90→  if [[ -n \"${CHANGED_FILES:-}\" ]] && [[ -z \"$DOCKERFILES\" ]]; then\n    91→    echo\n    92→    echo \"Result: SKIP (no Dockerfiles in CHANGED_FILES)\"\n    93→    fmt_elapsed\n    94→    return 0\n    95→  fi\n    96→\n    97→  if [[ -z \"$DOCKERFILES\" ]]; then\n    98→    echo\n    99→    echo \"Result: SKIP (no Dockerfiles found)\"\n   100→    fmt_elapsed\n   101→    return 0\n   102→  fi\n   103→\n   104→  local log=\"${OUTDIR}/lint.log\"\n   105→  local ok=1\n   106→\n   107→  while IFS= read -r dockerfile; do\n   108→    echo \"--- $dockerfile ---\" >> \"$log\"\n   109→    if ! hadolint \"$dockerfile\" >> \"$log\" 2>&1; then\n   110→      ok=0\n   111→    fi\n   112→  done <<< \"$DOCKERFILES\"\n   113→\n   114→  if [[ \"$ok\" == \"0\" ]]; then\n   115→    echo\n   116→    echo \"Output (first ${MAX_LINES} lines):\"\n   117→    head -n \"$MAX_LINES\" \"$log\"\n   118→  fi\n   119→\n   120→  print_result \"$ok\" \"$log\" \\\n   121→    \"resolve hadolint issues above, then re-run: /docker-agent lint\"\n   122→\n   123→  return $(( 1 - ok ))\n   124→}\n   125→\n   126→run_build_check() {\n   127→  step \"build-check\"\n   128→\n   129→  if ! command -v docker >/dev/null 2>&1; then\n   130→    echo\n   131→    echo \"Result: SKIP (docker not found)\"\n   132→    fmt_elapsed\n   133→    return 0\n   134→  fi\n   135→\n   136→  if [[ -n \"${CHANGED_FILES:-}\" ]] && [[ -z \"$DOCKERFILES\" ]]; then\n   137→    echo\n   138→    echo \"Result: SKIP (no Dockerfiles in CHANGED_FILES)\"\n   139→    fmt_elapsed\n   140→    return 0\n   141→  fi\n   142→\n   143→  if [[ -z \"$DOCKERFILES\" ]]; then\n   144→    echo\n   145→    echo \"Result: SKIP (no Dockerfiles found)\"\n   146→    fmt_elapsed\n   147→    return 0\n   148→  fi\n   149→\n   150→  local log=\"${OUTDIR}/build-check.log\"\n   151→  local ok=1\n   152→\n   153→  while IFS= read -r dockerfile; do\n   154→    echo \"--- $dockerfile ---\" >> \"$log\"\n   155→    if ! docker build --check -f \"$dockerfile\" . >> \"$log\" 2>&1; then\n   156→      ok=0\n   157→    fi\n   158→  done <<< \"$DOCKERFILES\"\n   159→\n   160→  if [[ \"$ok\" == \"0\" ]]; then\n   161→    echo\n   162→    echo \"Output (first ${MAX_LINES} lines):\"\n   163→    head -n \"$MAX_LINES\" \"$log\"\n   164→  fi\n   165→\n   166→  print_result \"$ok\" \"$log\" \\\n   167→    \"resolve build check errors above, then re-run: /docker-agent build-check\"\n   168→\n   169→  return $(( 1 - ok ))\n   170→}\n   171→\n   172→# ---- Main -----------------------------------------------------------------\n   173→\n   174→main() {\n   175→  # Parse help before need() checks so --help works without tools installed\n   176→  case \"${1:-}\" in\n   177→    -h|--help|help)\n   178→      usage\n   179→      exit 0\n   180→      ;;\n   181→  esac\n   182→\n   183→  need hadolint\n   184→\n   185→  setup_outdir \"docker-agent\"\n   186→\n   187→  # Parse flags\n   188→  while [[ \"${1:-}\" == --* ]]; do\n   189→    case \"$1\" in\n   190→      --fail-fast)\n   191→        # shellcheck disable=SC2034\n   192→        FAIL_FAST=1\n   193→        shift\n   194→        ;;\n   195→      *)\n   196→        break\n   197→        ;;\n   198→    esac\n   199→  done\n   200→\n   201→  local cmd=\"${1:-all}\"\n   202→  shift 2>/dev/null || true\n   203→  local overall_ok=1\n   204→\n   205→  discover_dockerfiles\n   206→\n   207→  case \"$cmd\" in\n   208→    lint)\n   209→      run_lint || overall_ok=0\n   210→      ;;\n   211→    build-check)\n   212→      run_build_check || overall_ok=0\n   213→      ;;\n   214→    all)\n   215→      if [[ \"$RUN_LINT\" == \"1\" ]] && should_continue; then run_lint || overall_ok=0; fi\n   216→      if [[ \"$RUN_BUILD_CHECK\" == \"1\" ]] && should_continue; then run_build_check || overall_ok=0; fi\n   217→      ;;\n   218→    *)\n   219→      echo \"Unknown command: $cmd\" >&2\n   220→      usage\n   221→      exit 2\n   222→      ;;\n   223→  esac\n   224→\n   225→  print_overall \"$overall_ok\"\n   226→  [[ \"$overall_ok\" == \"1\" ]]\n   227→}\n   228→\n   229→main \"$@\"\n   230→"}]},"parent_tool_use_id":"toolu_01RpvTQ3WGywDJR35n94b4mq","session_id":"32a521e9-fb0e-42cc-9cbd-d9c4ff505402","uuid":"a88869a1-f75e-4ec9-889a-4e56954bfd84"}
