{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X4Nhnyk4wwDDf7URjbP8zo","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# npm-agent: lean Node.js workflow output for coding agents\n     5→# deps: bash, mktemp\n     6→# optional: biome, eslint, prettier\n     7→\n     8→KEEP_DIR=\"${KEEP_DIR:-0}\"         # set to 1 to keep temp dir even on success\n     9→# In CI, show full output; locally, limit to 40 lines to keep things tidy.\n    10→if [[ \"${CI:-}\" == \"true\" || \"${CI:-}\" == \"1\" ]]; then\n    11→  MAX_LINES=\"${MAX_LINES:-999999}\"\n    12→else\n    13→  MAX_LINES=\"${MAX_LINES:-40}\"\n    14→fi\n    15→RUN_LINT=\"${RUN_LINT:-1}\"         # set to 0 to skip lint\n    16→RUN_TYPECHECK=\"${RUN_TYPECHECK:-1}\" # set to 0 to skip typecheck\n    17→RUN_FORMAT=\"${RUN_FORMAT:-1}\"     # set to 0 to skip format\n    18→RUN_TESTS=\"${RUN_TESTS:-1}\"       # set to 0 to skip tests\n    19→RUN_BUILD=\"${RUN_BUILD:-1}\"       # set to 0 to skip build\n    20→FAIL_FAST=\"${FAIL_FAST:-0}\"      # set to 1 or use --fail-fast to stop after first failure\n    21→CHANGED_FILES=\"${CHANGED_FILES:-}\"  # space-separated list of changed files; scopes lint/format\n    22→\n    23→TMPDIR_ROOT=\"${TMPDIR_ROOT:-/tmp}\"\n    24→OUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/npm-agent.XXXXXX\")\"\n    25→\n    26→cleanup() {\n    27→  local code=\"$?\"\n    28→  if [[ \"$KEEP_DIR\" == \"1\" || \"$code\" != \"0\" ]]; then\n    29→    echo \"Logs kept in: $OUTDIR\"\n    30→  else\n    31→    rm -rf \"$OUTDIR\"\n    32→  fi\n    33→  exit \"$code\"\n    34→}\n    35→trap cleanup EXIT\n    36→\n    37→hr() { echo \"------------------------------------------------------------\"; }\n    38→\n    39→# Returns 0 (continue) unless fail-fast is on and a step already failed.\n    40→should_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n    41→\n    42→STEP_START_SECONDS=0\n    43→\n    44→step() {\n    45→  local name=\"$1\"\n    46→  STEP_START_SECONDS=$SECONDS\n    47→  hr\n    48→  echo \"Step: $name\"\n    49→}\n    50→\n    51→fmt_elapsed() {\n    52→  local elapsed=$(( SECONDS - STEP_START_SECONDS ))\n    53→  echo \"Time: ${elapsed}s\"\n    54→}\n    55→\n    56→# Detect which package manager is in use.\n    57→detect_pm() {\n    58→  if [[ -f \"bun.lock\" || -f \"bun.lockb\" ]]; then echo \"bun\"\n    59→  elif [[ -f \"pnpm-lock.yaml\" ]]; then echo \"pnpm\"\n    60→  elif [[ -f \"yarn.lock\" ]]; then echo \"yarn\"\n    61→  else echo \"npm\"\n    62→  fi\n    63→}\n    64→\n    65→PM=\"$(detect_pm)\"\n    66→echo \"Package manager: $PM\"\n    67→\n    68→# Filter CHANGED_FILES to JS/TS source files for scoping lint/format.\n    69→_CHANGED_SRC_FILES=()\n    70→if [[ -n \"$CHANGED_FILES\" ]]; then\n    71→  for f in $CHANGED_FILES; do\n    72→    case \"$f\" in\n    73→      *.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs|*.mts|*.cts|*.json|*.css|*.scss|*.less|*.html|*.vue|*.svelte)\n    74→        [[ -f \"$f\" ]] && _CHANGED_SRC_FILES+=(\"$f\")\n    75→        ;;\n    76→    esac\n    77→  done\n    78→  if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then\n    79→    echo \"Scoped to ${#_CHANGED_SRC_FILES[@]} changed file(s)\"\n    80→  fi\n    81→fi\n    82→\n    83→# Run a package.json script if it exists, capturing output.\n    84→# Returns 0 if the script ran successfully, 1 if it failed, 2 if script not found.\n    85→run_script() {\n    86→  local script_name=\"$1\"\n    87→  local log=\"$2\"\n    88→\n    89→  # Check if the script exists in package.json\n    90→  if ! node -e \"\n    91→    const pkg = require('./package.json');\n    92→    if (!pkg.scripts || !pkg.scripts['$script_name']) process.exit(1);\n    93→  \" 2>/dev/null; then\n    94→    return 2\n    95→  fi\n    96→\n    97→  if $PM run \"$script_name\" >\"$log\" 2>&1; then\n    98→    return 0\n    99→  else\n   100→    return 1\n   101→  fi\n   102→}\n   103→\n   104→run_format() {\n   105→  step \"format\"\n   106→  local log=\"$OUTDIR/format.log\"\n   107→  local ok=1\n   108→  local found=0\n   109→\n   110→  # Try package.json scripts first\n   111→  for script in format fmt \"format:fix\" \"fmt:fix\" \"format:check\" \"fmt:check\"; do\n   112→    run_script \"$script\" \"$log\"\n   113→    local rc=$?\n   114→    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n   115→    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n   116→  done\n   117→\n   118→  # Fallback: try common formatters directly\n   119→  if [[ \"$found\" == \"0\" ]]; then\n   120→    # Use changed files when available, otherwise check entire project.\n   121→    local -a targets=(.)\n   122→    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n   123→\n   124→    if command -v biome >/dev/null 2>&1; then\n   125→      echo \"Using: biome format\"\n   126→      if biome format \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   127→    elif npx prettier --version >/dev/null 2>&1; then\n   128→      echo \"Using: prettier\"\n   129→      if npx prettier --check \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   130→    fi\n   131→  fi\n   132→\n   133→  if [[ \"$found\" == \"0\" ]]; then\n   134→    echo \"Result: SKIP (no formatter found)\"\n   135→    fmt_elapsed\n   136→    return 0\n   137→  fi\n   138→\n   139→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   140→    echo\n   141→    echo \"Output (first ${MAX_LINES} lines):\"\n   142→    head -n \"$MAX_LINES\" \"$log\"\n   143→  fi\n   144→\n   145→  echo\n   146→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   147→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the formatting issues, then re-run: /npm-agent format\"\n   148→  echo \"Full log: $log\"\n   149→  fmt_elapsed\n   150→  [[ \"$ok\" == \"1\" ]]\n   151→}\n   152→\n   153→run_lint() {\n   154→  step \"lint\"\n   155→  local log=\"$OUTDIR/lint.log\"\n   156→  local ok=1\n   157→  local found=0\n   158→\n   159→  # Try package.json scripts first\n   160→  for script in lint \"lint:fix\" \"lint:check\"; do\n   161→    run_script \"$script\" \"$log\"\n   162→    local rc=$?\n   163→    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n   164→    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n   165→  done\n   166→\n   167→  # Fallback: try common linters directly\n   168→  if [[ \"$found\" == \"0\" ]]; then\n   169→    # Use changed files when available, otherwise check entire project.\n   170→    local -a targets=(.)\n   171→    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n   172→\n   173→    if command -v biome >/dev/null 2>&1; then\n   174→      echo \"Using: biome lint\"\n   175→      if biome lint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   176→    elif npx eslint --version >/dev/null 2>&1; then\n   177→      echo \"Using: eslint\"\n   178→      if npx eslint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   179→    fi\n   180→  fi\n   181→\n   182→  if [[ \"$found\" == \"0\" ]]; then\n   183→    echo \"Result: SKIP (no linter found)\"\n   184→    fmt_elapsed\n   185→    return 0\n   186→  fi\n   187→\n   188→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   189→    echo\n   190→    echo \"Output (first ${MAX_LINES} lines):\"\n   191→    head -n \"$MAX_LINES\" \"$log\"\n   192→  fi\n   193→\n   194→  echo\n   195→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   196→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the lint errors above, then re-run: /npm-agent lint\"\n   197→  echo \"Full log: $log\"\n   198→  fmt_elapsed\n   199→  [[ \"$ok\" == \"1\" ]]\n   200→}\n   201→\n   202→run_typecheck() {\n   203→  step \"typecheck\"\n   204→  local log=\"$OUTDIR/typecheck.log\"\n   205→  local ok=1\n   206→  local found=0\n   207→\n   208→  # Try package.json script