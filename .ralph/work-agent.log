{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UQEP7sgQyVi66bXQWTKaWm","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# kube-agent: lean Kubernetes manifest validator for coding agents\n     5→# deps: kubeconform OR kubeval\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→LIB_DIR=\"${SCRIPT_DIR}/../../../lib\"\n     9→# shellcheck source=../../../lib/x-agent-common.sh\n    10→source \"${LIB_DIR}/x-agent-common.sh\"\n    11→\n    12→# ---- Agent-specific knobs ------------------------------------------------\n    13→\n    14→RUN_VALIDATE=\"${RUN_VALIDATE:-1}\"\n    15→KUBE_SCHEMAS_DIR=\"${KUBE_SCHEMAS_DIR:-}\"\n    16→\n    17→# ---- Usage ----------------------------------------------------------------\n    18→\n    19→usage() {\n    20→  cat <<'EOF'\n    21→kube-agent — lean Kubernetes manifest validator for coding agents.\n    22→\n    23→Usage: kube-agent.sh [options] [command]\n    24→\n    25→Commands:\n    26→  validate  Validate Kubernetes manifests against schemas\n    27→  all       Run validate (default)\n    28→  help      Show this help\n    29→\n    30→Options:\n    31→  --fail-fast   Stop after first failing step\n    32→\n    33→Environment:\n    34→  RUN_VALIDATE=0|1           Toggle validate step (default: 1)\n    35→  KUBE_SCHEMAS_DIR=path      Custom schema location for validator\n    36→  CHANGED_FILES=\"a.yaml b.yml\"  Scope to only these files\n    37→  MAX_LINES=N                Max diagnostic lines per step (default: 40)\n    38→  KEEP_DIR=0|1               Keep temp log dir on success (default: 0)\n    39→  FAIL_FAST=0|1              Stop after first failure (default: 0)\n    40→EOF\n    41→}\n    42→\n    43→# ---- Tool detection -------------------------------------------------------\n    44→\n    45→KUBE_VALIDATOR=\"\"\n    46→\n    47→resolve_validator() {\n    48→  if command -v kubeconform >/dev/null 2>&1; then\n    49→    KUBE_VALIDATOR=\"kubeconform\"\n    50→  elif command -v kubeval >/dev/null 2>&1; then\n    51→    KUBE_VALIDATOR=\"kubeval\"\n    52→  else\n    53→    echo \"Missing required tool: kubeconform or kubeval\" >&2\n    54→    echo \"Install kubeconform: go install github.com/yannh/kubeconform/cmd/kubeconform@latest\" >&2\n    55→    echo \"Or kubeval: https://www.kubeval.com/installation/\" >&2\n    56→    exit 2\n    57→  fi\n    58→  echo \"Validator: $KUBE_VALIDATOR\"\n    59→}\n    60→\n    61→# ---- Manifest discovery ---------------------------------------------------\n    62→\n    63→# Populates MANIFEST_FILES (newline-separated list of K8s manifest paths).\n    64→MANIFEST_FILES=\"\"\n    65→\n    66→discover_manifests() {\n    67→  # Find all .yml/.yaml files, pruning excluded directories\n    68→  local candidates\n    69→  candidates=\"$(find . \\\n    70→    -name .git -prune -o \\\n    71→    -name .github -prune -o \\\n    72→    -name node_modules -prune -o \\\n    73→    -name charts -prune -o \\\n    74→    \\( -name '*.yml' -o -name '*.yaml' \\) -print 2>/dev/null | sort)\" || true\n    75→\n    76→  if [[ -z \"$candidates\" ]]; then\n    77→    return 0\n    78→  fi\n    79→\n    80→  # Apply CHANGED_FILES scoping if set\n    81→  if [[ -n \"${CHANGED_FILES:-}\" ]]; then\n    82→    local scoped=\"\" f candidate\n    83→    for candidate in $candidates; do\n    84→      # Normalize ./path to match CHANGED_FILES entries\n    85→      local norm=\"${candidate#./}\"\n    86→      for f in $CHANGED_FILES; do\n    87→        f=\"${f#./}\"\n    88→        if [[ \"$norm\" == \"$f\" ]]; then\n    89→          if [[ -z \"$scoped\" ]]; then\n    90→            scoped=\"$candidate\"\n    91→          else\n    92→            scoped=\"${scoped}\n    93→${candidate}\"\n    94→          fi\n    95→          break\n    96→        fi\n    97→      done\n    98→    done\n    99→    candidates=\"$scoped\"\n   100→    if [[ -z \"$candidates\" ]]; then\n   101→      echo \"CHANGED_FILES set but no matching YAML files found\"\n   102→      return 0\n   103→    fi\n   104→  fi\n   105→\n   106→  # Filter to Kubernetes manifests: files containing both apiVersion: and kind:\n   107→  local file\n   108→  while IFS= read -r file; do\n   109→    [[ -z \"$file\" ]] && continue\n   110→    [[ -f \"$file\" ]] || continue\n   111→    if grep -q 'apiVersion:' \"$file\" 2>/dev/null && grep -q 'kind:' \"$file\" 2>/dev/null; then\n   112→      if [[ -z \"$MANIFEST_FILES\" ]]; then\n   113→        MANIFEST_FILES=\"$file\"\n   114→      else\n   115→        MANIFEST_FILES=\"${MANIFEST_FILES}\n   116→${file}\"\n   117→      fi\n   118→    fi\n   119→  done <<< \"$candidates\"\n   120→}\n   121→\n   122→# ---- Steps ----------------------------------------------------------------\n   123→\n   124→run_validate() {\n   125→  step \"validate\"\n   126→\n   127→  if [[ -z \"$MANIFEST_FILES\" ]]; then\n   128→    echo\n   129→    echo \"Result: SKIP (no Kubernetes manifests found)\"\n   130→    fmt_elapsed\n   131→    return 0\n   132→  fi\n   133→\n   134→  local count\n   135→  count=\"$(printf '%s\\n' \"$MANIFEST_FILES\" | wc -l | tr -d ' ')\"\n   136→  echo \"Found ${count} Kubernetes manifest(s)\"\n   137→\n   138→  local log=\"${OUTDIR}/validate.log\"\n   139→  local ok=1\n   140→\n   141→  # Build file list as array\n   142→  local files=()\n   143→  while IFS= read -r f; do\n   144→    [[ -n \"$f\" ]] && files+=(\"$f\")\n   145→  done <<< \"$MANIFEST_FILES\"\n   146→\n   147→  if [[ \"$KUBE_VALIDATOR\" == \"kubeconform\" ]]; then\n   148→    local args=(-summary -output json)\n   149→    if [[ -n \"$KUBE_SCHEMAS_DIR\" ]]; then\n   150→      args+=(-schema-location \"$KUBE_SCHEMAS_DIR\")\n   151→    fi\n   152→    if ! kubeconform \"${args[@]}\" \"${files[@]}\" >\"$log\" 2>&1; then\n   153→      ok=0\n   154→    fi\n   155→    # Parse JSON summary for resource counts\n   156→    parse_kubeconform_summary \"$log\"\n   157→  else\n   158→    local args=(--strict)\n   159→    if [[ -n \"$KUBE_SCHEMAS_DIR\" ]]; then\n   160→      args+=(--schema-location \"$KUBE_SCHEMAS_DIR\")\n   161→    fi\n   162→    if ! kubeval \"${args[@]}\" \"${files[@]}\" >\"$log\" 2>&1; then\n   163→      ok=0\n   164→    fi\n   165→    # Parse kubeval output for resource counts\n   166→    parse_kubeval_output \"$log\"\n   167→  fi\n   168→\n   169→  if [[ \"$ok\" == \"0\" ]]; then\n   170→    echo\n   171→    echo \"Output (first ${MAX_LINES} lines):\"\n   172→    head -n \"$MAX_LINES\" \"$log\"\n   173→  fi\n   174→\n   175→  print_result \"$ok\" \"${OUTDIR}/validate.log\" \\\n   176→    \"resolve schema validation errors above, then re-run: /kube-agent validate\"\n   177→\n   178→  return $(( 1 - ok ))\n   179→}\n   180→\n   181→parse_kubeconform_summary() {\n   182→  local log=\"$1\"\n   183→  # kubeconform -output json -summary produces pretty-printed JSON with\n   184→  # a \"summary\" object containing \"valid\", \"invalid\", \"errors\", \"skipped\".\n   185→  # Extract counts with grep+sed — no jq dependency needed.\n   186→  local valid=0 invalid=0 errors=0\n   187→  if [[ -f \"$log\" ]]; then\n   188→    local val\n   189→    val=\"$(grep '\"valid\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n   190→    [[ -n \"$val\" ]] && valid=\"$val\"\n   191→    val=\"$(grep '\"invalid\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n   192→    [[ -n \"$val\" ]] && invalid=\"$val\"\n   193→    val=\"$(grep '\"errors\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n   194→    [[ -n \"$val\" ]] && errors=\"$val\"\n   195→    echo \"Resources: ${valid} valid, ${invalid} invalid, ${errors} errors\"\n   196→  fi\n   197→}\n   198→\n   199→parse_kubeval_output() {\n   200→  local log=\"$1\"\n   201→  if [[ ! -f \"$log\" ]]; then\n   202→    return 0\n   203→  fi\n   204→  # kubeval outputs lines like:\n   205→  #   PASS - file.yaml contains a valid Deployment (apps/v1)\n   206→  #   ERR  - file.yaml contains an invalid Deployment (apps/v1) - ...\n   207→  #   WARN - ...\n   208→  local valid=0 invalid=0 errors=0\n   209→  local line\n   210→  while IFS= read -r line; do\n   211→    case \"$line\" in\n   212→      PASS\\ -*)  valid=$((valid + 1)) ;;\n   213→      ERR\\ -*)   invalid=$((invalid + 1)) ;;\n   214→      WARN\\ -*)  errors=$((errors + 1)) ;;\n   215→    esac\n   216→  done < \"$log\"\n   217→  echo \"Resources: ${valid} valid, ${invalid} invalid, ${errors} warnings\"\n   218→}\n   219→\n   220→# ---- Main -----------------------------------------------------------------\n   221→\n   222→main() {\n   223→  # Parse help before dependency checks so --help works without validators\n   224→  case \"${1:-}\" in\n   225→    -h|--help|help)\n   226→      usage\n   227→      exit 0\n   228→      ;;\n   229→  esac\n   230→\n   231→  resolve_validator\n   232→\n   233→  setup_outdir \"kube-agent\"\n   234→\n   235→  # Parse flags\n   236→  while [[ \"${1:-}\" == --* ]]; do\n   237→    case \"$1\" in\n   238→      --fail-fast)\n   239→        # shellcheck disable=SC2034\n   240→        FAIL_FAST=1\n   241→        shift\n   242→        ;;\n   243→      *)\n   244→        break\n   245→        ;;\n   246→    esac\n   247→  done\n   248→\n   249→  local cmd=\"${1:-all}\"\n   250→  shift 2>/dev/null || true\n   251→  local overall_ok=1\n   252→\n   253→  discover_manifests\n   254→\n   255→  case \"$cmd\" in\n   256→    validate) run_validate || overall_ok=0 ;;\n   257→    all)\n   258→      if [[ \"$RUN_VALIDATE\" == \"1\" ]] && should_continue; then run_validate || overall_ok=0; fi\n   259→      ;;\n   260→    *)\n   261→      echo \"Unknown command: $cmd\" >&2\n   262→      usage\n   263→      exit 2\n   264→      ;;\n   265→  esac\n   266→\n   267→  print_overall \"$overall_ok\"\n   268→  [[ \"$overall_ok\" == \"1\" ]]\n   269→}\n   270→\n   271→main \"$@\"\n   272→"}]},"parent_tool_use_id":null,"session_id":"85fc0a59-c739-40c4-adb1-d8ca4c9716cd","uuid":"95c1787b-c83b-42ac-a122-c4415fd0c547","tool_use_result":{"type":"text","file":{"filePath":"/Users/chrisraethke/projects/x-agent/skills/kube-agent/scripts/kube-agent.sh","content":"#!/usr/bin/env bash\nset -euo pipefail\n\n# kube-agent: lean Kubernetes manifest validator for coding agents\n# deps: kubeconform OR kubeval\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nLIB_DIR=\"${SCRIPT_DIR}/../../../lib\"\n# shellcheck source=../../../lib/x-agent-common.sh\nsource \"${LIB_DIR}/x-agent-common.sh\"\n\n# ---- Agent-specific knobs ------------------------------------------------\n\nRUN_VALIDATE=\"${RUN_VALIDATE:-1}\"\nKUBE_SCHEMAS_DIR=\"${KUBE_SCHEMAS_DIR:-}\"\n\n# ---- Usage ----------------------------------------------------------------\n\nusage() {\n  cat <<'EOF'\nkube-agent — lean Kubernetes manifest validator for coding agents.\n\nUsage: kube-agent.sh [options] [command]\n\nCommands:\n  validate  Validate Kubernetes manifests against schemas\n  all       Run validate (default)\n  help      Show this help\n\nOptions:\n  --fail-fast   Stop after first failing step\n\nEnvironment:\n  RUN_VALIDATE=0|1           Toggle validate step (default: 1)\n  KUBE_SCHEMAS_DIR=path      Custom schema location for validator\n  CHANGED_FILES=\"a.yaml b.yml\"  Scope to only these files\n  MAX_LINES=N                Max diagnostic lines per step (default: 40)\n  KEEP_DIR=0|1               Keep temp log dir on success (default: 0)\n  FAIL_FAST=0|1              Stop after first failure (default: 0)\nEOF\n}\n\n# ---- Tool detection -------------------------------------------------------\n\nKUBE_VALIDATOR=\"\"\n\nresolve_validator() {\n  if command -v kubeconform >/dev/null 2>&1; then\n    KUBE_VALIDATOR=\"kubeconform\"\n  elif command -v kubeval >/dev/null 2>&1; then\n    KUBE_VALIDATOR=\"kubeval\"\n  else\n    echo \"Missing required tool: kubeconform or kubeval\" >&2\n    echo \"Install kubeconform: go install github.com/yannh/kubeconform/cmd/kubeconform@latest\" >&2\n    echo \"Or kubeval: https://www.kubeval.com/installation/\" >&2\n    exit 2\n  fi\n  echo \"Validator: $KUBE_VALIDATOR\"\n}\n\n# ---- Manifest discovery ---------------------------------------------------\n\n# Populates MANIFEST_FILES (newline-separated list of K8s manifest paths).\nMANIFEST_FILES=\"\"\n\ndiscover_manifests() {\n  # Find all .yml/.yaml files, pruning excluded directories\n  local candidates\n  candidates=\"$(find . \\\n    -name .git -prune -o \\\n    -name .github -prune -o \\\n    -name node_modules -prune -o \\\n    -name charts -prune -o \\\n    \\( -name '*.yml' -o -name '*.yaml' \\) -print 2>/dev/null | sort)\" || true\n\n  if [[ -z \"$candidates\" ]]; then\n    return 0\n  fi\n\n  # Apply CHANGED_FILES scoping if set\n  if [[ -n \"${CHANGED_FILES:-}\" ]]; then\n    local scoped=\"\" f candidate\n    for candidate in $candidates; do\n      # Normalize ./path to match CHANGED_FILES entries\n      local norm=\"${candidate#./}\"\n      for f in $CHANGED_FILES; do\n        f=\"${f#./}\"\n        if [[ \"$norm\" == \"$f\" ]]; then\n          if [[ -z \"$scoped\" ]]; then\n            scoped=\"$candidate\"\n          else\n            scoped=\"${scoped}\n${candidate}\"\n          fi\n          break\n        fi\n      done\n    done\n    candidates=\"$scoped\"\n    if [[ -z \"$candidates\" ]]; then\n      echo \"CHANGED_FILES set but no matching YAML files found\"\n      return 0\n    fi\n  fi\n\n  # Filter to Kubernetes manifests: files containing both apiVersion: and kind:\n  local file\n  while IFS= read -r file; do\n    [[ -z \"$file\" ]] && continue\n    [[ -f \"$file\" ]] || continue\n    if grep -q 'apiVersion:' \"$file\" 2>/dev/null && grep -q 'kind:' \"$file\" 2>/dev/null; then\n      if [[ -z \"$MANIFEST_FILES\" ]]; then\n        MANIFEST_FILES=\"$file\"\n      else\n        MANIFEST_FILES=\"${MANIFEST_FILES}\n${file}\"\n      fi\n    fi\n  done <<< \"$candidates\"\n}\n\n# ---- Steps ----------------------------------------------------------------\n\nrun_validate() {\n  step \"validate\"\n\n  if [[ -z \"$MANIFEST_FILES\" ]]; then\n    echo\n    echo \"Result: SKIP (no Kubernetes manifests found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  local count\n  count=\"$(printf '%s\\n' \"$MANIFEST_FILES\" | wc -l | tr -d ' ')\"\n  echo \"Found ${count} Kubernetes manifest(s)\"\n\n  local log=\"${OUTDIR}/validate.log\"\n  local ok=1\n\n  # Build file list as array\n  local files=()\n  while IFS= read -r f; do\n    [[ -n \"$f\" ]] && files+=(\"$f\")\n  done <<< \"$MANIFEST_FILES\"\n\n  if [[ \"$KUBE_VALIDATOR\" == \"kubeconform\" ]]; then\n    local args=(-summary -output json)\n    if [[ -n \"$KUBE_SCHEMAS_DIR\" ]]; then\n      args+=(-schema-location \"$KUBE_SCHEMAS_DIR\")\n    fi\n    if ! kubeconform \"${args[@]}\" \"${files[@]}\" >\"$log\" 2>&1; then\n      ok=0\n    fi\n    # Parse JSON summary for resource counts\n    parse_kubeconform_summary \"$log\"\n  else\n    local args=(--strict)\n    if [[ -n \"$KUBE_SCHEMAS_DIR\" ]]; then\n      args+=(--schema-location \"$KUBE_SCHEMAS_DIR\")\n    fi\n    if ! kubeval \"${args[@]}\" \"${files[@]}\" >\"$log\" 2>&1; then\n      ok=0\n    fi\n    # Parse kubeval output for resource counts\n    parse_kubeval_output \"$log\"\n  fi\n\n  if [[ \"$ok\" == \"0\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  print_result \"$ok\" \"${OUTDIR}/validate.log\" \\\n    \"resolve schema validation errors above, then re-run: /kube-agent validate\"\n\n  return $(( 1 - ok ))\n}\n\nparse_kubeconform_summary() {\n  local log=\"$1\"\n  # kubeconform -output json -summary produces pretty-printed JSON with\n  # a \"summary\" object containing \"valid\", \"invalid\", \"errors\", \"skipped\".\n  # Extract counts with grep+sed — no jq dependency needed.\n  local valid=0 invalid=0 errors=0\n  if [[ -f \"$log\" ]]; then\n    local val\n    val=\"$(grep '\"valid\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n    [[ -n \"$val\" ]] && valid=\"$val\"\n    val=\"$(grep '\"invalid\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n    [[ -n \"$val\" ]] && invalid=\"$val\"\n    val=\"$(grep '\"errors\"' \"$log\" | tail -1 | sed 's/[^0-9]//g')\" || true\n    [[ -n \"$val\" ]] && errors=\"$val\"\n    echo \"Resources: ${valid} valid, ${invalid} invalid, ${errors} errors\"\n  fi\n}\n\nparse_kubeval_output() {\n  local log=\"$1\"\n  if [[ ! -f \"$log\" ]]; then\n    return 0\n  fi\n  # kubeval outputs lines like:\n  #   PASS - file.yaml contains a valid Deployment (apps/v1)\n  #   ERR  - file.yaml contains an invalid Deployment (apps/v1) - ...\n  #   WARN - ...\n  local valid=0 invalid=0 errors=0\n  local line\n  while IFS= read -r line; do\n    case \"$line\" in\n      PASS\\ -*)  valid=$((valid + 1)) ;;\n      ERR\\ -*)   invalid=$((invalid + 1)) ;;\n      WARN\\ -*)  errors=$((errors + 1)) ;;\n    esac\n  done < \"$log\"\n  echo \"Resources: ${valid} valid, ${invalid} invalid, ${errors} warnings\"\n}\n\n# ---- Main -----------------------------------------------------------------\n\nmain() {\n  # Parse help before dependency checks so --help works without validators\n  case \"${1:-}\" in\n    -h|--help|help)\n      usage\n      exit 0\n      ;;\n  esac\n\n  resolve_validator\n\n  setup_outdir \"kube-agent\"\n\n  # Parse flags\n  while [[ \"${1:-}\" == --* ]]; do\n    case \"$1\" in\n      --fail-fast)\n        # shellcheck disable=SC2034\n        FAIL_FAST=1\n        shift\n        ;;\n      *)\n        break\n        ;;\n    esac\n  done\n\n  local cmd=\"${1:-all}\"\n  shift 2>/dev/null || true\n  local overall_ok=1\n\n  discover_manifests\n\n  case \"$cmd\" in\n    validate) run_validate || overall_ok=0 ;;\n    all)\n      if [[ \"$RUN_VALIDATE\" == \"1\" ]] && should_continue; then run_validate || overall_ok=0; fi\n      ;;\n    *)\n      echo \"Unknown command: $cmd\" >&2\n      usage\n      exit 2\n      ;;\n  esac\n\n  print_overall \"$overall_ok\"\n  [[ \"$overall_ok\" == \"1\" ]]\n}\n\nmain \"$@\"\n","numLines":272,"startLine":1,"totalLines":272}}}
