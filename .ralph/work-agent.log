{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YT1FBuXn7NLqrmsAa4jWKb","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# x-agent-common.sh — shared boilerplate for x-agent workflow runners.\n     3→# Source this file from agent scripts; it produces no output or side effects.\n     4→# Bash 3.2 compatible.\n     5→\n     6→# ---------------------------------------------------------------------------\n     7→# Environment defaults (agent can override after sourcing)\n     8→# ---------------------------------------------------------------------------\n     9→\n    10→KEEP_DIR=\"${KEEP_DIR:-0}\"\n    11→FAIL_FAST=\"${FAIL_FAST:-0}\"\n    12→CHANGED_FILES=\"${CHANGED_FILES:-}\"\n    13→TMPDIR_ROOT=\"${TMPDIR_ROOT:-/tmp}\"\n    14→\n    15→# CI-aware MAX_LINES: unlimited in CI, concise locally.\n    16→if [[ \"${CI:-}\" == \"true\" || \"${CI:-}\" == \"1\" ]]; then\n    17→  MAX_LINES=\"${MAX_LINES:-999999}\"\n    18→else\n    19→  MAX_LINES=\"${MAX_LINES:-40}\"\n    20→fi\n    21→\n    22→# ---------------------------------------------------------------------------\n    23→# Output helpers\n    24→# ---------------------------------------------------------------------------\n    25→\n    26→hr() { echo \"------------------------------------------------------------\"; }\n    27→\n    28→STEP_START_SECONDS=0\n    29→\n    30→step() {\n    31→  local name=\"$1\"\n    32→  STEP_START_SECONDS=$SECONDS\n    33→  hr\n    34→  echo \"Step: $name\"\n    35→}\n    36→\n    37→fmt_elapsed() {\n    38→  local elapsed=$(( SECONDS - STEP_START_SECONDS ))\n    39→  echo \"Time: ${elapsed}s\"\n    40→}\n    41→\n    42→# ---------------------------------------------------------------------------\n    43→# Flow control\n    44→# ---------------------------------------------------------------------------\n    45→\n    46→# Returns 0 (continue) unless fail-fast is on and a step already failed.\n    47→# Caller must declare `overall_ok` before use.\n    48→should_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n    49→\n    50→# ---------------------------------------------------------------------------\n    51→# Dependency checking\n    52→# ---------------------------------------------------------------------------\n    53→\n    54→need() {\n    55→  command -v \"$1\" >/dev/null 2>&1 || { echo \"Missing required tool: $1\" >&2; exit 2; }\n    56→}\n    57→\n    58→# ---------------------------------------------------------------------------\n    59→# Setup helpers (called explicitly by agents, not auto-executed)\n    60→# ---------------------------------------------------------------------------\n    61→\n    62→# Create a temp output directory and install a cleanup trap.\n    63→# Usage: setup_outdir <agent-name>\n    64→# Sets: OUTDIR\n    65→setup_outdir() {\n    66→  local agent_name=\"$1\"\n    67→  OUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/${agent_name}.XXXXXX\")\"\n    68→\n    69→  # Define the cleanup function inside setup_outdir so it captures OUTDIR.\n    70→  _xagent_cleanup() {\n    71→    local code=\"$?\"\n    72→    if [[ \"${KEEP_DIR:-0}\" == \"1\" || \"$code\" != \"0\" ]]; then\n    73→      echo \"Logs kept in: $OUTDIR\"\n    74→    else\n    75→      rm -rf \"$OUTDIR\"\n    76→    fi\n    77→    exit \"$code\"\n    78→  }\n    79→\n    80→  trap _xagent_cleanup EXIT\n    81→}\n    82→\n    83→# Acquire a workflow lock to prevent concurrent agent runs.\n    84→# Usage: setup_lock <agent-name>\n    85→setup_lock() {\n    86→  local agent_name=\"$1\"\n    87→  local lockfile=\"${TMPDIR_ROOT%/}/${agent_name}.lock\"\n    88→\n    89→  # Open fd 9 for locking.\n    90→  exec 9>\"$lockfile\"\n    91→\n    92→  if command -v flock >/dev/null 2>&1; then\n    93→    if ! flock -n 9; then\n    94→      echo \"${agent_name}: waiting for another run to finish...\"\n    95→      flock 9\n    96→    fi\n    97→  elif command -v perl >/dev/null 2>&1; then\n    98→    # macOS: flock not available, use perl as a portable fallback.\n    99→    perl -e '\n   100→      use Fcntl \":flock\";\n   101→      open(my $fh, \">&=\", 9) or die \"fdopen: $!\";\n   102→      if (!flock($fh, LOCK_EX | LOCK_NB)) {\n   103→        print STDERR \"'\"${agent_name}\"': waiting for another run to finish...\\n\";\n   104→        flock($fh, LOCK_EX) or die \"flock: $!\";\n   105→      }\n   106→    '\n   107→  else\n   108→    echo \"Warning: neither flock nor perl available; skipping workflow lock\" >&2\n   109→  fi\n   110→}\n   111→\n   112→# ---------------------------------------------------------------------------\n   113→# Result formatting\n   114→# ---------------------------------------------------------------------------\n   115→\n   116→# Print a step result with optional fix hint.\n   117→# Usage: print_result <ok> <log_path> [fix_hint]\n   118→#   ok: \"1\" for pass, \"0\" for fail\n   119→#   log_path: path to the full log file\n   120→#   fix_hint: text shown only on failure (optional but expected on FAIL)\n   121→print_result() {\n   122→  local ok=\"$1\"\n   123→  local log_path=\"$2\"\n   124→  local fix_hint=\"${3:-}\"\n   125→\n   126→  echo\n   127→  if [[ \"$ok\" == \"1\" ]]; then\n   128→    echo \"Result: PASS\"\n   129→  else\n   130→    echo \"Result: FAIL\"\n   131→    if [[ -n \"$fix_hint\" ]]; then\n   132→      echo \"Fix: $fix_hint\"\n   133→    fi\n   134→  fi\n   135→  echo \"Full log: $log_path\"\n   136→  fmt_elapsed\n   137→}\n   138→\n   139→# Print the final overall summary.\n   140→# Usage: print_overall <overall_ok>\n   141→#   overall_ok: \"1\" for pass, \"0\" for fail\n   142→# The caller should exit with the appropriate code after calling this.\n   143→print_overall() {\n   144→  local overall_ok=\"$1\"\n   145→  hr\n   146→  if [[ \"$overall_ok\" == \"1\" ]]; then\n   147→    echo \"Overall: PASS\"\n   148→  else\n   149→    echo \"Overall: FAIL\"\n   150→  fi\n   151→  echo \"Logs: $OUTDIR\"\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_01BEJvUovoZReNGGRcar99ZU","session_id":"be0e30e7-8817-4b77-ad57-f2dbd38ea5b9","uuid":"5aa12b1a-8e6d-461c-9d10-7854431c60a4"}
