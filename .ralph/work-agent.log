n   126→  local scripts=()\n   127→  while IFS= read -r -d '' f; do\n   128→    scripts+=(\"$f\")\n   129→  done < <(find \"$ROOT_DIR/skills\" -name '*.sh' -print0; find \"$TESTS_DIR\" -name '*.sh' -print0; find \"$ROOT_DIR\" -maxdepth 1 -name '*.sh' -print0)\n   130→\n   131→  if shellcheck --severity=warning \"${scripts[@]}\" >/dev/null 2>&1; then\n   132→    print_status \"PASS\" \"shellcheck\"\n   133→    return 0\n   134→  fi\n   135→\n   136→  print_status \"FAIL\" \"shellcheck\"\n   137→  shellcheck --severity=warning \"${scripts[@]}\" | sed 's/^/    /'\n   138→  return 1\n   139→}\n   140→\n   141→main() {\n   142→  local mode=\"${1:-run}\"\n   143→  local filter=\"\"\n   144→\n   145→  case \"$mode\" in\n   146→    -h|--help|help)\n   147→      usage\n   148→      exit 0\n   149→      ;;\n   150→    --list)\n   151→      while IFS= read -r scenario_file; do\n   152→        scenario_label_from_file \"$scenario_file\"\n   153→      done < <(list_scenarios)\n   154→      exit 0\n   155→      ;;\n   156→    *)\n   157→      if [[ \"$#\" -gt 0 ]]; then\n   158→        filter=\"$1\"\n   159→      fi\n   160→      ;;\n   161→  esac\n   162→\n   163→  local total=0\n   164→  local failed=0\n   165→\n   166→  # Run shellcheck if no filter or filter matches \"shellcheck\"\n   167→  if [[ -z \"$filter\" || \"shellcheck\" == *\"$filter\"* ]]; then\n   168→    total=$((total + 1))\n   169→    if ! run_shellcheck; then\n   170→      failed=$((failed + 1))\n   171→    fi\n   172→  fi\n   173→\n   174→  while IFS= read -r scenario_file; do\n   175→    if [[ -n \"$filter\" && \"$scenario_file\" != *\"$filter\"* ]]; then\n   176→      continue\n   177→    fi\n   178→\n   179→    total=$((total + 1))\n   180→    if ! run_one \"$scenario_file\"; then\n   181→      failed=$((failed + 1))\n   182→    fi\n   183→  done < <(list_scenarios)\n   184→\n   185→  echo \"------\"\n   186→  echo \"Scenarios run: $total\"\n   187→  echo \"Failures: $failed\"\n   188→  [[ \"$failed\" -eq 0