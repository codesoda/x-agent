{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KhfCUfFtWHp1KvKhZEQpPs","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# terra-agent: lean Terraform workflow output for coding agents\n     5→# deps: bash, mktemp, terraform\n     6→# optional: tflint\n     7→\n     8→KEEP_DIR=\"${KEEP_DIR:-0}\"              # set to 1 to keep temp dir even on success\n     9→# In CI, show full output; locally, limit to 40 lines to keep things tidy.\n    10→if [[ \"${CI:-}\" == \"true\" || \"${CI:-}\" == \"1\" ]]; then\n    11→  MAX_LINES=\"${MAX_LINES:-999999}\"\n    12→else\n    13→  MAX_LINES=\"${MAX_LINES:-40}\"\n    14→fi\n    15→RUN_FMT=\"${RUN_FMT:-1}\"                # set to 0 to skip fmt\n    16→RUN_INIT=\"${RUN_INIT:-1}\"              # set to 0 to skip init\n    17→RUN_VALIDATE=\"${RUN_VALIDATE:-1}\"      # set to 0 to skip validate\n    18→RUN_LINT=\"${RUN_LINT:-1}\"              # set to 0 to skip lint\n    19→RUN_PLAN_SAFE=\"${RUN_PLAN_SAFE:-0}\"    # set to 1 to run plan-safe in all\n    20→FMT_MODE=\"${FMT_MODE:-check}\"          # check|fix\n    21→FMT_RECURSIVE=\"${FMT_RECURSIVE:-1}\"    # set to 0 to disable recursive fmt\n    22→TFLINT_RECURSIVE=\"${TFLINT_RECURSIVE:-1}\" # set to 0 to disable recursive tflint\n    23→TERRAFORM_CHDIR=\"${TERRAFORM_CHDIR:-${TF_CHDIR:-.}}\"\n    24→FAIL_FAST=\"${FAIL_FAST:-0}\"           # set to 1 or use --fail-fast to stop after first failure\n    25→CHANGED_FILES=\"${CHANGED_FILES:-}\"    # space-separated list; auto-sets TERRAFORM_CHDIR from .tf files\n    26→\n    27→TMPDIR_ROOT=\"${TMPDIR_ROOT:-/tmp}\"\n    28→OUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/terra-agent.XXXXXX\")\"\n    29→TF_DATA_DIR_PATH=\"${TF_DATA_DIR:-$OUTDIR/tf-data}\"\n    30→\n    31→cleanup() {\n    32→  local code=\"$?\"\n    33→  if [[ \"$KEEP_DIR\" == \"1\" || \"$code\" != \"0\" ]]; then\n    34→    echo \"Logs kept in: $OUTDIR\"\n    35→  else\n    36→    rm -rf \"$OUTDIR\"\n    37→  fi\n    38→  exit \"$code\"\n    39→}\n    40→trap cleanup EXIT\n    41→\n    42→need() {\n    43→  command -v \"$1\" >/dev/null 2>&1 || { echo \"Missing required tool: $1\" >&2; exit 2; }\n    44→}\n    45→\n    46→hr() { echo \"------------------------------------------------------------\"; }\n    47→\n    48→# Returns 0 (continue) unless fail-fast is on and a step already failed.\n    49→should_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n    50→\n    51→STEP_START_SECONDS=0\n    52→\n    53→step() {\n    54→  local name=\"$1\"\n    55→  STEP_START_SECONDS=$SECONDS\n    56→  hr\n    57→  echo \"Step: $name\"\n    58→}\n    59→\n    60→fmt_elapsed() {\n    61→  local elapsed=$(( SECONDS - STEP_START_SECONDS ))\n    62→  echo \"Time: ${elapsed}s\"\n    63→}\n    64→\n    65→normalize_dir() {\n    66→  if [[ -z \"$TERRAFORM_CHDIR\" ]]; then\n    67→    TERRAFORM_CHDIR=\".\"\n    68→  fi\n    69→}\n    70→\n    71→# If CHANGED_FILES is set and TERRAFORM_CHDIR was not explicitly provided,\n    72→# auto-detect the terraform root from changed .tf files.\n    73→resolve_changed_tf_dir() {\n    74→  if [[ -z \"$CHANGED_FILES\" ]]; then return; fi\n    75→  # Only auto-detect when TERRAFORM_CHDIR is the default.\n    76→  if [[ \"$TERRAFORM_CHDIR\" != \".\" ]]; then return; fi\n    77→\n    78→  local dirs=\"\"\n    79→  local f dir\n    80→  for f in $CHANGED_FILES; do\n    81→    case \"$f\" in\n    82→      *.tf|*.tf.json)\n    83→        dir=\"$(dirname \"$f\")\"\n    84→        if ! echo \"$dirs\" | grep -Fxq \"$dir\"; then\n    85→          dirs=\"${dirs:+$dirs$'\\n'}$dir\"\n    86→        fi\n    87→        ;;\n    88→    esac\n    89→  done\n    90→\n    91→  if [[ -z \"$dirs\" ]]; then return; fi\n    92→  local count\n    93→  count=\"$(echo \"$dirs\" | wc -l | tr -d ' ')\"\n    94→  if [[ \"$count\" == \"1\" ]]; then\n    95→    TERRAFORM_CHDIR=\"$dirs\"\n    96→    echo \"Auto-detected TERRAFORM_CHDIR=$TERRAFORM_CHDIR from changed files\"\n    97→  else\n    98→    echo \"Note: changed .tf files span multiple directories, running from .\"\n    99→  fi\n   100→}\n   101→\n   102→normalize_fmt_mode() {\n   103→  case \"$1\" in\n   104→    check|fix) return 0 ;;\n   105→    *)\n   106→      echo \"Invalid fmt mode: $1 (expected check or fix)\" >&2\n   107→      exit 2\n   108→      ;;\n   109→  esac\n   110→}\n   111→\n   112→tf() {\n   113→  if [[ \"$TERRAFORM_CHDIR\" == \".\" ]]; then\n   114→    TF_DATA_DIR=\"$TF_DATA_DIR_PATH\" terraform \"$@\"\n   115→  else\n   116→    TF_DATA_DIR=\"$TF_DATA_DIR_PATH\" terraform \"-chdir=$TERRAFORM_CHDIR\" \"$@\"\n   117→  fi\n   118→}\n   119→\n   120→ensure_terraform_project() {\n   121→  if [[ ! -d \"$TERRAFORM_CHDIR\" ]]; then\n   122→    echo \"Error: TERRAFORM_CHDIR does not exist: $TERRAFORM_CHDIR\" >&2\n   123→    exit 2\n   124→  fi\n   125→\n   126→  if ! find \"$TERRAFORM_CHDIR\" -type f \\( -name \"*.tf\" -o -name \"*.tf.json\" \\) | grep -q .; then\n   127→    echo \"Error: no Terraform files found in $TERRAFORM_CHDIR\" >&2\n   128→    exit 2\n   129→  fi\n   130→}\n   131→\n   132→run_fmt() {\n   133→  local mode=\"$1\"\n   134→  normalize_fmt_mode \"$mode\"\n   135→\n   136→  step \"fmt\"\n   137→  local log=\"$OUTDIR/fmt.${mode}.log\"\n   138→  local ok=1\n   139→  local -a args=(fmt)\n   140→\n   141→  if [[ \"$mode\" == \"check\" ]]; then\n   142→    args+=(\"-check\")\n   143→  fi\n   144→  if [[ \"$FMT_RECURSIVE\" == \"1\" ]]; then\n   145→    args+=(\"-recursive\")\n   146→  fi\n   147→\n   148→  echo \"Mode: $mode\"\n   149→  if tf \"${args[@]}\" >\"$log\" 2>&1; then\n   150→    :\n   151→  else\n   152→    ok=0\n   153→  fi\n   154→\n   155→  if [[ \"$mode\" == \"check\" && \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   156→    echo\n   157→    echo \"Files needing formatting (first ${MAX_LINES} lines):\"\n   158→    head -n \"$MAX_LINES\" \"$log\"\n   159→  fi\n   160→\n   161→  if [[ \"$mode\" == \"fix\" && -s \"$log\" ]]; then\n   162→    echo\n   163→    echo \"Files formatted (first ${MAX_LINES} lines):\"\n   164→    head -n \"$MAX_LINES\" \"$log\"\n   165→  fi\n   166→\n   167→  echo\n   168→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   169→  if [[ \"$ok\" == \"0\" && \"$mode\" == \"check\" ]]; then\n   170→    echo \"Fix: run /terra-agent fmt-fix to auto-format, then re-check: /terra-agent fmt-check\"\n   171→  elif [[ \"$ok\" == \"0\" ]]; then\n   172→    echo \"Fix: resolve the errors above, then re-run: /terra-agent fmt-fix\"\n   173→  fi\n   174→  echo \"Full log: $log\"\n   175→  fmt_elapsed\n   176→  [[ \"$ok\" == \"1\" ]]\n   177→}\n   178→\n   179→run_validate() {\n   180→  step \"validate\"\n   181→  local log=\"$OUTDIR/validate.log\"\n   182→  local ok=1\n   183→\n   184→  if tf validate -no-color >\"$log\" 2>&1; then\n   185→    :\n   186→  else\n   187→    ok=0\n   188→  fi\n   189→\n   190→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   191→    echo\n   192→    echo \"Output (first ${MAX_LINES} lines):\"\n   193→    head -n \"$MAX_LINES\" \"$log\"\n   194→  fi\n   195→\n   196→  echo\n   197→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   198→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the validation errors above, then re-run: /terra-agent validate\"\n   199→  echo \"Full log: $log\"\n   200→  fmt_elapsed\n   201→  [[ \"$ok\" == \"1\" ]]\n   202→}\n   203→\n   204→run_init() {\n   205→  step \"init\"\n   206→  local log=\"$OUTDIR/init.log\"\n   207→  local ok=1\n   208→  local -a args=(\n   209→    init\n   210→    -backend=false\n   211→    -input=false\n   212→    -lockfile=readonly\n   213→    -get=false\n   214→    -upgrade=false\n   215→    -no-color\n   216→  )\n   217→\n   218→  # Safety guarantees:\n   219→  # - no backend init\n   220→  # - no prompts\n   221→  # - no module downloads/upgrades\n   222→  # - lockfile must stay unchanged\n   223→  # - TF_DATA_DIR points at temp output dir, not the project\n   224→  if tf \"${args[@]}\" >\"$log\" 2>&1; then\n   225→    :\n   226→  else\n   227→    ok=0\n   228→  fi\n   229→\n   230→  echo \"Mode: safe (non-mutating)\"\n   231→  echo \"TF_DATA_DIR: $TF_DATA_DIR_PATH\"\n   232→\n   233→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   234→    echo\n   235→    echo \"Output (first ${MAX_LINES} lines):\"\n   236→    head -n \"$MAX_LINES\" \"$log\"\n   237→  fi\n   238→\n   239→  echo\n   240→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   241→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the init errors above, then re-run: /terra-agent init\"\n   242→  echo \"Full log: $log\"\n   243→  fmt_elapsed\n   244→  [[ \"$ok\" == \"1\" ]]\n   245→}\n   246→\n   247→run_plan_safe() {\n   248→  step \"plan-safe\"\n   249→  local init_log=\"$OUTDIR/plan-safe.init.log\"\n   250→  local log=\"$OUTDIR/plan-safe.log\"\n   251→  local ok=1\n   252→  local changed=0\n   253→  local rc=0\n   254→  local -a init_args=(\n   255→    init\n   256→    -backend=false\n   257→    -input=false\n   258→    -lockfile=readonly\n   259→    -get=false\n   260→    -upgrade=false\n   261→    -no-color\n   262→  )\n   263→  local -a plan_args=(\n   264→    plan\n   265→    -refresh=false\n   266→    -lock=false\n   267→    -input=false\n   268→    -detailed-exitcode\n   269→    -no-color\n   270→  )\n   271→\n   272→  # Run safe init first so plan-safe works from a clean temp TF_DATA_DIR.\n   273→  if tf \"${init_args[@]}\" >\"$init_log\" 2>&1; then\n   274→    :\n   275→  else\n   276→    ok=0\n   277→  fi\n   278→\n   279→  if [[ \"$ok\" == \"1\" ]]; then\n   280→    set +e\n   281→    tf \"${plan_args[@]}\" >\"$log\" 2>&1\n   282→    rc=$?\n   283→    set -e\n   284→\n   285→    case \"$rc\" in\n   286→      0)\n   287→        changed=0\n   288→        ;;\n   289→      2)\n   290→        changed=1\n   291→        ;;\n   292→      *)\n   293→        ok=0\n   294→        ;;\n   295→    esac\n   296→  fi\n   297→\n   298→  echo \"Mode: safe (non-mutating)\"\n   299→  echo \"TF_DATA_DIR: $TF_DATA_DIR_PATH\"\n   300→  if [[ \"$ok\" == \"1\" ]]; then\n   301→    echo \"Changes detected: $([[ \"$changed\" == \"1\" ]] && echo yes || echo no)\"\n   302→  fi\n   303→\n   304→  if [[ \"$ok\" == \"0\" ]]; then\n   305→    if [[ -s \"$init_log\" ]]; then\n   306→      echo\n   307→      echo \"Init output (first ${MAX_LINES} lines):\"\n   308→      head -n \"$MAX_LINES\" \"$init_log\"\n   309→    fi\n   310→    if [[ -s \"$log\" ]]; then\n   311→      echo\n   312→      echo \"Plan output (first ${MAX_LINES} lines):\"\n   313→      head -n \"$MAX_LINES\" \"$log\"\n   314→    fi\n   315→  fi\n   316→\n   317→  echo\n   318→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   319→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the errors above, then re-run: /terra-agent plan-safe\"\n   320→  echo \"Init log: $init_log\"\n   321→  echo \"Full log: $log\"\n   322→  fmt_elapsed\n   323→  [[ \"$ok\" == \"1\" ]]\n   324→}\n   325→\n   326→run_lint() {\n   327→  step \"lint\"\n   328→  local log=\"$OUTDIR/lint.log\"\n   329→  local ok=1\n   330→  local -a args=()\n   331→\n   332→  if ! command -v tflint >/dev/null 2>&1; then\n   333→    echo \"Result: SKIP (tflint not found)\"\n   334→    fmt_elapsed\n   335→    return 0\n   336→  fi\n   337→\n   338→  if [[ \"$TFLINT_RECURSIVE\" == \"1\" ]]; then\n   339→    args+=(\"--recursive\")\n   340→  fi\n   341→\n   342→  if [[ \"$TERRAFORM_CHDIR\" == \".\" ]]; then\n   343→    if tflint \"${args[@]}\" >\"$log\" 2>&1; then\n   344→      :\n   345→    else\n   346→      ok=0\n   347→    fi\n   348→  else\n   349→    if (cd \"$TERRAFORM_CHDIR\" && tflint \"${args[@]}\") >\"$log\" 2>&1; then\n   350→      :\n   351→    else\n   352→      ok=0\n   353→    fi\n   354→  fi\n   355→\n   356→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   357→    echo\n   358→    echo \"Output (first ${MAX_LINES} lines):\"\n   359→    head -n \"$MAX_LINES\" \"$log\"\n   360→  fi\n   361→\n   362→  echo\n   363→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   364→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the lint issues above, then re-run: /terra-agent lint\"\n   365→  echo \"Full log: $log\"\n   366→  fmt_elapsed\n   367→  [[ \"$ok\" == \"1\" ]]\n   368→}\n   369→\n   370→usage() {\n   371→  cat <<'EOF'\n   372→terra-agent: lean Terraform workflow output for coding agents\n   373→\n   374→Usage:\n   375→  terra-agent [--fail-fast]                   # runs fmt(check), init(safe), validate, lint\n   376→  terra-agent [--fail-fast] fmt               # fmt in FMT_MODE\n   377→  terra-agent fmt-check                       # report-only format check\n   378→  terra-agent fmt-fix                         # auto-fix formatting\n   379→  terra-agent init                            # safe non-mutating init\n   380→  terra-agent plan-safe                       # safe non-mutating plan (passes on exit 0 or 2)\n   381→  terra-agent validate                        # terraform validate\n   382→  terra-agent lint                            # tflint (if installed)\n   383→  terra-agent [--fail-fast] all               # full suite (default)\n   384→\n   385→Flags:\n   386→  --fail-fast              stop after first failing step\n   387→\n   388→Env knobs:\n   389→  MAX_LINES=40                   # printed lines per step (unlimited in CI)\n   390→  KEEP_DIR=0|1                   # keep temp log dir even on success\n   391→  FAIL_FAST=0|1                  # same as --fail-fast flag\n   392→  TERRAFORM_CHDIR=.              # terraform root directory\n   393→  TF_CHDIR=.                     # alias for TERRAFORM_CHDIR\n   394→  RUN_FMT=0|1\n   395→  RUN_INIT=0|1\n   396→  RUN_VALIDATE=0|1\n   397→  RUN_LINT=0|1\n   398→  RUN_PLAN_SAFE=0|1            # set to 1 to include in \"all\"\n   399→  FMT_MODE=check|fix             # default: check\n   400→  FMT_RECURSIVE=0|1              # default: 1\n   401→  TFLINT_RECURSIVE=0|1           # default: 1\n   402→  CHANGED_FILES=\"f1 f2\"          # auto-set TERRAFORM_CHDIR from changed .tf files\n   403→\n   404→Examples:\n   405→  terra-agent\n   406→  terra-agent --fail-fast                         # full suite, stop on first failure\n   407→  TERRAFORM_CHDIR=infra terra-agent fmt-check\n   408→  TERRAFORM_CHDIR=infra terra-agent fmt-fix\n   409→  TERRAFORM_CHDIR=infra terra-agent init\n   410→  TERRAFORM_CHDIR=infra terra-agent plan-safe\n   411→  FMT_MODE=fix TERRAFORM_CHDIR=infra terra-agent fmt\n   412→  RUN_PLAN_SAFE=1 TERRAFORM_CHDIR=infra terra-agent all\n   413→  RUN_LINT=0 TERRAFORM_CHDIR=infra terra-agent all\n   414→EOF\n   415→}\n   416→\n   417→main() {\n   418→  while [[ \"${1:-}\" == --* ]]; do\n   419→    case \"$1\" in\n   420→      --fail-fast) FAIL_FAST=1; shift ;;\n   421→      *) break ;;\n   422→    esac\n   423→  done\n   424→\n   425→  local cmd=\"${1:-all}\"\n   426→  shift 2>/dev/null || true\n   427→  local overall_ok=1\n   428→\n   429→  case \"$cmd\" in\n   430→    -h|--help|help)\n   431→      usage\n   432→      exit 0\n   433→      ;;\n   434→  esac\n   435→\n   436→  need terraform\n   437→  normalize_dir\n   438→  resolve_changed_tf_dir\n   439→  ensure_terraform_project\n   440→\n   441→  case \"$cmd\" in\n   442→    fmt)       run_fmt \"$FMT_MODE\" || overall_ok=0 ;;\n   443→    fmt-check) run_fmt \"check\" || overall_ok=0 ;;\n   444→    fmt-fix)   run_fmt \"fix\" || overall_ok=0 ;;\n   445→    init)      run_init || overall_ok=0 ;;\n   446→    plan-safe) run_plan_safe || overall_ok=0 ;;\n   447→    validate)  run_validate || overall_ok=0 ;;\n   448→    lint)      run_lint || overall_ok=0 ;;\n   449→    all)\n   450→      if [[ \"$RUN_FMT\" == \"1\" ]] && should_continue; then run_fmt \"$FMT_MODE\" || overall_ok=0; fi\n   451→      if [[ \"$RUN_INIT\" == \"1\" ]] && should_continue; then run_init || overall_ok=0; fi\n   452→      if [[ \"$RUN_VALIDATE\" == \"1\" ]] && should_continue; then run_validate || overall_ok=0; fi\n   453→      if [[ \"$RUN_LINT\" == \"1\" ]] && should_continue; then run_lint || overall_ok=0; fi\n   454→      if [[ \"$RUN_PLAN_SAFE\" == \"1\" ]] && should_continue; then run_plan_safe || overall_ok=0; fi\n   455→      ;;\n   456→    *)\n   457→      echo \"Unknown command: $cmd\" >&2\n   458→      usage\n   459→      exit 2\n   460→      ;;\n   461→  esac\n   462→\n   463→  hr\n   464→  echo \"Overall: $([[ \"$overall_ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   465→  echo \"Logs: $OUTDIR\"\n   466→  [[ \"$overall_ok\" == \"1\" ]]\n   467→}\n   468→\n   469→main \"$@\"\n   470→"}]},"parent_tool_use_id":"toolu_01NVu7UwcKcwDBtgn1XDv5pX","session_id":"226048e6-738a-41d7-adea-ced326c6394c","uuid":"eb71e803-f6c8-4fa2-881e-23d80dfd2432"}
