{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EHFrS9BrfQmG74UPaHkZ92","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# gha-agent: lean GitHub Actions workflow linter for coding agents\n     5→# deps: actionlint\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→LIB_DIR=\"${SCRIPT_DIR}/../../../lib\"\n     9→# shellcheck source=../../../lib/x-agent-common.sh\n    10→source \"${LIB_DIR}/x-agent-common.sh\"\n    11→\n    12→# ---- Agent-specific knobs ------------------------------------------------\n    13→\n    14→RUN_LINT=\"${RUN_LINT:-1}\"\n    15→\n    16→# ---- Usage ----------------------------------------------------------------\n    17→\n    18→usage() {\n    19→  cat <<'EOF'\n    20→gha-agent — lean GitHub Actions workflow linter for coding agents.\n    21→\n    22→Usage: gha-agent.sh [options] [command]\n    23→\n    24→Commands:\n    25→  lint      Run actionlint on workflow files\n    26→  all       Run lint (default)\n    27→  help      Show this help\n    28→\n    29→Options:\n    30→  --fail-fast   Stop after first failing step\n    31→\n    32→Environment:\n    33→  RUN_LINT=0|1             Toggle lint step (default: 1)\n    34→  CHANGED_FILES=\"a.yml b.yml\"  Scope to specific files\n    35→  MAX_LINES=N              Max diagnostic lines per step (default: 40)\n    36→  KEEP_DIR=0|1             Keep temp log dir on success (default: 0)\n    37→  FAIL_FAST=0|1            Stop after first failure (default: 0)\n    38→EOF\n    39→}\n    40→\n    41→# ---- Workflow discovery ---------------------------------------------------\n    42→\n    43→# Populates WORKFLOW_FILES (newline-separated list of workflow file paths).\n    44→collect_workflow_files() {\n    45→  WORKFLOW_FILES=\"\"\n    46→\n    47→  if [[ -n \"${CHANGED_FILES:-}\" ]]; then\n    48→    # Filter CHANGED_FILES to existing .yml/.yaml under .github/workflows/\n    49→    local f\n    50→    for f in $CHANGED_FILES; do\n    51→      case \"$f\" in\n    52→        .github/workflows/*.yml|.github/workflows/*.yaml)\n    53→          if [[ -f \"$f\" ]]; then\n    54→            if [[ -z \"$WORKFLOW_FILES\" ]]; then\n    55→              WORKFLOW_FILES=\"$f\"\n    56→            else\n    57→              WORKFLOW_FILES=\"${WORKFLOW_FILES}\n    58→$f\"\n    59→            fi\n    60→          fi\n    61→          ;;\n    62→      esac\n    63→    done\n    64→  else\n    65→    if [[ ! -d \".github/workflows\" ]]; then\n    66→      WORKFLOW_FILES=\"\"\n    67→      return 0\n    68→    fi\n    69→    # Discover all .yml/.yaml files in .github/workflows/\n    70→    WORKFLOW_FILES=\"$(find .github/workflows \\\n    71→      -maxdepth 1 -type f \\( -name '*.yml' -o -name '*.yaml' \\) -print | sort)\"\n    72→  fi\n    73→\n    74→  local count=0\n    75→  if [[ -n \"$WORKFLOW_FILES\" ]]; then\n    76→    count=\"$(printf '%s\\n' \"$WORKFLOW_FILES\" | wc -l | tr -d ' ')\"\n    77→  fi\n    78→  echo \"Discovered ${count} workflow file(s)\"\n    79→}\n    80→\n    81→# ---- Steps ----------------------------------------------------------------\n    82→\n    83→run_lint() {\n    84→  step \"lint\"\n    85→\n    86→  # No .github/workflows directory at all\n    87→  if [[ -z \"${CHANGED_FILES:-}\" ]] && [[ ! -d \".github/workflows\" ]]; then\n    88→    echo\n    89→    echo \"Result: SKIP (no .github/workflows/ directory found)\"\n    90→    fmt_elapsed\n    91→    return 0\n    92→  fi\n    93→\n    94→  # CHANGED_FILES set but no workflow files matched\n    95→  if [[ -n \"${CHANGED_FILES:-}\" ]] && [[ -z \"$WORKFLOW_FILES\" ]]; then\n    96→    echo\n    97→    echo \"Result: SKIP (no workflow files in CHANGED_FILES)\"\n    98→    fmt_elapsed\n    99→    return 0\n   100→  fi\n   101→\n   102→  # No workflow files found via discovery\n   103→  if [[ -z \"$WORKFLOW_FILES\" ]]; then\n   104→    echo\n   105→    echo \"Result: SKIP (no .yml/.yaml files in .github/workflows/)\"\n   106→    fmt_elapsed\n   107→    return 0\n   108→  fi\n   109→\n   110→  local log=\"${OUTDIR}/lint.log\"\n   111→  local ok=1\n   112→\n   113→  # Build file list array for actionlint invocation\n   114→  local files=()\n   115→  while IFS= read -r f; do\n   116→    files+=(\"$f\")\n   117→  done <<< \"$WORKFLOW_FILES\"\n   118→\n   119→  if ! actionlint \"${files[@]}\" >\"$log\" 2>&1; then\n   120→    ok=0\n   121→  fi\n   122→\n   123→  if [[ \"$ok\" == \"0\" ]]; then\n   124→    echo\n   125→    echo \"Output (first ${MAX_LINES} lines):\"\n   126→    head -n \"$MAX_LINES\" \"$log\"\n   127→  fi\n   128→\n   129→  print_result \"$ok\" \"$log\" \\\n   130→    \"resolve the workflow errors above, then re-run: /gha-agent lint\"\n   131→\n   132→  return $(( 1 - ok ))\n   133→}\n   134→\n   135→# ---- Main -----------------------------------------------------------------\n   136→\n   137→main() {\n   138→  # Parse help before need() checks so --help works without tools installed\n   139→  case \"${1:-}\" in\n   140→    -h|--help|help)\n   141→      usage\n   142→      exit 0\n   143→      ;;\n   144→  esac\n   145→\n   146→  need actionlint\n   147→\n   148→  setup_outdir \"gha-agent\"\n   149→\n   150→  # Parse flags\n   151→  while [[ \"${1:-}\" == --* ]]; do\n   152→    case \"$1\" in\n   153→      --fail-fast)\n   154→        # shellcheck disable=SC2034\n   155→        FAIL_FAST=1\n   156→        shift\n   157→        ;;\n   158→      *)\n   159→        break\n   160→        ;;\n   161→    esac\n   162→  done\n   163→\n   164→  local cmd=\"${1:-all}\"\n   165→  shift 2>/dev/null || true\n   166→  local overall_ok=1\n   167→\n   168→  collect_workflow_files\n   169→\n   170→  case \"$cmd\" in\n   171→    lint) run_lint || overall_ok=0 ;;\n   172→    all)\n   173→      if [[ \"$RUN_LINT\" == \"1\" ]] && should_continue; then run_lint || overall_ok=0; fi\n   174→      ;;\n   175→    *)\n   176→      echo \"Unknown command: $cmd\" >&2\n   177→      usage\n   178→      exit 2\n   179→      ;;\n   180→  esac\n   181→\n   182→  print_overall \"$overall_ok\"\n   183→  [[ \"$overall_ok\" == \"1\" ]]\n   184→}\n   185→\n   186→main \"$@\"\n   187→"}]},"parent_tool_use_id":"toolu_01BEJvUovoZReNGGRcar99ZU","session_id":"be0e30e7-8817-4b77-ad57-f2dbd38ea5b9","uuid":"9d39c491-fe7b-47c8-bfe0-d769ba7e5f75"}
