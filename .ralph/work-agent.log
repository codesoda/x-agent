{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SU7qfb1uR3PJfAejHjUq5C","type":"tool_result","content":"     1→#!/bin/sh\n     2→set -eu\n     3→\n     4→# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n     5→# Works via: curl -sSf <raw-url>/install.sh | sh\n     6→# Or locally: sh install.sh\n     7→\n     8→PROJECT_NAME=\"x-agent\"\n     9→REPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\n    10→REPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\n    11→REPO_REF=\"${X_AGENT_REPO_REF:-main}\"\n    12→RAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n    13→\n    14→CODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\n    15→CLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n    16→\n    17→AUTO_YES=0\n    18→SKIP_DEPS=0\n    19→INSTALL_CODEX=1\n    20→INSTALL_CLAUDE=1\n    21→\n    22→TMP_DIR=\"\"\n    23→SOURCE_DIR=\"\"\n    24→SOURCE_MODE=\"remote\"\n    25→\n    26→# Available skills to install (each has its own scripts/ subdirectory)\n    27→SKILLS=\"bash-agent cargo-agent npm-agent py-agent terra-agent\"\n    28→SELECTED_SKILLS=\"\"\n    29→\n    30→info() {\n    31→  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n    32→}\n    33→\n    34→warn() {\n    35→  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    36→}\n    37→\n    38→die() {\n    39→  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    40→  exit 1\n    41→}\n    42→\n    43→usage() {\n    44→  cat <<'EOF'\n    45→Install x-agent skills and scripts into local agent skill directories.\n    46→\n    47→Usage:\n    48→  sh install.sh [options]\n    49→  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n    50→\n    51→Options:\n    52→  --yes          Non-interactive mode; accept default install prompts.\n    53→  --skip-deps    Skip dependency checks.\n    54→  --codex-only   Only install to ~/.codex/skills.\n    55→  --claude-only  Only install to ~/.claude/skills.\n    56→  --help         Show this help text.\n    57→\n    58→Notes:\n    59→  Interactive mode prompts per x-agent skill and install destination.\n    60→  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n    61→\n    62→Environment variables:\n    63→  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n    64→  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n    65→  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n    66→  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n    67→  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n    68→  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\n    69→EOF\n    70→}\n    71→\n    72→cleanup() {\n    73→  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    74→    rm -rf \"$TMP_DIR\"\n    75→  fi\n    76→}\n    77→\n    78→trap cleanup EXIT INT TERM\n    79→\n    80→prompt_yes_no() {\n    81→  question=\"$1\"\n    82→  default=\"${2:-yes}\"\n    83→\n    84→  if [ \"$AUTO_YES\" -eq 1 ]; then\n    85→    return 0\n    86→  fi\n    87→\n    88→  if [ \"$default\" = \"yes\" ]; then\n    89→    prompt=\"[Y/n]\"\n    90→    fallback=\"yes\"\n    91→  else\n    92→    prompt=\"[y/N]\"\n    93→    fallback=\"no\"\n    94→  fi\n    95→\n    96→  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    97→    while :; do\n    98→      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n    99→      if ! IFS= read -r answer < /dev/tty; then\n   100→        break\n   101→      fi\n   102→      case \"$answer\" in\n   103→        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n   104→        [Nn]|[Nn][Oo]) return 1 ;;\n   105→        \"\")\n   106→          if [ \"$fallback\" = \"yes\" ]; then\n   107→            return 0\n   108→          fi\n   109→          return 1\n   110→          ;;\n   111→        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n   112→      esac\n   113→    done\n   114→  fi\n   115→\n   116→  [ \"$fallback\" = \"yes\" ]\n   117→}\n   118→\n   119→skill_selected() {\n   120→  skill=\"$1\"\n   121→  case \" ${SELECTED_SKILLS} \" in\n   122→    *\" ${skill} \"*) return 0 ;;\n   123→    *) return 1 ;;\n   124→  esac\n   125→}\n   126→\n   127→add_selected_skill() {\n   128→  skill=\"$1\"\n   129→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   130→    SELECTED_SKILLS=\"$skill\"\n   131→  else\n   132→    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n   133→  fi\n   134→}\n   135→\n   136→select_skills() {\n   137→  if [ \"$AUTO_YES\" -eq 1 ]; then\n   138→    SELECTED_SKILLS=\"$SKILLS\"\n   139→    return 0\n   140→  fi\n   141→\n   142→  info \"Select x-agent skills to install:\"\n   143→  for skill in $SKILLS; do\n   144→    if prompt_yes_no \"Install ${skill}?\" yes; then\n   145→      add_selected_skill \"$skill\"\n   146→    fi\n   147→  done\n   148→}\n   149→\n   150→fetch_to_file() {\n   151→  url=\"$1\"\n   152→  out=\"$2\"\n   153→\n   154→  if command -v curl >/dev/null 2>&1; then\n   155→    curl -fsSL \"$url\" -o \"$out\"\n   156→    return 0\n   157→  fi\n   158→\n   159→  if command -v wget >/dev/null 2>&1; then\n   160→    wget -qO \"$out\" \"$url\"\n   161→    return 0\n   162→  fi\n   163→\n   164→  return 1\n   165→}\n   166→\n   167→# Detect if we're running from a local checkout or need to fetch from remote.\n   168→resolve_source_dir() {\n   169→  # Check if running from inside the repo\n   170→  if [ -d \"./skills\" ]; then\n   171→    SOURCE_DIR=\"$(pwd)\"\n   172→    SOURCE_MODE=\"local\"\n   173→    info \"Using local source at ${SOURCE_DIR}.\"\n   174→    return 0\n   175→  fi\n   176→\n   177→  # Check relative to the script location\n   178→  case \"$0\" in\n   179→    */*)\n   180→      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n   181→      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n   182→        SOURCE_DIR=\"$script_dir\"\n   183→        SOURCE_MODE=\"local\"\n   184→        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n   185→        return 0\n   186→      fi\n   187→      ;;\n   188→  esac\n   189→\n   190→  # Remote fetch\n   191→  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n   192→  SOURCE_DIR=\"${TMP_DIR}\"\n   193→  SOURCE_MODE=\"remote\"\n   194→\n   195→  # Fetch shared library\n   196→  mkdir -p \"${SOURCE_DIR}/lib\"\n   197→  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n   198→  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n   199→  info \"Fetching lib/x-agent-common.sh...\"\n   200→  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   201→    die \"Unable to download ${src_url}\"\n   202→  fi\n   203→\n   204→  # Fetch each selected skill's SKILL.md and scripts\n   205→  for skill in $SELECTED_SKILLS; do\n   206→    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n   207→\n   208→    # Fetch SKILL.md\n   209→    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n   210→    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n   211→    info \"Fetching skills/${skill}/SKILL.md...\"\n   212→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   213→      die \"Unable to download ${src_url}\"\n   214→    fi\n   215→\n   216→    # Fetch the skill's script\n   217→    script_name=\"${skill}.sh\"\n   218→    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n   219→    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n   220→    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n   221→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   222→      die \"Unable to download ${src_url}\"\n   223→    fi\n   224→    chmod +x \"$dest\"\n   225→  done\n   226→}\n   227→\n   228→# Install a single skill to a skills root, with scripts alongside it.\n   229→install_skill_to_root() {\n   230→  root=\"$1\"\n   231→  skill=\"$2\"\n   232→  target=\"${root}/${skill}\"\n   233→\n   234→  mkdir -p \"$root\"\n   235→  rm -rf \"$target\"\n   236→\n   237→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   238→    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n   239→    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n   240→  else\n   241→    mkdir -p \"$target\"\n   242→    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n   243→    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n   244→    info \"Installed ${skill} to ${target}\"\n   245→  fi\n   246→}\n   247→\n   248→# Install the shared library to a skills root so agent scripts can source it.\n   249→# For local installs, symlink the lib/ directory.\n   250→# For remote installs, copy the fetched lib/ directory.\n   251→install_lib_to_root() {\n   252→  root=\"$1\"\n   253→  target=\"${root}/lib\"\n   254→\n   255→  mkdir -p \"$root\"\n   256→  rm -rf \"$target\"\n   257→\n   258→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   259→    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n   260→    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n   261→  else\n   262→    mkdir -p \"$target\"\n   263→    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n   264→    info \"Installed lib to ${target}\"\n   265→  fi\n   266→}\n   267→\n   268→# Rewrite SKILL.md paths to point at the actual installed script location.\n   269→patch_skill_paths() {\n   270→  root=\"$1\"\n   271→  skill=\"$2\"\n   272→  skill_md=\"${root}/${skill}/SKILL.md\"\n   273→\n   274→  if [ ! -f \"$skill_md\" ]; then return; fi\n   275→\n   276→  # For local (symlink) installs, paths already point to the right place via the repo.\n   277→  # For remote installs, update paths to point at the skill's bundled scripts dir.\n   278→  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n   279→    scripts_dir=\"${root}/${skill}/scripts\"\n   280→    # Replace relative scripts/ paths with the actual installed path\n   281→    if command -v sed >/dev/null 2>&1; then\n   282→      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n   283→      rm -f \"${skill_md}.bak\"\n   284→    fi\n   285→  fi\n   286→}\n   287→\n   288→check_optional_deps() {\n   289→  info \"Checking optional dependencies...\"\n   290→  all_ok=1\n   291→\n   292→  if skill_selected \"bash-agent\"; then\n   293→    if command -v shellcheck >/dev/null 2>&1; then\n   294→      info \"  Found: shellcheck\"\n   295→    else\n   296→      warn \"  Missing: shellcheck (needed by bash-agent)\"\n   297→      all_ok=0\n   298→    fi\n   299→  fi\n   300→\n   301→  if skill_selected \"cargo-agent\"; then\n   302→    if command -v jq >/dev/null 2>&1; then\n   303→      info \"  Found: jq\"\n   304→    else\n   305→      warn \"  Missing: jq (needed by cargo-agent)\"\n   306→      all_ok=0\n   307→    fi\n   308→\n   309→    if command -v cargo >/dev/null 2>&1; then\n   310→      info \"  Found: cargo\"\n   311→    else\n   312→      warn \"  Missing: cargo (needed by cargo-agent)\"\n   313→      all_ok=0\n   314→    fi\n   315→  fi\n   316→\n   317→  if skill_selected \"npm-agent\"; then\n   318→    if command -v node >/dev/null 2>&1; then\n   319→      info \"  Found: node\"\n   320→    else\n   321→      warn \"  Missing: node (needed by npm-agent)\"\n   322→      all_ok=0\n   323→    fi\n   324→  fi\n   325→\n   326→  if skill_selected \"py-agent\"; then\n   327→    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n   328→      info \"  Found: python\"\n   329→    else\n   330→      warn \"  Missing: python3 (needed by py-agent)\"\n   331→      all_ok=0\n   332→    fi\n   333→\n   334→    for dep in ruff black; do\n   335→      if command -v \"$dep\" >/dev/null 2>&1; then\n   336→        info \"  Found: ${dep}\"\n   337→        break\n   338→      fi\n   339→    done\n   340→  fi\n   341→\n   342→  if skill_selected \"terra-agent\"; then\n   343→    if command -v terraform >/dev/null 2>&1; then\n   344→      info \"  Found: terraform\"\n   345→    else\n   346→      warn \"  Missing: terraform (needed by terra-agent)\"\n   347→      all_ok=0\n   348→    fi\n   349→\n   350→    if command -v tflint >/dev/null 2>&1; then\n   351→      info \"  Found: tflint\"\n   352→    else\n   353→      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n   354→    fi\n   355→  fi\n   356→\n   357→  if [ \"$all_ok\" -eq 0 ]; then\n   358→    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n   359→  fi\n   360→}\n   361→\n   362→print_agents_md_snippet() {\n   363→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   364→    return 0\n   365→  fi\n   366→\n   367→  echo \"\"\n   368→  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n   369→  echo \"## x-agent checks\"\n   370→  echo \"\"\n   371→  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n   372→\n   373→  for skill in $SELECTED_SKILLS; do\n   374→    case \"$skill\" in\n   375→      bash-agent)\n   376→        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n   377→        ;;\n   378→      cargo-agent)\n   379→        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n   380→        ;;\n   381→      npm-agent)\n   382→        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n   383→        ;;\n   384→      py-agent)\n   385→        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n   386→        ;;\n   387→      terra-agent)\n   388→        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n   389→        ;;\n   390→    esac\n   391→  done\n   392→\n   393→  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n   394→  echo \"- If a change touches multiple stacks, run all matching skills.\"\n   395→  if skill_selected \"terra-agent\"; then\n   396→    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n   397→    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n   398→  fi\n   399→  echo \"- Resolve all FAIL results before completing the task.\"\n   400→  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n   401→}\n   402→\n   403→# --- Main ---\n   404→\n   405→while [ $# -gt 0 ]; do\n   406→  case \"$1\" in\n   407→    --yes)\n   408→      AUTO_YES=1\n   409→      ;;\n   410→    --skip-deps)\n   411→      SKIP_DEPS=1\n   412→      ;;\n   413→    --codex-only)\n   414→      INSTALL_CODEX=1\n   415→      INSTALL_CLAUDE=0\n   416→      ;;\n   417→    --claude-only)\n   418→      INSTALL_CODEX=0\n   419→      INSTALL_CLAUDE=1\n   420→      ;;\n   421→    --help|-h)\n   422→      usage\n   423→      exit 0\n   424→      ;;\n   425→    *)\n   426→      die \"Unknown option: $1 (use --help)\"\n   427→      ;;\n   428→  esac\n   429→  shift\n   430→done\n   431→\n   432→info \"x-agent installer\"\n   433→info \"==================\"\n   434→\n   435→select_skills\n   436→if [ -z \"$SELECTED_SKILLS\" ]; then\n   437→  info \"No skills selected. Nothing to install.\"\n   438→  info \"Done.\"\n   439→  exit 0\n   440→fi\n   441→\n   442→resolve_source_dir\n   443→\n   444→if [ \"$SKIP_DEPS\" -eq 0 ]; then\n   445→  check_optional_deps\n   446→else\n   447→  info \"Skipping dependency checks (--skip-deps).\"\n   448→fi\n   449→\n   450→if [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n   451→  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n   452→    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n   453→    for skill in $SELECTED_SKILLS; do\n   454→      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   455→      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   456→    done\n   457→  else\n   458→    info \"Skipped Claude install.\"\n   459→  fi\n   460→fi\n   461→\n   462→if [ \"$INSTALL_CODEX\" -eq 1 ]; then\n   463→  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n   464→    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n   465→    for skill in $SELECTED_SKILLS; do\n   466→      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n   467→      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n   468→    done\n   469→  else\n   470→    info \"Skipped Codex install.\"\n   471→  fi\n   472→fi\n   473→\n   474→info \"\"\n   475→info \"Installed skills: ${SELECTED_SKILLS}\"\n   476→info \"\"\n   477→print_agents_md_snippet\n   478→info \"\"\n   479→info \"Done.\"\n   480→"}]},"parent_tool_use_id":null,"session_id":"d1d69c5f-0ac2-4adc-92c8-852dd8c9cd25","uuid":"f5793ec3-9fe9-41b8-a080-d6442cfaac66","tool_use_result":{"type":"text","file":{"filePath":"/Users/chrisraethke/projects/x-agent/install.sh","content":"#!/bin/sh\nset -eu\n\n# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n# Works via: curl -sSf <raw-url>/install.sh | sh\n# Or locally: sh install.sh\n\nPROJECT_NAME=\"x-agent\"\nREPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\nREPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\nREPO_REF=\"${X_AGENT_REPO_REF:-main}\"\nRAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n\nCODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\nCLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n\nAUTO_YES=0\nSKIP_DEPS=0\nINSTALL_CODEX=1\nINSTALL_CLAUDE=1\n\nTMP_DIR=\"\"\nSOURCE_DIR=\"\"\nSOURCE_MODE=\"remote\"\n\n# Available skills to install (each has its own scripts/ subdirectory)\nSKILLS=\"bash-agent cargo-agent npm-agent py-agent terra-agent\"\nSELECTED_SKILLS=\"\"\n\ninfo() {\n  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n}\n\nwarn() {\n  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n}\n\ndie() {\n  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n  exit 1\n}\n\nusage() {\n  cat <<'EOF'\nInstall x-agent skills and scripts into local agent skill directories.\n\nUsage:\n  sh install.sh [options]\n  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n\nOptions:\n  --yes          Non-interactive mode; accept default install prompts.\n  --skip-deps    Skip dependency checks.\n  --codex-only   Only install to ~/.codex/skills.\n  --claude-only  Only install to ~/.claude/skills.\n  --help         Show this help text.\n\nNotes:\n  Interactive mode prompts per x-agent skill and install destination.\n  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n\nEnvironment variables:\n  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\nEOF\n}\n\ncleanup() {\n  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    rm -rf \"$TMP_DIR\"\n  fi\n}\n\ntrap cleanup EXIT INT TERM\n\nprompt_yes_no() {\n  question=\"$1\"\n  default=\"${2:-yes}\"\n\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    return 0\n  fi\n\n  if [ \"$default\" = \"yes\" ]; then\n    prompt=\"[Y/n]\"\n    fallback=\"yes\"\n  else\n    prompt=\"[y/N]\"\n    fallback=\"no\"\n  fi\n\n  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    while :; do\n      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n      if ! IFS= read -r answer < /dev/tty; then\n        break\n      fi\n      case \"$answer\" in\n        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n        [Nn]|[Nn][Oo]) return 1 ;;\n        \"\")\n          if [ \"$fallback\" = \"yes\" ]; then\n            return 0\n          fi\n          return 1\n          ;;\n        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n      esac\n    done\n  fi\n\n  [ \"$fallback\" = \"yes\" ]\n}\n\nskill_selected() {\n  skill=\"$1\"\n  case \" ${SELECTED_SKILLS} \" in\n    *\" ${skill} \"*) return 0 ;;\n    *) return 1 ;;\n  esac\n}\n\nadd_selected_skill() {\n  skill=\"$1\"\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    SELECTED_SKILLS=\"$skill\"\n  else\n    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n  fi\n}\n\nselect_skills() {\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    SELECTED_SKILLS=\"$SKILLS\"\n    return 0\n  fi\n\n  info \"Select x-agent skills to install:\"\n  for skill in $SKILLS; do\n    if prompt_yes_no \"Install ${skill}?\" yes; then\n      add_selected_skill \"$skill\"\n    fi\n  done\n}\n\nfetch_to_file() {\n  url=\"$1\"\n  out=\"$2\"\n\n  if command -v curl >/dev/null 2>&1; then\n    curl -fsSL \"$url\" -o \"$out\"\n    return 0\n  fi\n\n  if command -v wget >/dev/null 2>&1; then\n    wget -qO \"$out\" \"$url\"\n    return 0\n  fi\n\n  return 1\n}\n\n# Detect if we're running from a local checkout or need to fetch from remote.\nresolve_source_dir() {\n  # Check if running from inside the repo\n  if [ -d \"./skills\" ]; then\n    SOURCE_DIR=\"$(pwd)\"\n    SOURCE_MODE=\"local\"\n    info \"Using local source at ${SOURCE_DIR}.\"\n    return 0\n  fi\n\n  # Check relative to the script location\n  case \"$0\" in\n    */*)\n      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n        SOURCE_DIR=\"$script_dir\"\n        SOURCE_MODE=\"local\"\n        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n        return 0\n      fi\n      ;;\n  esac\n\n  # Remote fetch\n  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n  SOURCE_DIR=\"${TMP_DIR}\"\n  SOURCE_MODE=\"remote\"\n\n  # Fetch shared library\n  mkdir -p \"${SOURCE_DIR}/lib\"\n  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n  info \"Fetching lib/x-agent-common.sh...\"\n  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n    die \"Unable to download ${src_url}\"\n  fi\n\n  # Fetch each selected skill's SKILL.md and scripts\n  for skill in $SELECTED_SKILLS; do\n    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n\n    # Fetch SKILL.md\n    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n    info \"Fetching skills/${skill}/SKILL.md...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n\n    # Fetch the skill's script\n    script_name=\"${skill}.sh\"\n    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n    chmod +x \"$dest\"\n  done\n}\n\n# Install a single skill to a skills root, with scripts alongside it.\ninstall_skill_to_root() {\n  root=\"$1\"\n  skill=\"$2\"\n  target=\"${root}/${skill}\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n    info \"Installed ${skill} to ${target}\"\n  fi\n}\n\n# Install the shared library to a skills root so agent scripts can source it.\n# For local installs, symlink the lib/ directory.\n# For remote installs, copy the fetched lib/ directory.\ninstall_lib_to_root() {\n  root=\"$1\"\n  target=\"${root}/lib\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n    info \"Installed lib to ${target}\"\n  fi\n}\n\n# Rewrite SKILL.md paths to point at the actual installed script location.\npatch_skill_paths() {\n  root=\"$1\"\n  skill=\"$2\"\n  skill_md=\"${root}/${skill}/SKILL.md\"\n\n  if [ ! -f \"$skill_md\" ]; then return; fi\n\n  # For local (symlink) installs, paths already point to the right place via the repo.\n  # For remote installs, update paths to point at the skill's bundled scripts dir.\n  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n    scripts_dir=\"${root}/${skill}/scripts\"\n    # Replace relative scripts/ paths with the actual installed path\n    if command -v sed >/dev/null 2>&1; then\n      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n      rm -f \"${skill_md}.bak\"\n    fi\n  fi\n}\n\ncheck_optional_deps() {\n  info \"Checking optional dependencies...\"\n  all_ok=1\n\n  if skill_selected \"bash-agent\"; then\n    if command -v shellcheck >/dev/null 2>&1; then\n      info \"  Found: shellcheck\"\n    else\n      warn \"  Missing: shellcheck (needed by bash-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"cargo-agent\"; then\n    if command -v jq >/dev/null 2>&1; then\n      info \"  Found: jq\"\n    else\n      warn \"  Missing: jq (needed by cargo-agent)\"\n      all_ok=0\n    fi\n\n    if command -v cargo >/dev/null 2>&1; then\n      info \"  Found: cargo\"\n    else\n      warn \"  Missing: cargo (needed by cargo-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"npm-agent\"; then\n    if command -v node >/dev/null 2>&1; then\n      info \"  Found: node\"\n    else\n      warn \"  Missing: node (needed by npm-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"py-agent\"; then\n    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n      info \"  Found: python\"\n    else\n      warn \"  Missing: python3 (needed by py-agent)\"\n      all_ok=0\n    fi\n\n    for dep in ruff black; do\n      if command -v \"$dep\" >/dev/null 2>&1; then\n        info \"  Found: ${dep}\"\n        break\n      fi\n    done\n  fi\n\n  if skill_selected \"terra-agent\"; then\n    if command -v terraform >/dev/null 2>&1; then\n      info \"  Found: terraform\"\n    else\n      warn \"  Missing: terraform (needed by terra-agent)\"\n      all_ok=0\n    fi\n\n    if command -v tflint >/dev/null 2>&1; then\n      info \"  Found: tflint\"\n    else\n      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n    fi\n  fi\n\n  if [ \"$all_ok\" -eq 0 ]; then\n    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n  fi\n}\n\nprint_agents_md_snippet() {\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    return 0\n  fi\n\n  echo \"\"\n  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n  echo \"## x-agent checks\"\n  echo \"\"\n  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n\n  for skill in $SELECTED_SKILLS; do\n    case \"$skill\" in\n      bash-agent)\n        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n        ;;\n      cargo-agent)\n        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n        ;;\n      npm-agent)\n        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n        ;;\n      py-agent)\n        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n        ;;\n      terra-agent)\n        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n        ;;\n    esac\n  done\n\n  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n  echo \"- If a change touches multiple stacks, run all matching skills.\"\n  if skill_selected \"terra-agent\"; then\n    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n  fi\n  echo \"- Resolve all FAIL results before completing the task.\"\n  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n}\n\n# --- Main ---\n\nwhile [ $# -gt 0 ]; do\n  case \"$1\" in\n    --yes)\n      AUTO_YES=1\n      ;;\n    --skip-deps)\n      SKIP_DEPS=1\n      ;;\n    --codex-only)\n      INSTALL_CODEX=1\n      INSTALL_CLAUDE=0\n      ;;\n    --claude-only)\n      INSTALL_CODEX=0\n      INSTALL_CLAUDE=1\n      ;;\n    --help|-h)\n      usage\n      exit 0\n      ;;\n    *)\n      die \"Unknown option: $1 (use --help)\"\n      ;;\n  esac\n  shift\ndone\n\ninfo \"x-agent installer\"\ninfo \"==================\"\n\nselect_skills\nif [ -z \"$SELECTED_SKILLS\" ]; then\n  info \"No skills selected. Nothing to install.\"\n  info \"Done.\"\n  exit 0\nfi\n\nresolve_source_dir\n\nif [ \"$SKIP_DEPS\" -eq 0 ]; then\n  check_optional_deps\nelse\n  info \"Skipping dependency checks (--skip-deps).\"\nfi\n\nif [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Claude install.\"\n  fi\nfi\n\nif [ \"$INSTALL_CODEX\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Codex install.\"\n  fi\nfi\n\ninfo \"\"\ninfo \"Installed skills: ${SELECTED_SKILLS}\"\ninfo \"\"\nprint_agents_md_snippet\ninfo \"\"\ninfo \"Done.\"\n","numLines":480,"startLine":1,"totalLines":480}}}
