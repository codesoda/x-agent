{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MzsNwVQTSAf5kQwuSqk2Mi","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# npm-agent: lean Node.js workflow output for coding agents\n     5→# deps: bash, mktemp\n     6→# optional: biome, eslint, prettier\n     7→\n     8→KEEP_DIR=\"${KEEP_DIR:-0}\"         # set to 1 to keep temp dir even on success\n     9→# In CI, show full output; locally, limit to 40 lines to keep things tidy.\n    10→if [[ \"${CI:-}\" == \"true\" || \"${CI:-}\" == \"1\" ]]; then\n    11→  MAX_LINES=\"${MAX_LINES:-999999}\"\n    12→else\n    13→  MAX_LINES=\"${MAX_LINES:-40}\"\n    14→fi\n    15→RUN_LINT=\"${RUN_LINT:-1}\"         # set to 0 to skip lint\n    16→RUN_TYPECHECK=\"${RUN_TYPECHECK:-1}\" # set to 0 to skip typecheck\n    17→RUN_FORMAT=\"${RUN_FORMAT:-1}\"     # set to 0 to skip format\n    18→RUN_TESTS=\"${RUN_TESTS:-1}\"       # set to 0 to skip tests\n    19→RUN_BUILD=\"${RUN_BUILD:-1}\"       # set to 0 to skip build\n    20→FAIL_FAST=\"${FAIL_FAST:-0}\"      # set to 1 or use --fail-fast to stop after first failure\n    21→CHANGED_FILES=\"${CHANGED_FILES:-}\"  # space-separated list of changed files; scopes lint/format\n    22→\n    23→TMPDIR_ROOT=\"${TMPDIR_ROOT:-/tmp}\"\n    24→OUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/npm-agent.XXXXXX\")\"\n    25→\n    26→cleanup() {\n    27→  local code=\"$?\"\n    28→  if [[ \"$KEEP_DIR\" == \"1\" || \"$code\" != \"0\" ]]; then\n    29→    echo \"Logs kept in: $OUTDIR\"\n    30→  else\n    31→    rm -rf \"$OUTDIR\"\n    32→  fi\n    33→  exit \"$code\"\n    34→}\n    35→trap cleanup EXIT\n    36→\n    37→hr() { echo \"------------------------------------------------------------\"; }\n    38→\n    39→# Returns 0 (continue) unless fail-fast is on and a step already failed.\n    40→should_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n    41→\n    42→STEP_START_SECONDS=0\n    43→\n    44→step() {\n    45→  local name=\"$1\"\n    46→  STEP_START_SECONDS=$SECONDS\n    47→  hr\n    48→  echo \"Step: $name\"\n    49→}\n    50→\n    51→fmt_elapsed() {\n    52→  local elapsed=$(( SECONDS - STEP_START_SECONDS ))\n    53→  echo \"Time: ${elapsed}s\"\n    54→}\n    55→\n    56→# Detect which package manager is in use.\n    57→detect_pm() {\n    58→  if [[ -f \"bun.lock\" || -f \"bun.lockb\" ]]; then echo \"bun\"\n    59→  elif [[ -f \"pnpm-lock.yaml\" ]]; then echo \"pnpm\"\n    60→  elif [[ -f \"yarn.lock\" ]]; then echo \"yarn\"\n    61→  else echo \"npm\"\n    62→  fi\n    63→}\n    64→\n    65→PM=\"$(detect_pm)\"\n    66→echo \"Package manager: $PM\"\n    67→\n    68→# Filter CHANGED_FILES to JS/TS source files for scoping lint/format.\n    69→_CHANGED_SRC_FILES=()\n    70→if [[ -n \"$CHANGED_FILES\" ]]; then\n    71→  for f in $CHANGED_FILES; do\n    72→    case \"$f\" in\n    73→      *.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs|*.mts|*.cts|*.json|*.css|*.scss|*.less|*.html|*.vue|*.svelte)\n    74→        [[ -f \"$f\" ]] && _CHANGED_SRC_FILES+=(\"$f\")\n    75→        ;;\n    76→    esac\n    77→  done\n    78→  if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then\n    79→    echo \"Scoped to ${#_CHANGED_SRC_FILES[@]} changed file(s)\"\n    80→  fi\n    81→fi\n    82→\n    83→# Run a package.json script if it exists, capturing output.\n    84→# Returns 0 if the script ran successfully, 1 if it failed, 2 if script not found.\n    85→run_script() {\n    86→  local script_name=\"$1\"\n    87→  local log=\"$2\"\n    88→\n    89→  # Check if the script exists in package.json\n    90→  if ! node -e \"\n    91→    const pkg = require('./package.json');\n    92→    if (!pkg.scripts || !pkg.scripts['$script_name']) process.exit(1);\n    93→  \" 2>/dev/null; then\n    94→    return 2\n    95→  fi\n    96→\n    97→  if $PM run \"$script_name\" >\"$log\" 2>&1; then\n    98→    return 0\n    99→  else\n   100→    return 1\n   101→  fi\n   102→}\n   103→\n   104→run_format() {\n   105→  step \"format\"\n   106→  local log=\"$OUTDIR/format.log\"\n   107→  local ok=1\n   108→  local found=0\n   109→\n   110→  # Try package.json scripts first\n   111→  for script in format fmt \"format:fix\" \"fmt:fix\" \"format:check\" \"fmt:check\"; do\n   112→    run_script \"$script\" \"$log\"\n   113→    local rc=$?\n   114→    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n   115→    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n   116→  done\n   117→\n   118→  # Fallback: try common formatters directly\n   119→  if [[ \"$found\" == \"0\" ]]; then\n   120→    # Use changed files when available, otherwise check entire project.\n   121→    local -a targets=(.)\n   122→    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n   123→\n   124→    if command -v biome >/dev/null 2>&1; then\n   125→      echo \"Using: biome format\"\n   126→      if biome format \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   127→    elif npx prettier --version >/dev/null 2>&1; then\n   128→      echo \"Using: prettier\"\n   129→      if npx prettier --check \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   130→    fi\n   131→  fi\n   132→\n   133→  if [[ \"$found\" == \"0\" ]]; then\n   134→    echo \"Result: SKIP (no formatter found)\"\n   135→    fmt_elapsed\n   136→    return 0\n   137→  fi\n   138→\n   139→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   140→    echo\n   141→    echo \"Output (first ${MAX_LINES} lines):\"\n   142→    head -n \"$MAX_LINES\" \"$log\"\n   143→  fi\n   144→\n   145→  echo\n   146→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   147→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the formatting issues, then re-run: /npm-agent format\"\n   148→  echo \"Full log: $log\"\n   149→  fmt_elapsed\n   150→  [[ \"$ok\" == \"1\" ]]\n   151→}\n   152→\n   153→run_lint() {\n   154→  step \"lint\"\n   155→  local log=\"$OUTDIR/lint.log\"\n   156→  local ok=1\n   157→  local found=0\n   158→\n   159→  # Try package.json scripts first\n   160→  for script in lint \"lint:fix\" \"lint:check\"; do\n   161→    run_script \"$script\" \"$log\"\n   162→    local rc=$?\n   163→    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n   164→    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n   165→  done\n   166→\n   167→  # Fallback: try common linters directly\n   168→  if [[ \"$found\" == \"0\" ]]; then\n   169→    # Use changed files when available, otherwise check entire project.\n   170→    local -a targets=(.)\n   171→    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n   172→\n   173→    if command -v biome >/dev/null 2>&1; then\n   174→      echo \"Using: biome lint\"\n   175→      if biome lint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   176→    elif npx eslint --version >/dev/null 2>&1; then\n   177→      echo \"Using: eslint\"\n   178→      if npx eslint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   179→    fi\n   180→  fi\n   181→\n   182→  if [[ \"$found\" == \"0\" ]]; then\n   183→    echo \"Result: SKIP (no linter found)\"\n   184→    fmt_elapsed\n   185→    return 0\n   186→  fi\n   187→\n   188→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   189→    echo\n   190→    echo \"Output (first ${MAX_LINES} lines):\"\n   191→    head -n \"$MAX_LINES\" \"$log\"\n   192→  fi\n   193→\n   194→  echo\n   195→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   196→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the lint errors above, then re-run: /npm-agent lint\"\n   197→  echo \"Full log: $log\"\n   198→  fmt_elapsed\n   199→  [[ \"$ok\" == \"1\" ]]\n   200→}\n   201→\n   202→run_typecheck() {\n   203→  step \"typecheck\"\n   204→  local log=\"$OUTDIR/typecheck.log\"\n   205→  local ok=1\n   206→  local found=0\n   207→\n   208→  # Try package.json scripts first\n   209→  for script in typecheck \"type-check\" \"types:check\" tsc; do\n   210→    run_script \"$script\" \"$log\"\n   211→    local rc=$?\n   212→    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n   213→    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n   214→  done\n   215→\n   216→  # Fallback: try tsc directly if tsconfig exists\n   217→  if [[ \"$found\" == \"0\" && -f \"tsconfig.json\" ]]; then\n   218→    echo \"Using: tsc --noEmit\"\n   219→    if npx tsc --noEmit >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n   220→  fi\n   221→\n   222→  if [[ \"$found\" == \"0\" ]]; then\n   223→    echo \"Result: SKIP (no TypeScript config found)\"\n   224→    fmt_elapsed\n   225→    return 0\n   226→  fi\n   227→\n   228→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   229→    echo\n   230→    echo \"Output (first ${MAX_LINES} lines):\"\n   231→    head -n \"$MAX_LINES\" \"$log\"\n   232→  fi\n   233→\n   234→  echo\n   235→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   236→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the type errors above, then re-run: /npm-agent typecheck\"\n   237→  echo \"Full log: $log\"\n   238→  fmt_elapsed\n   239→  [[ \"$ok\" == \"1\" ]]\n   240→}\n   241→\n   242→run_tests() {\n   243→  step \"test\"\n   244→  local log=\"$OUTDIR/test.log\"\n   245→  local ok=1\n   246→  local found=0\n   247→\n   248→  # Try package.json \"test\" script\n   249→  run_script \"test\" \"$log\"\n   250→  local rc=$?\n   251→  if [[ \"$rc\" == \"0\" ]]; then found=1; fi\n   252→  if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; fi\n   253→\n   254→  if [[ \"$found\" == \"0\" ]]; then\n   255→    echo \"Result: SKIP (no test script found)\"\n   256→    fmt_elapsed\n   257→    return 0\n   258→  fi\n   259→\n   260→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   261→    echo\n   262→    echo \"Output (first ${MAX_LINES} lines):\"\n   263→    head -n \"$MAX_LINES\" \"$log\"\n   264→  fi\n   265→\n   266→  echo\n   267→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   268→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the failing tests, then re-run: /npm-agent test\"\n   269→  echo \"Full log: $log\"\n   270→  fmt_elapsed\n   271→  [[ \"$ok\" == \"1\" ]]\n   272→}\n   273→\n   274→run_build() {\n   275→  step \"build\"\n   276→  local log=\"$OUTDIR/build.log\"\n   277→  local ok=1\n   278→  local found=0\n   279→\n   280→  run_script \"build\" \"$log\"\n   281→  local rc=$?\n   282→  if [[ \"$rc\" == \"0\" ]]; then found=1; fi\n   283→  if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; fi\n   284→\n   285→  if [[ \"$found\" == \"0\" ]]; then\n   286→    echo \"Result: SKIP (no build script found)\"\n   287→    fmt_elapsed\n   288→    return 0\n   289→  fi\n   290→\n   291→  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n   292→    echo\n   293→    echo \"Output (first ${MAX_LINES} lines):\"\n   294→    head -n \"$MAX_LINES\" \"$log\"\n   295→  fi\n   296→\n   297→  echo\n   298→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   299→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the build errors above, then re-run: /npm-agent build\"\n   300→  echo \"Full log: $log\"\n   301→  fmt_elapsed\n   302→  [[ \"$ok\" == \"1\" ]]\n   303→}\n   304→\n   305→usage() {\n   306→  cat <<'EOF'\n   307→npm-agent: lean Node.js workflow output for coding agents\n   308→\n   309→Usage:\n   310→  npm-agent [--fail-fast]              # runs format, lint, typecheck, test, build\n   311→  npm-agent [--fail-fast] format|lint|typecheck|test|build|all\n   312→\n   313→Flags:\n   314→  --fail-fast            stop after first failing step\n   315→\n   316→Env knobs:\n   317→  MAX_LINES=40           # printed lines per step (unlimited in CI)\n   318→  KEEP_DIR=0|1           # keep temp log dir even on success\n   319→  FAIL_FAST=0|1          # same as --fail-fast flag\n   320→  RUN_FORMAT=0|1\n   321→  RUN_LINT=0|1\n   322→  RUN_TYPECHECK=0|1\n   323→  RUN_TESTS=0|1\n   324→  RUN_BUILD=0|1\n   325→  CHANGED_FILES=\"f1 f2\"   # scope lint/format to changed files (fallback tools only)\n   326→\n   327→Auto-detection:\n   328→  - Package manager: detects bun, pnpm, yarn, or npm from lock files\n   329→  - Format: tries package.json scripts (format, fmt), then biome, then prettier\n   330→  - Lint: tries package.json scripts (lint), then biome, then eslint\n   331→  - Typecheck: tries package.json scripts (typecheck, tsc), then tsc --noEmit\n   332→  - Tests: runs package.json \"test\" script\n   333→  - Build: runs package.json \"build\" script\n   334→\n   335→Examples:\n   336→  npm-agent                            # full suite\n   337→  npm-agent --fail-fast                # full suite, stop on first failure\n   338→  npm-agent lint                       # lint only\n   339→  npm-agent test                       # tests only\n   340→  RUN_BUILD=0 npm-agent                # skip build\n   341→  RUN_TESTS=0 RUN_BUILD=0 npm-agent    # lint + typecheck only\n   342→EOF\n   343→}\n   344→\n   345→main() {\n   346→  while [[ \"${1:-}\" == --* ]]; do\n   347→    case \"$1\" in\n   348→      --fail-fast) FAIL_FAST=1; shift ;;\n   349→      *) break ;;\n   350→    esac\n   351→  done\n   352→\n   353→  local cmd=\"${1:-all}\"\n   354→  shift 2>/dev/null || true\n   355→  local overall_ok=1\n   356→\n   357→  # Verify we're in a Node.js project\n   358→  if [[ ! -f \"package.json\" ]]; then\n   359→    echo \"Error: no package.json found in current directory\" >&2\n   360→    exit 2\n   361→  fi\n   362→\n   363→  case \"$cmd\" in\n   364→    -h|--help|help) usage; exit 0 ;;\n   365→    format)    run_format    || overall_ok=0 ;;\n   366→    lint)      run_lint      || overall_ok=0 ;;\n   367→    typecheck) run_typecheck || overall_ok=0 ;;\n   368→    test)      run_tests     || overall_ok=0 ;;\n   369→    build)     run_build     || overall_ok=0 ;;\n   370→    all)\n   371→      if [[ \"$RUN_FORMAT\" == \"1\" ]] && should_continue; then run_format || overall_ok=0; fi\n   372→      if [[ \"$RUN_LINT\" == \"1\" ]] && should_continue; then run_lint || overall_ok=0; fi\n   373→      if [[ \"$RUN_TYPECHECK\" == \"1\" ]] && should_continue; then run_typecheck || overall_ok=0; fi\n   374→      if [[ \"$RUN_TESTS\" == \"1\" ]] && should_continue; then run_tests || overall_ok=0; fi\n   375→      if [[ \"$RUN_BUILD\" == \"1\" ]] && should_continue; then run_build || overall_ok=0; fi\n   376→      ;;\n   377→    *)\n   378→      echo \"Unknown command: $cmd\" >&2\n   379→      usage\n   380→      exit 2\n   381→      ;;\n   382→  esac\n   383→\n   384→  hr\n   385→  echo \"Overall: $([[ \"$overall_ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   386→  echo \"Logs: $OUTDIR\"\n   387→  [[ \"$overall_ok\" == \"1\" ]]\n   388→}\n   389→\n   390→main \"$@\"\n   391→"}]},"parent_tool_use_id":null,"session_id":"6009da08-f492-4e44-8ec1-e3891bd2efc5","uuid":"afdff2a9-1e7d-4666-92f4-2dac6d71ba30","tool_use_result":{"type":"text","file":{"filePath":"/Users/chrisraethke/projects/x-agent/skills/npm-agent/scripts/npm-agent.sh","content":"#!/usr/bin/env bash\nset -euo pipefail\n\n# npm-agent: lean Node.js workflow output for coding agents\n# deps: bash, mktemp\n# optional: biome, eslint, prettier\n\nKEEP_DIR=\"${KEEP_DIR:-0}\"         # set to 1 to keep temp dir even on success\n# In CI, show full output; locally, limit to 40 lines to keep things tidy.\nif [[ \"${CI:-}\" == \"true\" || \"${CI:-}\" == \"1\" ]]; then\n  MAX_LINES=\"${MAX_LINES:-999999}\"\nelse\n  MAX_LINES=\"${MAX_LINES:-40}\"\nfi\nRUN_LINT=\"${RUN_LINT:-1}\"         # set to 0 to skip lint\nRUN_TYPECHECK=\"${RUN_TYPECHECK:-1}\" # set to 0 to skip typecheck\nRUN_FORMAT=\"${RUN_FORMAT:-1}\"     # set to 0 to skip format\nRUN_TESTS=\"${RUN_TESTS:-1}\"       # set to 0 to skip tests\nRUN_BUILD=\"${RUN_BUILD:-1}\"       # set to 0 to skip build\nFAIL_FAST=\"${FAIL_FAST:-0}\"      # set to 1 or use --fail-fast to stop after first failure\nCHANGED_FILES=\"${CHANGED_FILES:-}\"  # space-separated list of changed files; scopes lint/format\n\nTMPDIR_ROOT=\"${TMPDIR_ROOT:-/tmp}\"\nOUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/npm-agent.XXXXXX\")\"\n\ncleanup() {\n  local code=\"$?\"\n  if [[ \"$KEEP_DIR\" == \"1\" || \"$code\" != \"0\" ]]; then\n    echo \"Logs kept in: $OUTDIR\"\n  else\n    rm -rf \"$OUTDIR\"\n  fi\n  exit \"$code\"\n}\ntrap cleanup EXIT\n\nhr() { echo \"------------------------------------------------------------\"; }\n\n# Returns 0 (continue) unless fail-fast is on and a step already failed.\nshould_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n\nSTEP_START_SECONDS=0\n\nstep() {\n  local name=\"$1\"\n  STEP_START_SECONDS=$SECONDS\n  hr\n  echo \"Step: $name\"\n}\n\nfmt_elapsed() {\n  local elapsed=$(( SECONDS - STEP_START_SECONDS ))\n  echo \"Time: ${elapsed}s\"\n}\n\n# Detect which package manager is in use.\ndetect_pm() {\n  if [[ -f \"bun.lock\" || -f \"bun.lockb\" ]]; then echo \"bun\"\n  elif [[ -f \"pnpm-lock.yaml\" ]]; then echo \"pnpm\"\n  elif [[ -f \"yarn.lock\" ]]; then echo \"yarn\"\n  else echo \"npm\"\n  fi\n}\n\nPM=\"$(detect_pm)\"\necho \"Package manager: $PM\"\n\n# Filter CHANGED_FILES to JS/TS source files for scoping lint/format.\n_CHANGED_SRC_FILES=()\nif [[ -n \"$CHANGED_FILES\" ]]; then\n  for f in $CHANGED_FILES; do\n    case \"$f\" in\n      *.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs|*.mts|*.cts|*.json|*.css|*.scss|*.less|*.html|*.vue|*.svelte)\n        [[ -f \"$f\" ]] && _CHANGED_SRC_FILES+=(\"$f\")\n        ;;\n    esac\n  done\n  if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then\n    echo \"Scoped to ${#_CHANGED_SRC_FILES[@]} changed file(s)\"\n  fi\nfi\n\n# Run a package.json script if it exists, capturing output.\n# Returns 0 if the script ran successfully, 1 if it failed, 2 if script not found.\nrun_script() {\n  local script_name=\"$1\"\n  local log=\"$2\"\n\n  # Check if the script exists in package.json\n  if ! node -e \"\n    const pkg = require('./package.json');\n    if (!pkg.scripts || !pkg.scripts['$script_name']) process.exit(1);\n  \" 2>/dev/null; then\n    return 2\n  fi\n\n  if $PM run \"$script_name\" >\"$log\" 2>&1; then\n    return 0\n  else\n    return 1\n  fi\n}\n\nrun_format() {\n  step \"format\"\n  local log=\"$OUTDIR/format.log\"\n  local ok=1\n  local found=0\n\n  # Try package.json scripts first\n  for script in format fmt \"format:fix\" \"fmt:fix\" \"format:check\" \"fmt:check\"; do\n    run_script \"$script\" \"$log\"\n    local rc=$?\n    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n  done\n\n  # Fallback: try common formatters directly\n  if [[ \"$found\" == \"0\" ]]; then\n    # Use changed files when available, otherwise check entire project.\n    local -a targets=(.)\n    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n\n    if command -v biome >/dev/null 2>&1; then\n      echo \"Using: biome format\"\n      if biome format \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n    elif npx prettier --version >/dev/null 2>&1; then\n      echo \"Using: prettier\"\n      if npx prettier --check \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n    fi\n  fi\n\n  if [[ \"$found\" == \"0\" ]]; then\n    echo \"Result: SKIP (no formatter found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  echo\n  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the formatting issues, then re-run: /npm-agent format\"\n  echo \"Full log: $log\"\n  fmt_elapsed\n  [[ \"$ok\" == \"1\" ]]\n}\n\nrun_lint() {\n  step \"lint\"\n  local log=\"$OUTDIR/lint.log\"\n  local ok=1\n  local found=0\n\n  # Try package.json scripts first\n  for script in lint \"lint:fix\" \"lint:check\"; do\n    run_script \"$script\" \"$log\"\n    local rc=$?\n    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n  done\n\n  # Fallback: try common linters directly\n  if [[ \"$found\" == \"0\" ]]; then\n    # Use changed files when available, otherwise check entire project.\n    local -a targets=(.)\n    if [[ ${#_CHANGED_SRC_FILES[@]} -gt 0 ]]; then targets=(\"${_CHANGED_SRC_FILES[@]}\"); fi\n\n    if command -v biome >/dev/null 2>&1; then\n      echo \"Using: biome lint\"\n      if biome lint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n    elif npx eslint --version >/dev/null 2>&1; then\n      echo \"Using: eslint\"\n      if npx eslint \"${targets[@]}\" >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n    fi\n  fi\n\n  if [[ \"$found\" == \"0\" ]]; then\n    echo \"Result: SKIP (no linter found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  echo\n  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the lint errors above, then re-run: /npm-agent lint\"\n  echo \"Full log: $log\"\n  fmt_elapsed\n  [[ \"$ok\" == \"1\" ]]\n}\n\nrun_typecheck() {\n  step \"typecheck\"\n  local log=\"$OUTDIR/typecheck.log\"\n  local ok=1\n  local found=0\n\n  # Try package.json scripts first\n  for script in typecheck \"type-check\" \"types:check\" tsc; do\n    run_script \"$script\" \"$log\"\n    local rc=$?\n    if [[ \"$rc\" == \"0\" ]]; then found=1; break; fi\n    if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; break; fi\n  done\n\n  # Fallback: try tsc directly if tsconfig exists\n  if [[ \"$found\" == \"0\" && -f \"tsconfig.json\" ]]; then\n    echo \"Using: tsc --noEmit\"\n    if npx tsc --noEmit >\"$log\" 2>&1; then found=1; else found=1; ok=0; fi\n  fi\n\n  if [[ \"$found\" == \"0\" ]]; then\n    echo \"Result: SKIP (no TypeScript config found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  echo\n  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the type errors above, then re-run: /npm-agent typecheck\"\n  echo \"Full log: $log\"\n  fmt_elapsed\n  [[ \"$ok\" == \"1\" ]]\n}\n\nrun_tests() {\n  step \"test\"\n  local log=\"$OUTDIR/test.log\"\n  local ok=1\n  local found=0\n\n  # Try package.json \"test\" script\n  run_script \"test\" \"$log\"\n  local rc=$?\n  if [[ \"$rc\" == \"0\" ]]; then found=1; fi\n  if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; fi\n\n  if [[ \"$found\" == \"0\" ]]; then\n    echo \"Result: SKIP (no test script found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  echo\n  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the failing tests, then re-run: /npm-agent test\"\n  echo \"Full log: $log\"\n  fmt_elapsed\n  [[ \"$ok\" == \"1\" ]]\n}\n\nrun_build() {\n  step \"build\"\n  local log=\"$OUTDIR/build.log\"\n  local ok=1\n  local found=0\n\n  run_script \"build\" \"$log\"\n  local rc=$?\n  if [[ \"$rc\" == \"0\" ]]; then found=1; fi\n  if [[ \"$rc\" == \"1\" ]]; then found=1; ok=0; fi\n\n  if [[ \"$found\" == \"0\" ]]; then\n    echo \"Result: SKIP (no build script found)\"\n    fmt_elapsed\n    return 0\n  fi\n\n  if [[ \"$ok\" == \"0\" && -s \"$log\" ]]; then\n    echo\n    echo \"Output (first ${MAX_LINES} lines):\"\n    head -n \"$MAX_LINES\" \"$log\"\n  fi\n\n  echo\n  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the build errors above, then re-run: /npm-agent build\"\n  echo \"Full log: $log\"\n  fmt_elapsed\n  [[ \"$ok\" == \"1\" ]]\n}\n\nusage() {\n  cat <<'EOF'\nnpm-agent: lean Node.js workflow output for coding agents\n\nUsage:\n  npm-agent [--fail-fast]              # runs format, lint, typecheck, test, build\n  npm-agent [--fail-fast] format|lint|typecheck|test|build|all\n\nFlags:\n  --fail-fast            stop after first failing step\n\nEnv knobs:\n  MAX_LINES=40           # printed lines per step (unlimited in CI)\n  KEEP_DIR=0|1           # keep temp log dir even on success\n  FAIL_FAST=0|1          # same as --fail-fast flag\n  RUN_FORMAT=0|1\n  RUN_LINT=0|1\n  RUN_TYPECHECK=0|1\n  RUN_TESTS=0|1\n  RUN_BUILD=0|1\n  CHANGED_FILES=\"f1 f2\"   # scope lint/format to changed files (fallback tools only)\n\nAuto-detection:\n  - Package manager: detects bun, pnpm, yarn, or npm from lock files\n  - Format: tries package.json scripts (format, fmt), then biome, then prettier\n  - Lint: tries package.json scripts (lint), then biome, then eslint\n  - Typecheck: tries package.json scripts (typecheck, tsc), then tsc --noEmit\n  - Tests: runs package.json \"test\" script\n  - Build: runs package.json \"build\" script\n\nExamples:\n  npm-agent                            # full suite\n  npm-agent --fail-fast                # full suite, stop on first failure\n  npm-agent lint                       # lint only\n  npm-agent test                       # tests only\n  RUN_BUILD=0 npm-agent                # skip build\n  RUN_TESTS=0 RUN_BUILD=0 npm-agent    # lint + typecheck only\nEOF\n}\n\nmain() {\n  while [[ \"${1:-}\" == --* ]]; do\n    case \"$1\" in\n      --fail-fast) FAIL_FAST=1; shift ;;\n      *) break ;;\n    esac\n  done\n\n  local cmd=\"${1:-all}\"\n  shift 2>/dev/null || true\n  local overall_ok=1\n\n  # Verify we're in a Node.js project\n  if [[ ! -f \"package.json\" ]]; then\n    echo \"Error: no package.json found in current directory\" >&2\n    exit 2\n  fi\n\n  case \"$cmd\" in\n    -h|--help|help) usage; exit 0 ;;\n    format)    run_format    || overall_ok=0 ;;\n    lint)      run_lint      || overall_ok=0 ;;\n    typecheck) run_typecheck || overall_ok=0 ;;\n    test)      run_tests     || overall_ok=0 ;;\n    build)     run_build     || overall_ok=0 ;;\n    all)\n      if [[ \"$RUN_FORMAT\" == \"1\" ]] && should_continue; then run_format || overall_ok=0; fi\n      if [[ \"$RUN_LINT\" == \"1\" ]] && should_continue; then run_lint || overall_ok=0; fi\n      if [[ \"$RUN_TYPECHECK\" == \"1\" ]] && should_continue; then run_typecheck || overall_ok=0; fi\n      if [[ \"$RUN_TESTS\" == \"1\" ]] && should_continue; then run_tests || overall_ok=0; fi\n      if [[ \"$RUN_BUILD\" == \"1\" ]] && should_continue; then run_build || overall_ok=0; fi\n      ;;\n    *)\n      echo \"Unknown command: $cmd\" >&2\n      usage\n      exit 2\n      ;;\n  esac\n\n  hr\n  echo \"Overall: $([[ \"$overall_ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n  echo \"Logs: $OUTDIR\"\n  [[ \"$overall_ok\" == \"1\" ]]\n}\n\nmain \"$@\"\n","numLines":391,"startLine":1,"totalLines":391}}}
