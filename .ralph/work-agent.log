sts=\"$(extract_failing_tests \"$log\")\"\n   490→    if [[ -n \"$failed_tests\" ]]; then\n   491→      echo\n   492→      echo \"Failing tests:\"\n   493→      echo \"$failed_tests\" | while read -r test_name; do\n   494→        [[ -n \"$test_name\" ]] && echo \"  $test_name\"\n   495→      done\n   496→      echo\n   497→      echo \"Re-run failing tests with:\"\n   498→      echo \"$failed_tests\" | while read -r test_name; do\n   499→        [[ -n \"$test_name\" ]] && echo \"  /cargo-agent test $test_name\"\n   500→      done\n   501→    fi\n   502→  fi\n   503→\n   504→  echo\n   505→  echo \"Result: $([[ \"$ok\" == \"1\" ]] && echo PASS || echo FAIL)\"\n   506→  [[ \"$ok\" == \"0\" ]] && echo \"Fix: resolve the failing tests, then re-run: /cargo-agent test\"\n   507→  echo \"Full log: $log\"\n   508→  fmt_elapsed\n   509→  [[ \"$ok\" == \"1\" ]]\n   510→}\n   511→\n   512→usage() {\n   513→  cat <<'EOF'\n   514→cargo-agent: lean Rust workflow output for coding agents\n   515→\n   516→Usage:\n   517→  cargo-agent [--fail-fast]            # runs fmt, clippy, sqlx, nextest (if installed)\n   518→  cargo-agent [--fail-fast] fmt|check|clippy|sqlx|all\n   519→  cargo-agent [--fail-fast] test [--changed|--all] [NEXTEST_ARGS]\n   520→\n   521→Flags:\n   522→  --fail-fast            stop after first failing step; also passed to nextest\n   523→\n   524→Env knobs:\n   525→  MAX_LINES=40           # printed lines per step (unlimited in CI)\n   526→  KEEP_DIR=0|1           # keep temp log dir even on success\n   527→  FAIL_FAST=0|1          # same as --fail-fast flag\n   528→  RUN_FMT=0|1\n   529→  CI=true|1             # fmt runs in check mode on CI, fix mode locally\n   530→  RUN_CHECK=0|1\n   531→  RUN_CLIPPY=0|1\n   532→  RUN_SQLX=0|1\n   533→  RUN_TESTS=0|1\n   534→  RUN_INTEGRATION=0|1  # enable integration tests (requires DB/network)\n   535→  USE_NEXTEST=auto|1|0\n   536→  CHANGED_FILES=\"f1 f2\"   # scope check/clippy/test to affected packages\n   537→\n   538→Examples:\n   539→  cargo-agent                          # full suite\n   540→  cargo-agent --fail-fast              # full suite, stop on first failure\n   541→  cargo-agent sqlx                     # sqlx cache verify only\n   542→  cargo-agent test test_login          # tests matching \"test_login\"\n   543→  cargo-agent test --changed           # tests for crates with changed files\n   544→  cargo-agent test --changed test_auth # changed-crate tests filtered by \"test_auth\"\n   545→  cargo-agent test -p db               # tests in the db crate\n   546→  cargo-agent test -p api test_auth    # \"test_auth\" in api crate\n   547→  RUN_TESTS=0 cargo-agent              # skip tests\n   548→EOF\n   549→}\n   550→\n   551→main() {\n   552→  while [[ \"${1:-}\" == --* ]]; do\n   553→    case \"$1\" in\n   554→      --fail-fast) FAIL_FAST=1; shift ;;\n   555→      *) break ;;\n   556→    esac\n   557→  done\n   558→\n   559→  local cmd=\"${1:-all}\"\n   560→  shift 2>/dev/null || true\n   561→  local overall_ok=1\n   562→\n   563→  resolve_affected_packages\n   564→\n   565→  case \"$cmd\" in\n   566→    -h|--help|help) usage; exit 0 ;;\n   567→    fmt)   run_fmt   || overall_ok=0 ;;\n   568→    check) run_check || overall_ok=0 ;;\n   569→    clippy) run_clippy || overall_ok=0 ;;\n   570→    sqlx) run_sqlx_verify || overall_ok=0 ;;\n   571→    test)  run_tests \"$@\" || overall_ok=0 ;;\n   572→    all)\n   573→      # sqlx runs early: it verifies the cache before compilation steps, and\n   574→      # a stale cache causes confusing downstream errors in check/clippy.\n   575→      if [[ \"$RUN_FMT\" == \"1\" ]] && should_continue; then run_fmt || overall_ok=0; fi\n   576→      if [[ \"$RUN_SQLX\" == \"1\" ]] && should_continue; then run_sqlx_verify || overall_ok=0; fi\n   577→      # Skip check when clippy is enabled — clippy is a superset of check.\n   578→      if [[ \"$RUN_CHECK\" == \"1\" && \"$RUN_CLIPPY\" != \"1\" ]] && should_continue; then run_check || overall_ok=0