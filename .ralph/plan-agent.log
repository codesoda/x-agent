set -euo pipefail

# py-agent: lean Python workflow output for coding agents
# deps: bash, mktemp
# optional: ruff, black, mypy, pyright, pytest

KEEP_DIR="${KEEP_DIR:-0}"         # set to 1 to keep temp dir even on success
