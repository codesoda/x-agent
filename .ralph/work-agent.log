    67→    label=\"$SCENARIO_NAME\"\n    68→  else\n    69→    label=\"$(scenario_label_from_file \"$scenario_file\")\"\n    70→  fi\n    71→\n    72→  if [[ -z \"${AGENT_SCRIPT}\" ]]; then\n    73→    print_status \"FAIL\" \"${label} (AGENT_SCRIPT not set)\"\n    74→    return 1\n    75→  fi\n    76→\n    77→  local script_path=\"${ROOT_DIR}/${AGENT_SCRIPT}\"\n    78→  if [[ ! -x \"$script_path\" ]]; then\n    79→    print_status \"SKIP\" \"${label} (missing script: ${AGENT_SCRIPT})\"\n    80→    return 0\n    81→  fi\n    82→\n    83→  local missing_tool=\"\"\n    84→  if missing_tool=\"$(missing_required_tool \"${REQUIRED_TOOLS}\")\"; then\n    85→    print_status \"SKIP\" \"${label} (missing tool: ${missing_tool})\"\n    86→    return 0\n    87→  fi\n    88→\n    89→  mkdir -p \"$LOG_DIR\"\n    90→  local safe_name\n    91→  safe_name=\"$(echo \"$label\" | tr '/ ' '__' | tr -cd '[:alnum:]_.-')\"\n    92→  local log_file=\"${LOG_DIR}/${safe_name}.log\"\n    93→\n    94→  local -a args=()\n    95→  if [[ -n \"${RUN_ARGS}\" ]]; then\n    96→    # shellcheck disable=SC2206\n    97→    args=($RUN_ARGS)\n    98→  fi\n    99→\n   100→  local exit_code\n   101→  pushd \"$scenario_dir\" >/dev/null\n   102→  set +e\n   103→  \"$script_path\" \"${args[@]}\" >\"$log_file\" 2>&1\n   104→  exit_code=$?\n   105→  set -e\n   106→  popd >/dev/null\n   107→\n   108→  if [[ \"$exit_code\" == \"$EXPECT_EXIT\" ]]; then\n   109→    print_status \"PASS\" \"$label\"\n   110→    return 0\n   111→  fi\n   112→\n   113→  print_status \"FAIL\" \"${label} (expected ${EXPECT_EXIT}, got ${exit_code})\"\n   114→  echo \"  Log: $log_file\"\n   115→  echo \"  Output (first 40 lines):\"\n   116→  sed -n '1,40p' \"$log_file\" | sed 's/^/    /'\n   117→  return 1\n   118→}\n   119→\n   120→run_shellcheck() {\n   121→  if ! command -v shellcheck >/dev/null 2>&1; then\n   122→    print_status \"FAIL\" \"shellcheck (not installed — brew install shellcheck)\"\n   123→    return 1\n   124→  fi\n   125→\