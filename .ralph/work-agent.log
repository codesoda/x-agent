{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TM5pjPTKq8ThuC4N8NhB1r","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→ROOT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n     5→TESTS_DIR=\"${ROOT_DIR}/tests\"\n     6→LOG_DIR=\"${TESTS_DIR}/.logs\"\n     7→\n     8→usage() {\n     9→  cat <<'EOF'\n    10→Run x-agent scenario fixtures.\n    11→\n    12→Usage:\n    13→  tests/run-scenarios.sh [FILTER]\n    14→  tests/run-scenarios.sh --list\n    15→  tests/run-scenarios.sh --help\n    16→\n    17→Examples:\n    18→  tests/run-scenarios.sh\n    19→  tests/run-scenarios.sh cargo-agent\n    20→  tests/run-scenarios.sh npm-agent/issues\n    21→EOF\n    22→}\n    23→\n    24→print_status() {\n    25→  local status=\"$1\"\n    26→  local message=\"$2\"\n    27→  printf \"%-6s %s\\n\" \"$status\" \"$message\"\n    28→}\n    29→\n    30→scenario_label_from_file() {\n    31→  local scenario_file=\"$1\"\n    32→  echo \"${scenario_file#${ROOT_DIR}/tests/}\" | sed 's|/scenario.env$||'\n    33→}\n    34→\n    35→list_scenarios() {\n    36→  find \"$TESTS_DIR\" -type f -name scenario.env | sort\n    37→}\n    38→\n    39→missing_required_tool() {\n    40→  local tools=\"$1\"\n    41→  local tool\n    42→  for tool in $tools; do\n    43→    if ! command -v \"$tool\" >/dev/null 2>&1; then\n    44→      echo \"$tool\"\n    45→      return 0\n    46→    fi\n    47→  done\n    48→  return 1\n    49→}\n    50→\n    51→run_one() {\n    52→  local scenario_file=\"$1\"\n    53→  local scenario_dir\n    54→  scenario_dir=\"$(dirname \"$scenario_file\")\"\n    55→\n    56→  local SCENARIO_NAME=\"\"\n    57→  local AGENT_SCRIPT=\"\"\n    58→  local RUN_ARGS=\"all\"\n    59→  local EXPECT_EXIT=\"0\"\n    60→  local REQUIRED_TOOLS=\"\"\n    61→\n    62→  # shellcheck source=/dev/null\n    63→  source \"$scenario_file\"\n    64→\n    65→  local label\n    66→  if [[ -n \"${SCENARIO_NAME}\" ]]; then\n    67→    label=\"$SCENARIO_NAME\"\n    68→  else\n    69→    label=\"$(scenario_label_from_file \"$scenario_file\")\"\n    70→  fi\n    71→\n    72→  if [[ -z \"${AGENT_SCRIPT}\" ]]; then\n    73→    print_status \"FAIL\" \"${label} (AGENT_SCRIPT not set)\"\n    74→    return 1\n    75→  fi\n    76→\n    77→  local script_path=\"${ROOT_DIR}/${AGENT_SCRIPT}\"\n    78→  if [[ ! -x \"$script_path\" ]]; then\n    79→    print_status \"SKIP\" \"${label} (missing script: ${AGENT_SCRIPT})\"\n    80→    return 0\n    81→  fi\n    82→\n    83→  local missing_tool=\"\"\n    84→  if missing_tool=\"$(missing_required_tool \"${REQUIRED_TOOLS}\")\"; then\n    85→    print_status \"SKIP\" \"${label} (missing tool: ${missing_tool})\"\n    86→    return 0\n    87→  fi\n    88→\n    89→  mkdir -p \"$LOG_DIR\"\n    90→  local safe_name\n    91→  safe_name=\"$(echo \"$label\" | tr '/ ' '__' | tr -cd '[:alnum:]_.-')\"\n    92→  local log_file=\"${LOG_DIR}/${safe_name}.log\"\n    93→\n    94→  local -a args=()\n    95→  if [[ -n \"${RUN_ARGS}\" ]]; then\n    96→    # shellcheck disable=SC2206\n    97→    args=($RUN_ARGS)\n    98→  fi\n    99→\n   100→  local exit_code\n   101→  pushd \"$scenario_dir\" >/dev/null\n   102→  set +e\n   103→  \"$script_path\" \"${args[@]}\" >\"$log_file\" 2>&1\n   104→  exit_code=$?\n   105→  set -e\n   106→  popd >/dev/null\n   107→\n   108→  if [[ \"$exit_code\" == \"$EXPECT_EXIT\" ]]; then\n   109→    print_status \"PASS\" \"$label\"\n   110→    return 0\n   111→  fi\n   112→\n   113→  print_status \"FAIL\" \"${label} (expected ${EXPECT_EXIT}, got ${exit_code})\"\n   114→  echo \"  Log: $log_file\"\n   115→  echo \"  Output (first 40 lines):\"\n   116→  sed -n '1,40p' \"$log_file\" | sed 's/^/    /'\n   117→  return 1\n   118→}\n   119→\n   120→run_shellcheck() {\n   121→  if ! command -v shellcheck >/dev/null 2>&1; then\n   122→    print_status \"FAIL\" \"shellcheck (not installed — brew install shellcheck)\"\n   123→    return 1\n   124→  fi\n   125→\n   126→  local scripts=()\n   127→  while IFS= read -r -d '' f; do\n   128→    scripts+=(\"$f\")\n   129→  done < <(find \"$ROOT_DIR/skills\" -name '*.sh' -print0; find \"$ROOT_DIR/lib\" -name '*.sh' -print0 2>/dev/null; find \"$TESTS_DIR\" -name '*.sh' -not -path '*/issues/*' -print0; find \"$ROOT_DIR\" -maxdepth 1 -name '*.sh' -print0)\n   130→\n   131→  if shellcheck --severity=warning \"${scripts[@]}\" >/dev/null 2>&1; then\n   132→    print_status \"PASS\" \"shellcheck\"\n   133→    return 0\n   134→  fi\n   135→\n   136→  print_status \"FAIL\" \"shellcheck\"\n   137→  shellcheck --severity=warning \"${scripts[@]}\" | sed 's/^/    /'\n   138→  return 1\n   139→}\n   140→\n   141→main() {\n   142→  local mode=\"${1:-run}\"\n   143→  local filter=\"\"\n   144→\n   145→  case \"$mode\" in\n   146→    -h|--help|help)\n   147→      usage\n   148→      exit 0\n   149→      ;;\n   150→    --list)\n   151→      while IFS= read -r scenario_file; do\n   152→        scenario_label_from_file \"$scenario_file\"\n   153→      done < <(list_scenarios)\n   154→      exit 0\n   155→      ;;\n   156→    *)\n   157→      if [[ \"$#\" -gt 0 ]]; then\n   158→        filter=\"$1\"\n   159→      fi\n   160→      ;;\n   161→  esac\n   162→\n   163→  local total=0\n   164→  local failed=0\n   165→\n   166→  # Run shellcheck if no filter or filter matches \"shellcheck\"\n   167→  if [[ -z \"$filter\" || \"shellcheck\" == *\"$filter\"* ]]; then\n   168→    total=$((total + 1))\n   169→    if ! run_shellcheck; then\n   170→      failed=$((failed + 1))\n   171→    fi\n   172→  fi\n   173→\n   174→  while IFS= read -r scenario_file; do\n   175→    if [[ -n \"$filter\" && \"$scenario_file\" != *\"$filter\"* ]]; then\n   176→      continue\n   177→    fi\n   178→\n   179→    total=$((total + 1))\n   180→    if ! run_one \"$scenario_file\"; then\n   181→      failed=$((failed + 1))\n   182→    fi\n   183→  done < <(list_scenarios)\n   184→\n   185→  echo \"------\"\n   186→  echo \"Scenarios run: $total\"\n   187→  echo \"Failures: $failed\"\n   188→  [[ \"$failed\" -eq 0 ]]\n   189→}\n   190→\n   191→main \"$@\"\n   192→\n   193→"}]},"parent_tool_use_id":"toolu_01UaaUozJ2uL6jqxkwRdUpW4","session_id":"46dcc7a2-447a-40b5-b7b3-893789d3fd2e","uuid":"fbb52149-1480-4789-8a41-3dbc0c87821f"}
