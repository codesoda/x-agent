{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0172wCNq3krajcj6Fk5496pq","type":"tool_result","content":"     1→#!/bin/sh\n     2→set -eu\n     3→\n     4→# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n     5→# Works via: curl -sSf <raw-url>/install.sh | sh\n     6→# Or locally: sh install.sh\n     7→\n     8→PROJECT_NAME=\"x-agent\"\n     9→REPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\n    10→REPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\n    11→REPO_REF=\"${X_AGENT_REPO_REF:-main}\"\n    12→RAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n    13→\n    14→CODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\n    15→CLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n    16→\n    17→AUTO_YES=0\n    18→SKIP_DEPS=0\n    19→INSTALL_CODEX=1\n    20→INSTALL_CLAUDE=1\n    21→\n    22→TMP_DIR=\"\"\n    23→SOURCE_DIR=\"\"\n    24→SOURCE_MODE=\"remote\"\n    25→\n    26→# Available skills to install (each has its own scripts/ subdirectory)\n    27→SKILLS=\"bash-agent cargo-agent go-agent npm-agent py-agent terra-agent\"\n    28→SELECTED_SKILLS=\"\"\n    29→\n    30→info() {\n    31→  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n    32→}\n    33→\n    34→warn() {\n    35→  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    36→}\n    37→\n    38→die() {\n    39→  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    40→  exit 1\n    41→}\n    42→\n    43→usage() {\n    44→  cat <<'EOF'\n    45→Install x-agent skills and scripts into local agent skill directories.\n    46→\n    47→Usage:\n    48→  sh install.sh [options]\n    49→  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n    50→\n    51→Options:\n    52→  --yes          Non-interactive mode; accept default install prompts.\n    53→  --skip-deps    Skip dependency checks.\n    54→  --codex-only   Only install to ~/.codex/skills.\n    55→  --claude-only  Only install to ~/.claude/skills.\n    56→  --help         Show this help text.\n    57→\n    58→Notes:\n    59→  Interactive mode prompts per x-agent skill and install destination.\n    60→  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n    61→\n    62→Environment variables:\n    63→  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n    64→  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n    65→  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n    66→  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n    67→  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n    68→  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\n    69→EOF\n    70→}\n    71→\n    72→cleanup() {\n    73→  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    74→    rm -rf \"$TMP_DIR\"\n    75→  fi\n    76→}\n    77→\n    78→trap cleanup EXIT INT TERM\n    79→\n    80→prompt_yes_no() {\n    81→  question=\"$1\"\n    82→  default=\"${2:-yes}\"\n    83→\n    84→  if [ \"$AUTO_YES\" -eq 1 ]; then\n    85→    return 0\n    86→  fi\n    87→\n    88→  if [ \"$default\" = \"yes\" ]; then\n    89→    prompt=\"[Y/n]\"\n    90→    fallback=\"yes\"\n    91→  else\n    92→    prompt=\"[y/N]\"\n    93→    fallback=\"no\"\n    94→  fi\n    95→\n    96→  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    97→    while :; do\n    98→      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n    99→      if ! IFS= read -r answer < /dev/tty; then\n   100→        break\n   101→      fi\n   102→      case \"$answer\" in\n   103→        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n   104→        [Nn]|[Nn][Oo]) return 1 ;;\n   105→        \"\")\n   106→          if [ \"$fallback\" = \"yes\" ]; then\n   107→            return 0\n   108→          fi\n   109→          return 1\n   110→          ;;\n   111→        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n   112→      esac\n   113→    done\n   114→  fi\n   115→\n   116→  [ \"$fallback\" = \"yes\" ]\n   117→}\n   118→\n   119→skill_selected() {\n   120→  skill=\"$1\"\n   121→  case \" ${SELECTED_SKILLS} \" in\n   122→    *\" ${skill} \"*) return 0 ;;\n   123→    *) return 1 ;;\n   124→  esac\n   125→}\n   126→\n   127→add_selected_skill() {\n   128→  skill=\"$1\"\n   129→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   130→    SELECTED_SKILLS=\"$skill\"\n   131→  else\n   132→    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n   133→  fi\n   134→}\n   135→\n   136→select_skills() {\n   137→  if [ \"$AUTO_YES\" -eq 1 ]; then\n   138→    SELECTED_SKILLS=\"$SKILLS\"\n   139→    return 0\n   140→  fi\n   141→\n   142→  info \"Select x-agent skills to install:\"\n   143→  for skill in $SKILLS; do\n   144→    if prompt_yes_no \"Install ${skill}?\" yes; then\n   145→      add_selected_skill \"$skill\"\n   146→    fi\n   147→  done\n   148→}\n   149→\n   150→fetch_to_file() {\n   151→  url=\"$1\"\n   152→  out=\"$2\"\n   153→\n   154→  if command -v curl >/dev/null 2>&1; then\n   155→    curl -fsSL \"$url\" -o \"$out\"\n   156→    return 0\n   157→  fi\n   158→\n   159→  if command -v wget >/dev/null 2>&1; then\n   160→    wget -qO \"$out\" \"$url\"\n   161→    return 0\n   162→  fi\n   163→\n   164→  return 1\n   165→}\n   166→\n   167→# Detect if we're running from a local checkout or need to fetch from remote.\n   168→resolve_source_dir() {\n   169→  # Check if running from inside the repo\n   170→  if [ -d \"./skills\" ]; then\n   171→    SOURCE_DIR=\"$(pwd)\"\n   172→    SOURCE_MODE=\"local\"\n   173→    info \"Using local source at ${SOURCE_DIR}.\"\n   174→    return 0\n   175→  fi\n   176→\n   177→  # Check relative to the script location\n   178→  case \"$0\" in\n   179→    */*)\n   180→      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n   181→      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n   182→        SOURCE_DIR=\"$script_dir\"\n   183→        SOURCE_MODE=\"local\"\n   184→        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n   185→        return 0\n   186→      fi\n   187→      ;;\n   188→  esac\n   189→\n   190→  # Remote fetch\n   191→  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n   192→  SOURCE_DIR=\"${TMP_DIR}\"\n   193→  SOURCE_MODE=\"remote\"\n   194→\n   195→  # Fetch shared library\n   196→  mkdir -p \"${SOURCE_DIR}/lib\"\n   197→  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n   198→  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n   199→  info \"Fetching lib/x-agent-common.sh...\"\n   200→  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   201→    die \"Unable to download ${src_url}\"\n   202→  fi\n   203→\n   204→  # Fetch each selected skill's SKILL.md and scripts\n   205→  for skill in $SELECTED_SKILLS; do\n   206→    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n   207→\n   208→    # Fetch SKILL.md\n   209→    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n   210→    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n   211→    info \"Fetching skills/${skill}/SKILL.md...\"\n   212→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   213→      die \"Unable to download ${src_url}\"\n   214→    fi\n   215→\n   216→    # Fetch the skill's script\n   217→    script_name=\"${skill}.sh\"\n   218→    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n   219→    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n   220→    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n   221→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   222→      die \"Unable to download ${src_url}\"\n   223→    fi\n   224→    chmod +x \"$dest\"\n   225→  done\n   226→}\n   227→\n   228→# Install a single skill to a skills root, with scripts alongside it.\n   229→install_skill_to_root() {\n   230→  root=\"$1\"\n   231→  skill=\"$2\"\n   232→  target=\"${root}/${skill}\"\n   233→\n   234→  mkdir -p \"$root\"\n   235→  rm -rf \"$target\"\n   236→\n   237→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   238→    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n   239→    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n   240→  else\n   241→    mkdir -p \"$target\"\n   242→    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n   243→    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n   244→    info \"Installed ${skill} to ${target}\"\n   245→  fi\n   246→}\n   247→\n   248→# Install the shared library to a skills root so agent scripts can source it.\n   249→# For local installs, symlink the lib/ directory.\n   250→# For remote installs, copy the fetched lib/ directory.\n   251→install_lib_to_root() {\n   252→  root=\"$1\"\n   253→  target=\"${root}/lib\"\n   254→\n   255→  mkdir -p \"$root\"\n   256→  rm -rf \"$target\"\n   257→\n   258→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   259→    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n   260→    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n   261→  else\n   262→    mkdir -p \"$target\"\n   263→    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n   264→    info \"Installed lib to ${target}\"\n   265→  fi\n   266→}\n   267→\n   268→# Rewrite SKILL.md paths to point at the actual installed script location.\n   269→patch_skill_paths() {\n   270→  root=\"$1\"\n   271→  skill=\"$2\"\n   272→  skill_md=\"${root}/${skill}/SKILL.md\"\n   273→\n   274→  if [ ! -f \"$skill_md\" ]; then return; fi\n   275→\n   276→  # For local (symlink) installs, paths already point to the right place via the repo.\n   277→  # For remote installs, update paths to point at the skill's bundled scripts dir.\n   278→  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n   279→    scripts_dir=\"${root}/${skill}/scripts\"\n   280→    # Replace relative scripts/ paths with the actual installed path\n   281→    if command -v sed >/dev/null 2>&1; then\n   282→      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n   283→      rm -f \"${skill_md}.bak\"\n   284→    fi\n   285→  fi\n   286→}\n   287→\n   288→check_optional_deps() {\n   289→  info \"Checking optional dependencies...\"\n   290→  all_ok=1\n   291→\n   292→  if skill_selected \"bash-agent\"; then\n   293→    if command -v shellcheck >/dev/null 2>&1; then\n   294→      info \"  Found: shellcheck\"\n   295→    else\n   296→      warn \"  Missing: shellcheck (needed by bash-agent)\"\n   297→      all_ok=0\n   298→    fi\n   299→  fi\n   300→\n   301→  if skill_selected \"go-agent\"; then\n   302→    if command -v go >/dev/null 2>&1; then\n   303→      info \"  Found: go\"\n   304→    else\n   305→      warn \"  Missing: go (needed by go-agent)\"\n   306→      all_ok=0\n   307→    fi\n   308→\n   309→    if command -v staticcheck >/dev/null 2>&1; then\n   310→      info \"  Found: staticcheck\"\n   311→    else\n   312→      warn \"  Missing: staticcheck (optional for go-agent staticcheck step)\"\n   313→    fi\n   314→  fi\n   315→\n   316→  if skill_selected \"cargo-agent\"; then\n   317→    if command -v jq >/dev/null 2>&1; then\n   318→      info \"  Found: jq\"\n   319→    else\n   320→      warn \"  Missing: jq (needed by cargo-agent)\"\n   321→      all_ok=0\n   322→    fi\n   323→\n   324→    if command -v cargo >/dev/null 2>&1; then\n   325→      info \"  Found: cargo\"\n   326→    else\n   327→      warn \"  Missing: cargo (needed by cargo-agent)\"\n   328→      all_ok=0\n   329→    fi\n   330→  fi\n   331→\n   332→  if skill_selected \"npm-agent\"; then\n   333→    if command -v node >/dev/null 2>&1; then\n   334→      info \"  Found: node\"\n   335→    else\n   336→      warn \"  Missing: node (needed by npm-agent)\"\n   337→      all_ok=0\n   338→    fi\n   339→  fi\n   340→\n   341→  if skill_selected \"py-agent\"; then\n   342→    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n   343→      info \"  Found: python\"\n   344→    else\n   345→      warn \"  Missing: python3 (needed by py-agent)\"\n   346→      all_ok=0\n   347→    fi\n   348→\n   349→    for dep in ruff black; do\n   350→      if command -v \"$dep\" >/dev/null 2>&1; then\n   351→        info \"  Found: ${dep}\"\n   352→        break\n   353→      fi\n   354→    done\n   355→  fi\n   356→\n   357→  if skill_selected \"terra-agent\"; then\n   358→    if command -v terraform >/dev/null 2>&1; then\n   359→      info \"  Found: terraform\"\n   360→    else\n   361→      warn \"  Missing: terraform (needed by terra-agent)\"\n   362→      all_ok=0\n   363→    fi\n   364→\n   365→    if command -v tflint >/dev/null 2>&1; then\n   366→      info \"  Found: tflint\"\n   367→    else\n   368→      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n   369→    fi\n   370→  fi\n   371→\n   372→  if [ \"$all_ok\" -eq 0 ]; then\n   373→    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n   374→  fi\n   375→}\n   376→\n   377→print_agents_md_snippet() {\n   378→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   379→    return 0\n   380→  fi\n   381→\n   382→  echo \"\"\n   383→  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n   384→  echo \"## x-agent checks\"\n   385→  echo \"\"\n   386→  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n   387→\n   388→  for skill in $SELECTED_SKILLS; do\n   389→    case \"$skill\" in\n   390→      bash-agent)\n   391→        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n   392→        ;;\n   393→      go-agent)\n   394→        echo \"- Go: use \\`/go-agent\\` (fmt/vet/staticcheck/test).\"\n   395→        ;;\n   396→      cargo-agent)\n   397→        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n   398→        ;;\n   399→      npm-agent)\n   400→        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n   401→        ;;\n   402→      py-agent)\n   403→        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n   404→        ;;\n   405→      terra-agent)\n   406→        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n   407→        ;;\n   408→    esac\n   409→  done\n   410→\n   411→  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n   412→  echo \"- If a change touches multiple stacks, run all matching skills.\"\n   413→  if skill_selected \"terra-agent\"; then\n   414→    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n   415→    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n   416→  fi\n   417→  echo \"- Resolve all FAIL results before completing the task.\"\n   418→  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n   419→}\n   420→\n   421→# --- Main ---\n   422→\n   423→while [ $# -gt 0 ]; do\n   424→  case \"$1\" in\n   425→    --yes)\n   426→      AUTO_YES=1\n   427→      ;;\n   428→    --skip-deps)\n   429→      SKIP_DEPS=1\n   430→      ;;\n   431→    --codex-only)\n   432→      INSTALL_CODEX=1\n   433→      INSTALL_CLAUDE=0\n   434→      ;;\n   435→    --claude-only)\n   436→      INSTALL_CODEX=0\n   437→      INSTALL_CLAUDE=1\n   438→      ;;\n   439→    --help|-h)\n   440→      usage\n   441→      exit 0\n   442→      ;;\n   443→    *)\n   444→      die \"Unknown option: $1 (use --help)\"\n   445→      ;;\n   446→  esac\n   447→  shift\n   448→done\n   449→\n   450→info \"x-agent installer\"\n   451→info \"==================\"\n   452→\n   453→select_skills\n   454→if [ -z \"$SELECTED_SKILLS\" ]; then\n   455→  info \"No skills selected. Nothing to install.\"\n   456→  info \"Done.\"\n   457→  exit 0\n   458→fi\n   459→\n   460→resolve_source_dir\n   461→\n   462→if [ \"$SKIP_DEPS\" -eq 0 ]; then\n   463→  check_optional_deps\n   464→else\n   465→  info \"Skipping dependency checks (--skip-deps).\"\n   466→fi\n   467→\n   468→if [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n   469→  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n   470→    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n   471→    for skill in $SELECTED_SKILLS; do\n   472→      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   473→      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   474→    done\n   475→  else\n   476→    info \"Skipped Claude install.\"\n   477→  fi\n   478→fi\n   479→\n   480→if [ \"$INSTALL_CODEX\" -eq 1 ]; then\n   481→  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n   482→    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n   483→    for skill in $SELECTED_SKILLS; do\n   484→      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n   485→      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n   486→    done\n   487→  else\n   488→    info \"Skipped Codex install.\"\n   489→  fi\n   490→fi\n   491→\n   492→info \"\"\n   493→info \"Installed skills: ${SELECTED_SKILLS}\"\n   494→info \"\"\n   495→print_agents_md_snippet\n   496→info \"\"\n   497→info \"Done.\"\n   498→"}]},"parent_tool_use_id":null,"session_id":"04f1945e-7bf3-4940-ab64-46803dcd06b1","uuid":"4b09fd73-84c0-4c27-a303-96365779e362","tool_use_result":{"type":"text","file":{"filePath":"/Users/chrisraethke/projects/x-agent/install.sh","content":"#!/bin/sh\nset -eu\n\n# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n# Works via: curl -sSf <raw-url>/install.sh | sh\n# Or locally: sh install.sh\n\nPROJECT_NAME=\"x-agent\"\nREPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\nREPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\nREPO_REF=\"${X_AGENT_REPO_REF:-main}\"\nRAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n\nCODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\nCLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n\nAUTO_YES=0\nSKIP_DEPS=0\nINSTALL_CODEX=1\nINSTALL_CLAUDE=1\n\nTMP_DIR=\"\"\nSOURCE_DIR=\"\"\nSOURCE_MODE=\"remote\"\n\n# Available skills to install (each has its own scripts/ subdirectory)\nSKILLS=\"bash-agent cargo-agent go-agent npm-agent py-agent terra-agent\"\nSELECTED_SKILLS=\"\"\n\ninfo() {\n  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n}\n\nwarn() {\n  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n}\n\ndie() {\n  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n  exit 1\n}\n\nusage() {\n  cat <<'EOF'\nInstall x-agent skills and scripts into local agent skill directories.\n\nUsage:\n  sh install.sh [options]\n  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n\nOptions:\n  --yes          Non-interactive mode; accept default install prompts.\n  --skip-deps    Skip dependency checks.\n  --codex-only   Only install to ~/.codex/skills.\n  --claude-only  Only install to ~/.claude/skills.\n  --help         Show this help text.\n\nNotes:\n  Interactive mode prompts per x-agent skill and install destination.\n  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n\nEnvironment variables:\n  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\nEOF\n}\n\ncleanup() {\n  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    rm -rf \"$TMP_DIR\"\n  fi\n}\n\ntrap cleanup EXIT INT TERM\n\nprompt_yes_no() {\n  question=\"$1\"\n  default=\"${2:-yes}\"\n\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    return 0\n  fi\n\n  if [ \"$default\" = \"yes\" ]; then\n    prompt=\"[Y/n]\"\n    fallback=\"yes\"\n  else\n    prompt=\"[y/N]\"\n    fallback=\"no\"\n  fi\n\n  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    while :; do\n      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n      if ! IFS= read -r answer < /dev/tty; then\n        break\n      fi\n      case \"$answer\" in\n        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n        [Nn]|[Nn][Oo]) return 1 ;;\n        \"\")\n          if [ \"$fallback\" = \"yes\" ]; then\n            return 0\n          fi\n          return 1\n          ;;\n        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n      esac\n    done\n  fi\n\n  [ \"$fallback\" = \"yes\" ]\n}\n\nskill_selected() {\n  skill=\"$1\"\n  case \" ${SELECTED_SKILLS} \" in\n    *\" ${skill} \"*) return 0 ;;\n    *) return 1 ;;\n  esac\n}\n\nadd_selected_skill() {\n  skill=\"$1\"\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    SELECTED_SKILLS=\"$skill\"\n  else\n    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n  fi\n}\n\nselect_skills() {\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    SELECTED_SKILLS=\"$SKILLS\"\n    return 0\n  fi\n\n  info \"Select x-agent skills to install:\"\n  for skill in $SKILLS; do\n    if prompt_yes_no \"Install ${skill}?\" yes; then\n      add_selected_skill \"$skill\"\n    fi\n  done\n}\n\nfetch_to_file() {\n  url=\"$1\"\n  out=\"$2\"\n\n  if command -v curl >/dev/null 2>&1; then\n    curl -fsSL \"$url\" -o \"$out\"\n    return 0\n  fi\n\n  if command -v wget >/dev/null 2>&1; then\n    wget -qO \"$out\" \"$url\"\n    return 0\n  fi\n\n  return 1\n}\n\n# Detect if we're running from a local checkout or need to fetch from remote.\nresolve_source_dir() {\n  # Check if running from inside the repo\n  if [ -d \"./skills\" ]; then\n    SOURCE_DIR=\"$(pwd)\"\n    SOURCE_MODE=\"local\"\n    info \"Using local source at ${SOURCE_DIR}.\"\n    return 0\n  fi\n\n  # Check relative to the script location\n  case \"$0\" in\n    */*)\n      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n        SOURCE_DIR=\"$script_dir\"\n        SOURCE_MODE=\"local\"\n        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n        return 0\n      fi\n      ;;\n  esac\n\n  # Remote fetch\n  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n  SOURCE_DIR=\"${TMP_DIR}\"\n  SOURCE_MODE=\"remote\"\n\n  # Fetch shared library\n  mkdir -p \"${SOURCE_DIR}/lib\"\n  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n  info \"Fetching lib/x-agent-common.sh...\"\n  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n    die \"Unable to download ${src_url}\"\n  fi\n\n  # Fetch each selected skill's SKILL.md and scripts\n  for skill in $SELECTED_SKILLS; do\n    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n\n    # Fetch SKILL.md\n    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n    info \"Fetching skills/${skill}/SKILL.md...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n\n    # Fetch the skill's script\n    script_name=\"${skill}.sh\"\n    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n    chmod +x \"$dest\"\n  done\n}\n\n# Install a single skill to a skills root, with scripts alongside it.\ninstall_skill_to_root() {\n  root=\"$1\"\n  skill=\"$2\"\n  target=\"${root}/${skill}\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n    info \"Installed ${skill} to ${target}\"\n  fi\n}\n\n# Install the shared library to a skills root so agent scripts can source it.\n# For local installs, symlink the lib/ directory.\n# For remote installs, copy the fetched lib/ directory.\ninstall_lib_to_root() {\n  root=\"$1\"\n  target=\"${root}/lib\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n    info \"Installed lib to ${target}\"\n  fi\n}\n\n# Rewrite SKILL.md paths to point at the actual installed script location.\npatch_skill_paths() {\n  root=\"$1\"\n  skill=\"$2\"\n  skill_md=\"${root}/${skill}/SKILL.md\"\n\n  if [ ! -f \"$skill_md\" ]; then return; fi\n\n  # For local (symlink) installs, paths already point to the right place via the repo.\n  # For remote installs, update paths to point at the skill's bundled scripts dir.\n  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n    scripts_dir=\"${root}/${skill}/scripts\"\n    # Replace relative scripts/ paths with the actual installed path\n    if command -v sed >/dev/null 2>&1; then\n      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n      rm -f \"${skill_md}.bak\"\n    fi\n  fi\n}\n\ncheck_optional_deps() {\n  info \"Checking optional dependencies...\"\n  all_ok=1\n\n  if skill_selected \"bash-agent\"; then\n    if command -v shellcheck >/dev/null 2>&1; then\n      info \"  Found: shellcheck\"\n    else\n      warn \"  Missing: shellcheck (needed by bash-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"go-agent\"; then\n    if command -v go >/dev/null 2>&1; then\n      info \"  Found: go\"\n    else\n      warn \"  Missing: go (needed by go-agent)\"\n      all_ok=0\n    fi\n\n    if command -v staticcheck >/dev/null 2>&1; then\n      info \"  Found: staticcheck\"\n    else\n      warn \"  Missing: staticcheck (optional for go-agent staticcheck step)\"\n    fi\n  fi\n\n  if skill_selected \"cargo-agent\"; then\n    if command -v jq >/dev/null 2>&1; then\n      info \"  Found: jq\"\n    else\n      warn \"  Missing: jq (needed by cargo-agent)\"\n      all_ok=0\n    fi\n\n    if command -v cargo >/dev/null 2>&1; then\n      info \"  Found: cargo\"\n    else\n      warn \"  Missing: cargo (needed by cargo-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"npm-agent\"; then\n    if command -v node >/dev/null 2>&1; then\n      info \"  Found: node\"\n    else\n      warn \"  Missing: node (needed by npm-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"py-agent\"; then\n    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n      info \"  Found: python\"\n    else\n      warn \"  Missing: python3 (needed by py-agent)\"\n      all_ok=0\n    fi\n\n    for dep in ruff black; do\n      if command -v \"$dep\" >/dev/null 2>&1; then\n        info \"  Found: ${dep}\"\n        break\n      fi\n    done\n  fi\n\n  if skill_selected \"terra-agent\"; then\n    if command -v terraform >/dev/null 2>&1; then\n      info \"  Found: terraform\"\n    else\n      warn \"  Missing: terraform (needed by terra-agent)\"\n      all_ok=0\n    fi\n\n    if command -v tflint >/dev/null 2>&1; then\n      info \"  Found: tflint\"\n    else\n      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n    fi\n  fi\n\n  if [ \"$all_ok\" -eq 0 ]; then\n    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n  fi\n}\n\nprint_agents_md_snippet() {\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    return 0\n  fi\n\n  echo \"\"\n  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n  echo \"## x-agent checks\"\n  echo \"\"\n  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n\n  for skill in $SELECTED_SKILLS; do\n    case \"$skill\" in\n      bash-agent)\n        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n        ;;\n      go-agent)\n        echo \"- Go: use \\`/go-agent\\` (fmt/vet/staticcheck/test).\"\n        ;;\n      cargo-agent)\n        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n        ;;\n      npm-agent)\n        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n        ;;\n      py-agent)\n        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n        ;;\n      terra-agent)\n        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n        ;;\n    esac\n  done\n\n  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n  echo \"- If a change touches multiple stacks, run all matching skills.\"\n  if skill_selected \"terra-agent\"; then\n    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n  fi\n  echo \"- Resolve all FAIL results before completing the task.\"\n  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n}\n\n# --- Main ---\n\nwhile [ $# -gt 0 ]; do\n  case \"$1\" in\n    --yes)\n      AUTO_YES=1\n      ;;\n    --skip-deps)\n      SKIP_DEPS=1\n      ;;\n    --codex-only)\n      INSTALL_CODEX=1\n      INSTALL_CLAUDE=0\n      ;;\n    --claude-only)\n      INSTALL_CODEX=0\n      INSTALL_CLAUDE=1\n      ;;\n    --help|-h)\n      usage\n      exit 0\n      ;;\n    *)\n      die \"Unknown option: $1 (use --help)\"\n      ;;\n  esac\n  shift\ndone\n\ninfo \"x-agent installer\"\ninfo \"==================\"\n\nselect_skills\nif [ -z \"$SELECTED_SKILLS\" ]; then\n  info \"No skills selected. Nothing to install.\"\n  info \"Done.\"\n  exit 0\nfi\n\nresolve_source_dir\n\nif [ \"$SKIP_DEPS\" -eq 0 ]; then\n  check_optional_deps\nelse\n  info \"Skipping dependency checks (--skip-deps).\"\nfi\n\nif [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Claude install.\"\n  fi\nfi\n\nif [ \"$INSTALL_CODEX\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Codex install.\"\n  fi\nfi\n\ninfo \"\"\ninfo \"Installed skills: ${SELECTED_SKILLS}\"\ninfo \"\"\nprint_agents_md_snippet\ninfo \"\"\ninfo \"Done.\"\n","numLines":498,"startLine":1,"totalLines":498}}}
