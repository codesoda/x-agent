{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017PLi39oTpoeVmeZM8farDU","type":"tool_result","content":"     1→#!/bin/sh\n     2→set -eu\n     3→\n     4→# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n     5→# Works via: curl -sSf <raw-url>/install.sh | sh\n     6→# Or locally: sh install.sh\n     7→\n     8→PROJECT_NAME=\"x-agent\"\n     9→REPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\n    10→REPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\n    11→REPO_REF=\"${X_AGENT_REPO_REF:-main}\"\n    12→RAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n    13→\n    14→CODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\n    15→CLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n    16→\n    17→AUTO_YES=0\n    18→SKIP_DEPS=0\n    19→INSTALL_CODEX=1\n    20→INSTALL_CLAUDE=1\n    21→\n    22→TMP_DIR=\"\"\n    23→SOURCE_DIR=\"\"\n    24→SOURCE_MODE=\"remote\"\n    25→\n    26→# Available skills to install (each has its own scripts/ subdirectory)\n    27→SKILLS=\"bash-agent cargo-agent gha-agent go-agent helm-agent kube-agent npm-agent py-agent terra-agent\"\n    28→SELECTED_SKILLS=\"\"\n    29→\n    30→info() {\n    31→  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n    32→}\n    33→\n    34→warn() {\n    35→  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    36→}\n    37→\n    38→die() {\n    39→  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n    40→  exit 1\n    41→}\n    42→\n    43→usage() {\n    44→  cat <<'EOF'\n    45→Install x-agent skills and scripts into local agent skill directories.\n    46→\n    47→Usage:\n    48→  sh install.sh [options]\n    49→  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n    50→\n    51→Options:\n    52→  --yes          Non-interactive mode; accept default install prompts.\n    53→  --skip-deps    Skip dependency checks.\n    54→  --codex-only   Only install to ~/.codex/skills.\n    55→  --claude-only  Only install to ~/.claude/skills.\n    56→  --help         Show this help text.\n    57→\n    58→Notes:\n    59→  Interactive mode prompts per x-agent skill and install destination.\n    60→  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n    61→\n    62→Environment variables:\n    63→  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n    64→  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n    65→  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n    66→  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n    67→  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n    68→  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\n    69→EOF\n    70→}\n    71→\n    72→cleanup() {\n    73→  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    74→    rm -rf \"$TMP_DIR\"\n    75→  fi\n    76→}\n    77→\n    78→trap cleanup EXIT INT TERM\n    79→\n    80→prompt_yes_no() {\n    81→  question=\"$1\"\n    82→  default=\"${2:-yes}\"\n    83→\n    84→  if [ \"$AUTO_YES\" -eq 1 ]; then\n    85→    return 0\n    86→  fi\n    87→\n    88→  if [ \"$default\" = \"yes\" ]; then\n    89→    prompt=\"[Y/n]\"\n    90→    fallback=\"yes\"\n    91→  else\n    92→    prompt=\"[y/N]\"\n    93→    fallback=\"no\"\n    94→  fi\n    95→\n    96→  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    97→    while :; do\n    98→      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n    99→      if ! IFS= read -r answer < /dev/tty; then\n   100→        break\n   101→      fi\n   102→      case \"$answer\" in\n   103→        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n   104→        [Nn]|[Nn][Oo]) return 1 ;;\n   105→        \"\")\n   106→          if [ \"$fallback\" = \"yes\" ]; then\n   107→            return 0\n   108→          fi\n   109→          return 1\n   110→          ;;\n   111→        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n   112→      esac\n   113→    done\n   114→  fi\n   115→\n   116→  [ \"$fallback\" = \"yes\" ]\n   117→}\n   118→\n   119→skill_selected() {\n   120→  skill=\"$1\"\n   121→  case \" ${SELECTED_SKILLS} \" in\n   122→    *\" ${skill} \"*) return 0 ;;\n   123→    *) return 1 ;;\n   124→  esac\n   125→}\n   126→\n   127→add_selected_skill() {\n   128→  skill=\"$1\"\n   129→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   130→    SELECTED_SKILLS=\"$skill\"\n   131→  else\n   132→    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n   133→  fi\n   134→}\n   135→\n   136→select_skills() {\n   137→  if [ \"$AUTO_YES\" -eq 1 ]; then\n   138→    SELECTED_SKILLS=\"$SKILLS\"\n   139→    return 0\n   140→  fi\n   141→\n   142→  info \"Select x-agent skills to install:\"\n   143→  for skill in $SKILLS; do\n   144→    if prompt_yes_no \"Install ${skill}?\" yes; then\n   145→      add_selected_skill \"$skill\"\n   146→    fi\n   147→  done\n   148→}\n   149→\n   150→fetch_to_file() {\n   151→  url=\"$1\"\n   152→  out=\"$2\"\n   153→\n   154→  if command -v curl >/dev/null 2>&1; then\n   155→    curl -fsSL \"$url\" -o \"$out\"\n   156→    return 0\n   157→  fi\n   158→\n   159→  if command -v wget >/dev/null 2>&1; then\n   160→    wget -qO \"$out\" \"$url\"\n   161→    return 0\n   162→  fi\n   163→\n   164→  return 1\n   165→}\n   166→\n   167→# Detect if we're running from a local checkout or need to fetch from remote.\n   168→resolve_source_dir() {\n   169→  # Check if running from inside the repo\n   170→  if [ -d \"./skills\" ]; then\n   171→    SOURCE_DIR=\"$(pwd)\"\n   172→    SOURCE_MODE=\"local\"\n   173→    info \"Using local source at ${SOURCE_DIR}.\"\n   174→    return 0\n   175→  fi\n   176→\n   177→  # Check relative to the script location\n   178→  case \"$0\" in\n   179→    */*)\n   180→      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n   181→      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n   182→        SOURCE_DIR=\"$script_dir\"\n   183→        SOURCE_MODE=\"local\"\n   184→        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n   185→        return 0\n   186→      fi\n   187→      ;;\n   188→  esac\n   189→\n   190→  # Remote fetch\n   191→  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n   192→  SOURCE_DIR=\"${TMP_DIR}\"\n   193→  SOURCE_MODE=\"remote\"\n   194→\n   195→  # Fetch shared library\n   196→  mkdir -p \"${SOURCE_DIR}/lib\"\n   197→  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n   198→  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n   199→  info \"Fetching lib/x-agent-common.sh...\"\n   200→  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   201→    die \"Unable to download ${src_url}\"\n   202→  fi\n   203→\n   204→  # Fetch each selected skill's SKILL.md and scripts\n   205→  for skill in $SELECTED_SKILLS; do\n   206→    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n   207→\n   208→    # Fetch SKILL.md\n   209→    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n   210→    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n   211→    info \"Fetching skills/${skill}/SKILL.md...\"\n   212→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   213→      die \"Unable to download ${src_url}\"\n   214→    fi\n   215→\n   216→    # Fetch the skill's script\n   217→    script_name=\"${skill}.sh\"\n   218→    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n   219→    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n   220→    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n   221→    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n   222→      die \"Unable to download ${src_url}\"\n   223→    fi\n   224→    chmod +x \"$dest\"\n   225→  done\n   226→}\n   227→\n   228→# Install a single skill to a skills root, with scripts alongside it.\n   229→install_skill_to_root() {\n   230→  root=\"$1\"\n   231→  skill=\"$2\"\n   232→  target=\"${root}/${skill}\"\n   233→\n   234→  mkdir -p \"$root\"\n   235→  rm -rf \"$target\"\n   236→\n   237→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   238→    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n   239→    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n   240→  else\n   241→    mkdir -p \"$target\"\n   242→    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n   243→    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n   244→    info \"Installed ${skill} to ${target}\"\n   245→  fi\n   246→}\n   247→\n   248→# Install the shared library to a skills root so agent scripts can source it.\n   249→# For local installs, symlink the lib/ directory.\n   250→# For remote installs, copy the fetched lib/ directory.\n   251→install_lib_to_root() {\n   252→  root=\"$1\"\n   253→  target=\"${root}/lib\"\n   254→\n   255→  mkdir -p \"$root\"\n   256→  rm -rf \"$target\"\n   257→\n   258→  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n   259→    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n   260→    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n   261→  else\n   262→    mkdir -p \"$target\"\n   263→    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n   264→    info \"Installed lib to ${target}\"\n   265→  fi\n   266→}\n   267→\n   268→# Rewrite SKILL.md paths to point at the actual installed script location.\n   269→patch_skill_paths() {\n   270→  root=\"$1\"\n   271→  skill=\"$2\"\n   272→  skill_md=\"${root}/${skill}/SKILL.md\"\n   273→\n   274→  if [ ! -f \"$skill_md\" ]; then return; fi\n   275→\n   276→  # For local (symlink) installs, paths already point to the right place via the repo.\n   277→  # For remote installs, update paths to point at the skill's bundled scripts dir.\n   278→  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n   279→    scripts_dir=\"${root}/${skill}/scripts\"\n   280→    # Replace relative scripts/ paths with the actual installed path\n   281→    if command -v sed >/dev/null 2>&1; then\n   282→      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n   283→      rm -f \"${skill_md}.bak\"\n   284→    fi\n   285→  fi\n   286→}\n   287→\n   288→check_optional_deps() {\n   289→  info \"Checking optional dependencies...\"\n   290→  all_ok=1\n   291→\n   292→  if skill_selected \"bash-agent\"; then\n   293→    if command -v shellcheck >/dev/null 2>&1; then\n   294→      info \"  Found: shellcheck\"\n   295→    else\n   296→      warn \"  Missing: shellcheck (needed by bash-agent)\"\n   297→      all_ok=0\n   298→    fi\n   299→  fi\n   300→\n   301→  if skill_selected \"gha-agent\"; then\n   302→    if command -v actionlint >/dev/null 2>&1; then\n   303→      info \"  Found: actionlint\"\n   304→    else\n   305→      warn \"  Missing: actionlint (needed by gha-agent)\"\n   306→      all_ok=0\n   307→    fi\n   308→  fi\n   309→\n   310→  if skill_selected \"helm-agent\"; then\n   311→    if command -v helm >/dev/null 2>&1; then\n   312→      info \"  Found: helm\"\n   313→    else\n   314→      warn \"  Missing: helm (needed by helm-agent)\"\n   315→      all_ok=0\n   316→    fi\n   317→  fi\n   318→\n   319→  if skill_selected \"kube-agent\"; then\n   320→    if command -v kubeconform >/dev/null 2>&1; then\n   321→      info \"  Found: kubeconform\"\n   322→    elif command -v kubeval >/dev/null 2>&1; then\n   323→      info \"  Found: kubeval\"\n   324→    else\n   325→      warn \"  Missing: kubeconform or kubeval (needed by kube-agent)\"\n   326→      all_ok=0\n   327→    fi\n   328→  fi\n   329→\n   330→  if skill_selected \"go-agent\"; then\n   331→    if command -v go >/dev/null 2>&1; then\n   332→      info \"  Found: go\"\n   333→    else\n   334→      warn \"  Missing: go (needed by go-agent)\"\n   335→      all_ok=0\n   336→    fi\n   337→\n   338→    if command -v staticcheck >/dev/null 2>&1; then\n   339→      info \"  Found: staticcheck\"\n   340→    else\n   341→      warn \"  Missing: staticcheck (optional for go-agent staticcheck step)\"\n   342→    fi\n   343→  fi\n   344→\n   345→  if skill_selected \"cargo-agent\"; then\n   346→    if command -v jq >/dev/null 2>&1; then\n   347→      info \"  Found: jq\"\n   348→    else\n   349→      warn \"  Missing: jq (needed by cargo-agent)\"\n   350→      all_ok=0\n   351→    fi\n   352→\n   353→    if command -v cargo >/dev/null 2>&1; then\n   354→      info \"  Found: cargo\"\n   355→    else\n   356→      warn \"  Missing: cargo (needed by cargo-agent)\"\n   357→      all_ok=0\n   358→    fi\n   359→  fi\n   360→\n   361→  if skill_selected \"npm-agent\"; then\n   362→    if command -v node >/dev/null 2>&1; then\n   363→      info \"  Found: node\"\n   364→    else\n   365→      warn \"  Missing: node (needed by npm-agent)\"\n   366→      all_ok=0\n   367→    fi\n   368→  fi\n   369→\n   370→  if skill_selected \"py-agent\"; then\n   371→    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n   372→      info \"  Found: python\"\n   373→    else\n   374→      warn \"  Missing: python3 (needed by py-agent)\"\n   375→      all_ok=0\n   376→    fi\n   377→\n   378→    for dep in ruff black; do\n   379→      if command -v \"$dep\" >/dev/null 2>&1; then\n   380→        info \"  Found: ${dep}\"\n   381→        break\n   382→      fi\n   383→    done\n   384→  fi\n   385→\n   386→  if skill_selected \"terra-agent\"; then\n   387→    if command -v terraform >/dev/null 2>&1; then\n   388→      info \"  Found: terraform\"\n   389→    else\n   390→      warn \"  Missing: terraform (needed by terra-agent)\"\n   391→      all_ok=0\n   392→    fi\n   393→\n   394→    if command -v tflint >/dev/null 2>&1; then\n   395→      info \"  Found: tflint\"\n   396→    else\n   397→      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n   398→    fi\n   399→  fi\n   400→\n   401→  if [ \"$all_ok\" -eq 0 ]; then\n   402→    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n   403→  fi\n   404→}\n   405→\n   406→print_agents_md_snippet() {\n   407→  if [ -z \"$SELECTED_SKILLS\" ]; then\n   408→    return 0\n   409→  fi\n   410→\n   411→  echo \"\"\n   412→  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n   413→  echo \"## x-agent checks\"\n   414→  echo \"\"\n   415→  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n   416→\n   417→  for skill in $SELECTED_SKILLS; do\n   418→    case \"$skill\" in\n   419→      bash-agent)\n   420→        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n   421→        ;;\n   422→      gha-agent)\n   423→        echo \"- GitHub Actions: use \\`/gha-agent\\` (lint).\"\n   424→        ;;\n   425→      helm-agent)\n   426→        echo \"- Helm: use \\`/helm-agent\\` (lint/template).\"\n   427→        ;;\n   428→      kube-agent)\n   429→        echo \"- Kubernetes: use \\`/kube-agent\\` (validate manifests).\"\n   430→        ;;\n   431→      go-agent)\n   432→        echo \"- Go: use \\`/go-agent\\` (fmt/vet/staticcheck/test).\"\n   433→        ;;\n   434→      cargo-agent)\n   435→        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n   436→        ;;\n   437→      npm-agent)\n   438→        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n   439→        ;;\n   440→      py-agent)\n   441→        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n   442→        ;;\n   443→      terra-agent)\n   444→        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n   445→        ;;\n   446→    esac\n   447→  done\n   448→\n   449→  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n   450→  echo \"- If a change touches multiple stacks, run all matching skills.\"\n   451→  if skill_selected \"terra-agent\"; then\n   452→    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n   453→    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n   454→  fi\n   455→  echo \"- Resolve all FAIL results before completing the task.\"\n   456→  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n   457→}\n   458→\n   459→# --- Main ---\n   460→\n   461→while [ $# -gt 0 ]; do\n   462→  case \"$1\" in\n   463→    --yes)\n   464→      AUTO_YES=1\n   465→      ;;\n   466→    --skip-deps)\n   467→      SKIP_DEPS=1\n   468→      ;;\n   469→    --codex-only)\n   470→      INSTALL_CODEX=1\n   471→      INSTALL_CLAUDE=0\n   472→      ;;\n   473→    --claude-only)\n   474→      INSTALL_CODEX=0\n   475→      INSTALL_CLAUDE=1\n   476→      ;;\n   477→    --help|-h)\n   478→      usage\n   479→      exit 0\n   480→      ;;\n   481→    *)\n   482→      die \"Unknown option: $1 (use --help)\"\n   483→      ;;\n   484→  esac\n   485→  shift\n   486→done\n   487→\n   488→info \"x-agent installer\"\n   489→info \"==================\"\n   490→\n   491→select_skills\n   492→if [ -z \"$SELECTED_SKILLS\" ]; then\n   493→  info \"No skills selected. Nothing to install.\"\n   494→  info \"Done.\"\n   495→  exit 0\n   496→fi\n   497→\n   498→resolve_source_dir\n   499→\n   500→if [ \"$SKIP_DEPS\" -eq 0 ]; then\n   501→  check_optional_deps\n   502→else\n   503→  info \"Skipping dependency checks (--skip-deps).\"\n   504→fi\n   505→\n   506→if [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n   507→  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n   508→    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n   509→    for skill in $SELECTED_SKILLS; do\n   510→      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   511→      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n   512→    done\n   513→  else\n   514→    info \"Skipped Claude install.\"\n   515→  fi\n   516→fi\n   517→\n   518→if [ \"$INSTALL_CODEX\" -eq 1 ]; then\n   519→  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n   520→    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n   521→    for skill in $SELECTED_SKILLS; do\n   522→      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n   523→      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n   524→    done\n   525→  else\n   526→    info \"Skipped Codex install.\"\n   527→  fi\n   528→fi\n   529→\n   530→info \"\"\n   531→info \"Installed skills: ${SELECTED_SKILLS}\"\n   532→info \"\"\n   533→print_agents_md_snippet\n   534→info \"\"\n   535→info \"Done.\"\n   536→"}]},"parent_tool_use_id":null,"session_id":"46dcc7a2-447a-40b5-b7b3-893789d3fd2e","uuid":"9cc9446e-5420-476f-b603-77b4cb6ea600","tool_use_result":{"type":"text","file":{"filePath":"/Users/chrisraethke/projects/x-agent/install.sh","content":"#!/bin/sh\nset -eu\n\n# x-agent installer: installs agent-friendly workflow scripts and Claude/Codex skills.\n# Works via: curl -sSf <raw-url>/install.sh | sh\n# Or locally: sh install.sh\n\nPROJECT_NAME=\"x-agent\"\nREPO_OWNER=\"${X_AGENT_REPO_OWNER:-codesoda}\"\nREPO_NAME=\"${X_AGENT_REPO_NAME:-x-agent}\"\nREPO_REF=\"${X_AGENT_REPO_REF:-main}\"\nRAW_BASE=\"${X_AGENT_RAW_BASE:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}\"\n\nCODEX_SKILLS_DIR=\"${CODEX_SKILLS_DIR:-$HOME/.codex/skills}\"\nCLAUDE_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n\nAUTO_YES=0\nSKIP_DEPS=0\nINSTALL_CODEX=1\nINSTALL_CLAUDE=1\n\nTMP_DIR=\"\"\nSOURCE_DIR=\"\"\nSOURCE_MODE=\"remote\"\n\n# Available skills to install (each has its own scripts/ subdirectory)\nSKILLS=\"bash-agent cargo-agent gha-agent go-agent helm-agent kube-agent npm-agent py-agent terra-agent\"\nSELECTED_SKILLS=\"\"\n\ninfo() {\n  printf \"[%s] %s\\n\" \"$PROJECT_NAME\" \"$*\"\n}\n\nwarn() {\n  printf \"[%s] WARNING: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n}\n\ndie() {\n  printf \"[%s] ERROR: %s\\n\" \"$PROJECT_NAME\" \"$*\" >&2\n  exit 1\n}\n\nusage() {\n  cat <<'EOF'\nInstall x-agent skills and scripts into local agent skill directories.\n\nUsage:\n  sh install.sh [options]\n  curl -sSf https://raw.githubusercontent.com/codesoda/x-agent/main/install.sh | sh\n\nOptions:\n  --yes          Non-interactive mode; accept default install prompts.\n  --skip-deps    Skip dependency checks.\n  --codex-only   Only install to ~/.codex/skills.\n  --claude-only  Only install to ~/.claude/skills.\n  --help         Show this help text.\n\nNotes:\n  Interactive mode prompts per x-agent skill and install destination.\n  At the end, the installer prints a copy/paste snippet for AGENTS.md/CLAUDE.md.\n\nEnvironment variables:\n  CODEX_SKILLS_DIR   Override Codex skills root (default: ~/.codex/skills)\n  CLAUDE_SKILLS_DIR  Override Claude skills root (default: ~/.claude/skills)\n  X_AGENT_REPO_OWNER Override repo owner for remote fetches.\n  X_AGENT_REPO_NAME  Override repo name for remote fetches.\n  X_AGENT_REPO_REF   Override repo ref/branch for remote fetches.\n  X_AGENT_RAW_BASE   Override full raw base URL for remote fetches.\nEOF\n}\n\ncleanup() {\n  if [ -n \"$TMP_DIR\" ] && [ -d \"$TMP_DIR\" ]; then\n    rm -rf \"$TMP_DIR\"\n  fi\n}\n\ntrap cleanup EXIT INT TERM\n\nprompt_yes_no() {\n  question=\"$1\"\n  default=\"${2:-yes}\"\n\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    return 0\n  fi\n\n  if [ \"$default\" = \"yes\" ]; then\n    prompt=\"[Y/n]\"\n    fallback=\"yes\"\n  else\n    prompt=\"[y/N]\"\n    fallback=\"no\"\n  fi\n\n  if [ -r /dev/tty ] && [ -w /dev/tty ]; then\n    while :; do\n      printf \"%s %s \" \"$question\" \"$prompt\" > /dev/tty\n      if ! IFS= read -r answer < /dev/tty; then\n        break\n      fi\n      case \"$answer\" in\n        [Yy]|[Yy][Ee][Ss]) return 0 ;;\n        [Nn]|[Nn][Oo]) return 1 ;;\n        \"\")\n          if [ \"$fallback\" = \"yes\" ]; then\n            return 0\n          fi\n          return 1\n          ;;\n        *) printf \"Please answer yes or no.\\n\" > /dev/tty ;;\n      esac\n    done\n  fi\n\n  [ \"$fallback\" = \"yes\" ]\n}\n\nskill_selected() {\n  skill=\"$1\"\n  case \" ${SELECTED_SKILLS} \" in\n    *\" ${skill} \"*) return 0 ;;\n    *) return 1 ;;\n  esac\n}\n\nadd_selected_skill() {\n  skill=\"$1\"\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    SELECTED_SKILLS=\"$skill\"\n  else\n    SELECTED_SKILLS=\"${SELECTED_SKILLS} ${skill}\"\n  fi\n}\n\nselect_skills() {\n  if [ \"$AUTO_YES\" -eq 1 ]; then\n    SELECTED_SKILLS=\"$SKILLS\"\n    return 0\n  fi\n\n  info \"Select x-agent skills to install:\"\n  for skill in $SKILLS; do\n    if prompt_yes_no \"Install ${skill}?\" yes; then\n      add_selected_skill \"$skill\"\n    fi\n  done\n}\n\nfetch_to_file() {\n  url=\"$1\"\n  out=\"$2\"\n\n  if command -v curl >/dev/null 2>&1; then\n    curl -fsSL \"$url\" -o \"$out\"\n    return 0\n  fi\n\n  if command -v wget >/dev/null 2>&1; then\n    wget -qO \"$out\" \"$url\"\n    return 0\n  fi\n\n  return 1\n}\n\n# Detect if we're running from a local checkout or need to fetch from remote.\nresolve_source_dir() {\n  # Check if running from inside the repo\n  if [ -d \"./skills\" ]; then\n    SOURCE_DIR=\"$(pwd)\"\n    SOURCE_MODE=\"local\"\n    info \"Using local source at ${SOURCE_DIR}.\"\n    return 0\n  fi\n\n  # Check relative to the script location\n  case \"$0\" in\n    */*)\n      script_dir=\"$(cd \"$(dirname \"$0\")\" 2>/dev/null && pwd || true)\"\n      if [ -n \"$script_dir\" ] && [ -d \"$script_dir/skills\" ]; then\n        SOURCE_DIR=\"$script_dir\"\n        SOURCE_MODE=\"local\"\n        info \"Using source next to install.sh at ${SOURCE_DIR}.\"\n        return 0\n      fi\n      ;;\n  esac\n\n  # Remote fetch\n  TMP_DIR=\"$(mktemp -d \"${TMPDIR:-/tmp}/${PROJECT_NAME}.XXXXXX\")\"\n  SOURCE_DIR=\"${TMP_DIR}\"\n  SOURCE_MODE=\"remote\"\n\n  # Fetch shared library\n  mkdir -p \"${SOURCE_DIR}/lib\"\n  src_url=\"${RAW_BASE}/lib/x-agent-common.sh\"\n  dest=\"${SOURCE_DIR}/lib/x-agent-common.sh\"\n  info \"Fetching lib/x-agent-common.sh...\"\n  if ! fetch_to_file \"$src_url\" \"$dest\"; then\n    die \"Unable to download ${src_url}\"\n  fi\n\n  # Fetch each selected skill's SKILL.md and scripts\n  for skill in $SELECTED_SKILLS; do\n    mkdir -p \"${SOURCE_DIR}/skills/${skill}/scripts\"\n\n    # Fetch SKILL.md\n    src_url=\"${RAW_BASE}/skills/${skill}/SKILL.md\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/SKILL.md\"\n    info \"Fetching skills/${skill}/SKILL.md...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n\n    # Fetch the skill's script\n    script_name=\"${skill}.sh\"\n    src_url=\"${RAW_BASE}/skills/${skill}/scripts/${script_name}\"\n    dest=\"${SOURCE_DIR}/skills/${skill}/scripts/${script_name}\"\n    info \"Fetching skills/${skill}/scripts/${script_name}...\"\n    if ! fetch_to_file \"$src_url\" \"$dest\"; then\n      die \"Unable to download ${src_url}\"\n    fi\n    chmod +x \"$dest\"\n  done\n}\n\n# Install a single skill to a skills root, with scripts alongside it.\ninstall_skill_to_root() {\n  root=\"$1\"\n  skill=\"$2\"\n  target=\"${root}/${skill}\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/skills/${skill}\" \"$target\"\n    info \"Symlinked ${skill} to ${target} -> ${SOURCE_DIR}/skills/${skill}\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/skills/${skill}/.\" \"$target/\"\n    chmod +x \"${target}/scripts/\"*.sh 2>/dev/null || true\n    info \"Installed ${skill} to ${target}\"\n  fi\n}\n\n# Install the shared library to a skills root so agent scripts can source it.\n# For local installs, symlink the lib/ directory.\n# For remote installs, copy the fetched lib/ directory.\ninstall_lib_to_root() {\n  root=\"$1\"\n  target=\"${root}/lib\"\n\n  mkdir -p \"$root\"\n  rm -rf \"$target\"\n\n  if [ \"$SOURCE_MODE\" = \"local\" ]; then\n    ln -s \"${SOURCE_DIR}/lib\" \"$target\"\n    info \"Symlinked lib to ${target} -> ${SOURCE_DIR}/lib\"\n  else\n    mkdir -p \"$target\"\n    cp -R \"${SOURCE_DIR}/lib/.\" \"$target/\"\n    info \"Installed lib to ${target}\"\n  fi\n}\n\n# Rewrite SKILL.md paths to point at the actual installed script location.\npatch_skill_paths() {\n  root=\"$1\"\n  skill=\"$2\"\n  skill_md=\"${root}/${skill}/SKILL.md\"\n\n  if [ ! -f \"$skill_md\" ]; then return; fi\n\n  # For local (symlink) installs, paths already point to the right place via the repo.\n  # For remote installs, update paths to point at the skill's bundled scripts dir.\n  if [ \"$SOURCE_MODE\" = \"remote\" ]; then\n    scripts_dir=\"${root}/${skill}/scripts\"\n    # Replace relative scripts/ paths with the actual installed path\n    if command -v sed >/dev/null 2>&1; then\n      sed -i.bak \"s|scripts/${skill}.sh|${scripts_dir}/${skill}.sh|g\" \"$skill_md\"\n      rm -f \"${skill_md}.bak\"\n    fi\n  fi\n}\n\ncheck_optional_deps() {\n  info \"Checking optional dependencies...\"\n  all_ok=1\n\n  if skill_selected \"bash-agent\"; then\n    if command -v shellcheck >/dev/null 2>&1; then\n      info \"  Found: shellcheck\"\n    else\n      warn \"  Missing: shellcheck (needed by bash-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"gha-agent\"; then\n    if command -v actionlint >/dev/null 2>&1; then\n      info \"  Found: actionlint\"\n    else\n      warn \"  Missing: actionlint (needed by gha-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"helm-agent\"; then\n    if command -v helm >/dev/null 2>&1; then\n      info \"  Found: helm\"\n    else\n      warn \"  Missing: helm (needed by helm-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"kube-agent\"; then\n    if command -v kubeconform >/dev/null 2>&1; then\n      info \"  Found: kubeconform\"\n    elif command -v kubeval >/dev/null 2>&1; then\n      info \"  Found: kubeval\"\n    else\n      warn \"  Missing: kubeconform or kubeval (needed by kube-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"go-agent\"; then\n    if command -v go >/dev/null 2>&1; then\n      info \"  Found: go\"\n    else\n      warn \"  Missing: go (needed by go-agent)\"\n      all_ok=0\n    fi\n\n    if command -v staticcheck >/dev/null 2>&1; then\n      info \"  Found: staticcheck\"\n    else\n      warn \"  Missing: staticcheck (optional for go-agent staticcheck step)\"\n    fi\n  fi\n\n  if skill_selected \"cargo-agent\"; then\n    if command -v jq >/dev/null 2>&1; then\n      info \"  Found: jq\"\n    else\n      warn \"  Missing: jq (needed by cargo-agent)\"\n      all_ok=0\n    fi\n\n    if command -v cargo >/dev/null 2>&1; then\n      info \"  Found: cargo\"\n    else\n      warn \"  Missing: cargo (needed by cargo-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"npm-agent\"; then\n    if command -v node >/dev/null 2>&1; then\n      info \"  Found: node\"\n    else\n      warn \"  Missing: node (needed by npm-agent)\"\n      all_ok=0\n    fi\n  fi\n\n  if skill_selected \"py-agent\"; then\n    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then\n      info \"  Found: python\"\n    else\n      warn \"  Missing: python3 (needed by py-agent)\"\n      all_ok=0\n    fi\n\n    for dep in ruff black; do\n      if command -v \"$dep\" >/dev/null 2>&1; then\n        info \"  Found: ${dep}\"\n        break\n      fi\n    done\n  fi\n\n  if skill_selected \"terra-agent\"; then\n    if command -v terraform >/dev/null 2>&1; then\n      info \"  Found: terraform\"\n    else\n      warn \"  Missing: terraform (needed by terra-agent)\"\n      all_ok=0\n    fi\n\n    if command -v tflint >/dev/null 2>&1; then\n      info \"  Found: tflint\"\n    else\n      warn \"  Missing: tflint (optional for terra-agent lint step)\"\n    fi\n  fi\n\n  if [ \"$all_ok\" -eq 0 ]; then\n    warn \"Some optional dependencies are missing. Skills will skip steps that need them.\"\n  fi\n}\n\nprint_agents_md_snippet() {\n  if [ -z \"$SELECTED_SKILLS\" ]; then\n    return 0\n  fi\n\n  echo \"\"\n  echo \"----- BEGIN AGENTS/CLAUDE SNIPPET -----\"\n  echo \"## x-agent checks\"\n  echo \"\"\n  echo \"Before completing work, run the relevant x-agent checks in dedicated sub-agents for the stacks you changed:\"\n\n  for skill in $SELECTED_SKILLS; do\n    case \"$skill\" in\n      bash-agent)\n        echo \"- Bash/Shell: use \\`/bash-agent\\` (syntax/lint).\"\n        ;;\n      gha-agent)\n        echo \"- GitHub Actions: use \\`/gha-agent\\` (lint).\"\n        ;;\n      helm-agent)\n        echo \"- Helm: use \\`/helm-agent\\` (lint/template).\"\n        ;;\n      kube-agent)\n        echo \"- Kubernetes: use \\`/kube-agent\\` (validate manifests).\"\n        ;;\n      go-agent)\n        echo \"- Go: use \\`/go-agent\\` (fmt/vet/staticcheck/test).\"\n        ;;\n      cargo-agent)\n        echo \"- Rust: use \\`/cargo-agent\\` (fmt/check/clippy/test).\"\n        ;;\n      npm-agent)\n        echo \"- Node.js: use \\`/npm-agent\\` (format/lint/typecheck/test/build).\"\n        ;;\n      py-agent)\n        echo \"- Python: use \\`/py-agent\\` (format/lint/typecheck/test).\"\n        ;;\n      terra-agent)\n        echo \"- Terraform: use \\`/terra-agent\\` (fmt-check/fmt-fix/init/plan-safe/validate/lint).\"\n        ;;\n    esac\n  done\n\n  echo \"- Launch stack-specific sub-agents to run these checks; do not skip them in the main agent.\"\n  echo \"- If a change touches multiple stacks, run all matching skills.\"\n  if skill_selected \"terra-agent\"; then\n    echo \"- For Terraform formatting drift, run \\`/terra-agent fmt-check\\`; if it fails, run \\`/terra-agent fmt-fix\\` and then re-run checks.\"\n    echo \"- For safe planning, run \\`/terra-agent plan-safe\\` (exit code 2 = changes detected, not failure).\"\n  fi\n  echo \"- Resolve all FAIL results before completing the task.\"\n  echo \"----- END AGENTS/CLAUDE SNIPPET -----\"\n}\n\n# --- Main ---\n\nwhile [ $# -gt 0 ]; do\n  case \"$1\" in\n    --yes)\n      AUTO_YES=1\n      ;;\n    --skip-deps)\n      SKIP_DEPS=1\n      ;;\n    --codex-only)\n      INSTALL_CODEX=1\n      INSTALL_CLAUDE=0\n      ;;\n    --claude-only)\n      INSTALL_CODEX=0\n      INSTALL_CLAUDE=1\n      ;;\n    --help|-h)\n      usage\n      exit 0\n      ;;\n    *)\n      die \"Unknown option: $1 (use --help)\"\n      ;;\n  esac\n  shift\ndone\n\ninfo \"x-agent installer\"\ninfo \"==================\"\n\nselect_skills\nif [ -z \"$SELECTED_SKILLS\" ]; then\n  info \"No skills selected. Nothing to install.\"\n  info \"Done.\"\n  exit 0\nfi\n\nresolve_source_dir\n\nif [ \"$SKIP_DEPS\" -eq 0 ]; then\n  check_optional_deps\nelse\n  info \"Skipping dependency checks (--skip-deps).\"\nfi\n\nif [ \"$INSTALL_CLAUDE\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CLAUDE_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CLAUDE_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CLAUDE_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Claude install.\"\n  fi\nfi\n\nif [ \"$INSTALL_CODEX\" -eq 1 ]; then\n  if prompt_yes_no \"Install skills to ${CODEX_SKILLS_DIR}?\" yes; then\n    install_lib_to_root \"$CODEX_SKILLS_DIR\"\n    for skill in $SELECTED_SKILLS; do\n      install_skill_to_root \"$CODEX_SKILLS_DIR\" \"$skill\"\n      patch_skill_paths \"$CODEX_SKILLS_DIR\" \"$skill\"\n    done\n  else\n    info \"Skipped Codex install.\"\n  fi\nfi\n\ninfo \"\"\ninfo \"Installed skills: ${SELECTED_SKILLS}\"\ninfo \"\"\nprint_agents_md_snippet\ninfo \"\"\ninfo \"Done.\"\n","numLines":536,"startLine":1,"totalLines":536}}}
