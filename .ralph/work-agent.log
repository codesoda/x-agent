use.\n    48→should_continue() { [[ \"$FAIL_FAST\" != \"1\" || \"$overall_ok\" == \"1\" ]]; }\n    49→\n    50→# ---------------------------------------------------------------------------\n    51→# Dependency checking\n    52→# ---------------------------------------------------------------------------\n    53→\n    54→need() {\n    55→  command -v \"$1\" >/dev/null 2>&1 || { echo \"Missing required tool: $1\" >&2; exit 2; }\n    56→}\n    57→\n    58→# ---------------------------------------------------------------------------\n    59→# Setup helpers (called explicitly by agents, not auto-executed)\n    60→# ---------------------------------------------------------------------------\n    61→\n    62→# Create a temp output directory and install a cleanup trap.\n    63→# Usage: setup_outdir <agent-name>\n    64→# Sets: OUTDIR\n    65→setup_outdir() {\n    66→  local agent_name=\"$1\"\n    67→  OUTDIR=\"$(mktemp -d \"${TMPDIR_ROOT%/}/${agent_name}.XXXXXX\")\"\n    68→\n    69→  # Define the cleanup function inside setup_outdir so it captures OUTDIR.\n    70→  _xagent_cleanup() {\n    71→    local code=\"$?\"\n    72→    if [[ \"${KEEP_DIR:-0}\" == \"1\" || \"$code\" != \"0\" ]]; then\n    73→      echo \"Logs kept in: $OUTDIR\"\n    74→    else\n    75→      rm -rf \"$OUTDIR\"\n    76→    fi\n    77→    exit \"$code\"\n    78→  }\n    79→\n    80→  trap _xagent_cleanup EXIT\n    81→}\n    82→\n    83→# Acquire a workflow lock to prevent concurrent agent runs.\n    84→# Usage: setup_lock <agent-name>\n    85→setup_lock() {\n    86→  local agent_name=\"$1\"\n    87→  local lockfile=\"${TMPDIR_ROOT%/}/${agent_name}.lock\"\n    88→\n    89→  # Open fd 9 for locking.\n    90→  exec 9>\"$lockfile\"\n    91→\n    92→  if command -v flock >/dev/null 2>&1; then\n    93→    if ! flock -n 9; then\n    94→      echo \"${agent_name}: waiting for another run to finish...\"\n    95→      flock 9\n    96→    fi\n    97→  elif command -v perl >/dev/null 2>&1; then\n    98→    # macOS