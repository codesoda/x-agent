E_SKILLS_DIR=\"${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}\"\n\nAUTO_YES=0\nSKIP_DEPS=0\nINSTALL_CODEX=1\nINSTALL_CLAUDE=1\n\nTMP_DIR=\"\"\nSOURCE_DIR=\"\"\nSOURCE_MODE=\"remote\"\n\n# Available skills to install (each has its own scripts/ subdirectory)\nSKILLS=\"bash-agent cargo-agent go-agent npm-agent py-agent terra-agent\"\nSELECTED_SKILLS=\"\"\n\ninfo() {","numLines":30,"startLine":1,"totalLines":498}}}
